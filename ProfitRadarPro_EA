            {
               InpDashBgColor = newVal;
               Print("[SYNC] Dashboard colore sfondo da dashboard: ", newVal);
            }
         }
      }
   }

   //--- Estrai dash_bg
   int pos_dash_bg = StringFind(respStr, "\"dash_bg\"", cfgPos);
   if(pos_dash_bg >= 0)
   {
      int colonP = StringFind(respStr, ":", pos_dash_bg);
      if(colonP >= 0)
      {
         string valStr = StringSubstr(respStr, colonP + 1, 6);
         bool newVal = (StringFind(valStr, "true") >= 0);
         if(newVal != InpDashBg)
         {
            InpDashBg = newVal;
            Print("[SYNC] Dashboard sfondo ", (newVal ? "ATTIVATO" : "DISATTIVATO"), " da dashboard");
         }
      }
   }
}
