      response += CharToString(result[i]);

   return response;
}

//--- Estrae confidence dalla risposta JSON
//    Cerca: "confidence":78  o  "confidence": 78
int AIParseConfidence(string response)
{
   //--- Cerca "confidence"
   int pos = StringFind(response, "\"confidence\"");
   if(pos < 0) pos = StringFind(response, "\"conf\"");
   if(pos < 0)
   {
      Print("[AI] PARSE: 'confidence' non trovato in risposta");
      return 0;
   }

   //--- Trova il due punti
   int colonPos = StringFind(response, ":", pos);
   if(colonPos < 0) return 0;

   //--- Trova il numero
   int start = colonPos + 1;
   string numStr = "";
   for(int i = start; i < StringLen(response); i++)
   {
      string ch = StringSubstr(response, i, 1);
      if((ch >= "0" && ch <= "9") || ch == ".")
         numStr += ch;
      else if(StringLen(numStr) > 0)
         break;
   }

   if(StringLen(numStr) == 0) return 0;

   return (int)StringToDouble(numStr);
}

//--- Estrae signal dalla risposta JSON
//    Cerca: "signal":"BUY"  o  "signal": "SELL"
string AIParseSignal(string response)
{
   int pos = StringFind(response, "\"signal\"");
   if(pos < 0) return "";

   int colonPos = StringFind(response, ":", pos);
   if(colonPos < 0) return "";

   //--- Trova le virgolette
   int startQ = StringFind(response, "\"", colonPos);
   if(startQ < 0) return "";
   int endQ = StringFind(response, "\"", startQ + 1);
   if(endQ < 0) return "";

   string sig = StringSubstr(response, startQ + 1, endQ - startQ - 1);
   StringToUpper(sig);
   return sig;
}

//+------------------------------------------------------------------+
// |  FEEDBACK TRACKING — Salva dati trade aperto per feedback futuro  |
//+------------------------------------------------------------------+
void StoreTradeForFeedback(int ticket, int idx, string tag, bool isLong)
{
   //--- Trova slot libero (o ricicla il piu' vecchio)
   int slot = -1;
   for(int i = 0; i < g_fbCount; i++)
   {
      if(g_fbTicket[i] == 0 || g_fbSent[i])
      {
         slot = i;
         break;
      }
   }
   if(slot < 0)
   {
      if(g_fbCount < MAX_TRADES_TRACK)
      {
         slot = g_fbCount;
         g_fbCount++;
      }
      else
      {
         // Sovrascrivi il piu' vecchio (primo slot)
         slot = 0;
      }
   }

   g_fbTicket[slot]    = ticket;
   g_fbSymbol[slot]    = NormSym(g_symbol[idx]);
   g_fbDirection[slot] = isLong ? "BUY" : "SELL";
   g_fbModule[slot]    = tag;
   g_fbRV[slot]        = g_radarValue[idx];
   g_fbADX[slot]       = g_adx[idx];
   g_fbADRPct[slot]    = g_adrPercent[idx];
   g_fbHist[slot]      = HistStateStr(g_histogramState[idx]);
   g_fbAIConf[slot]    = g_aiLastConf;
   g_fbAISignal[slot]  = g_aiLastSignal;
   g_fbEntryPrice[slot]= isLong ? MarketInfo(g_symbol[idx], MODE_ASK)
                                : MarketInfo(g_symbol[idx], MODE_BID);
   g_fbSent[slot]      = false;

   //--- Momentum metrics
   g_fbNormMom[slot]   = g_normMomentum[idx];
   g_fbMomAccel[slot]  = g_momentumAccel[idx];
   g_fbMomDist[slot]   = g_momentumDist[idx];
   g_fbCompress[slot]  = g_isCompressing[idx];

   Print("[FEEDBACK] Salvato ticket #", ticket, " ", NormSym(g_symbol[idx]),
         " ", (isLong ? "BUY" : "SELL"), " | slot ", slot, "/", g_fbCount);
}

