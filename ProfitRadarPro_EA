string PadZero(int n)
{
   if(n < 10) return "0" + IntegerToString(n);
   return IntegerToString(n);
}

int FindSymbolIndex(string sym)
{
   string norm = NormSym(sym);
   for(int i = 0; i < g_dataCount; i++)
      if(NormSym(g_symbol[i]) == norm) return i;
   return -1;
}

string RXStr(int rxType, int rxAge, bool rxPresent)
{
   if(!rxPresent) return "---";
   return ((rxType == RX_NEW_H) ? "NEW-H" : "NEW-L") + IntegerToString(rxAge);
}

string HistStateStr(int hs)
{
   switch(hs)
   {
      case HS_GREEN_LIGHT: return "GREEN_LIGHT";
      case HS_GREEN_DARK:  return "GREEN_DARK";
      case HS_RED_LIGHT:   return "RED_LIGHT";
      case HS_RED_DARK:    return "RED_DARK";
      case HS_GRAY:        return "GRAY";
      default:             return "UNKNOWN";
   }
}

string RadarTypeStr(int rt)
{
   switch(rt)
   {
      case RT_LONG:    return "LONG";
      case RT_SHORT:   return "SHORT";
      case RT_RISE:    return "RISE";
      case RT_FALL:    return "FALL";
      default:         return "UNKNOWN";
