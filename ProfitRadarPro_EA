//--- Calcola il picco medio del Radar Value su M15 per ciascun cross usando i 4 picchi maggiori negli ultimi 10 giorni
double CalculateAveragePeak(string sym, int lookbackBars)
{
   double peaks[100];
   ArrayInitialize(peaks, 0.0);
   int peakCount = 0;
   
   double currentWaveMax = 0;
   bool inWave = false;
   
   for(int b = lookbackBars - 1; b >= 0; b--)
   {
      double val = 0;
      string histSt = "";
      GetRadarData(sym, b, val, histSt);
      
      double absVal = MathAbs(val);
      if(absVal > 0.01 && histSt != "GRAY" && histSt != "NONE")
      {
         inWave = true;
         if(absVal > currentWaveMax)
         {
            currentWaveMax = absVal;
         }
      }
      else
      {
         if(inWave)
         {
            // La wave e' finita, registriamo il picco
            if(currentWaveMax > 15.0 && currentWaveMax < 150.0) // Escludi piccoli sali-scendi o valori pazzi
            {
               if(peakCount < 100)
               {
                  peaks[peakCount] = currentWaveMax;
                  peakCount++;
               }
            }
            inWave = false;
            currentWaveMax = 0;
         }
      }
   }
   
   // Se l'ultima wave e' ancora aperta alla fine dello storico analizzato
   if(inWave && currentWaveMax > 15.0 && currentWaveMax < 150.0 && peakCount < 100)
   {
      peaks[peakCount] = currentWaveMax;
      peakCount++;
   }
   
   if(peakCount > 0)
   {
      // Ordiniamo l'array in ordine crescente. I picchi maggiori saranno alla fine dell'array (indici alti).
      ArraySort(peaks, WHOLE_ARRAY, 0, MODE_ASCEND);
      
      double sum = 0;
      int countToAverage = MathMin(4, peakCount); // Ne prendiamo al massimo 4 (i maggiori)
      
      for(int j = 0; j < countToAverage; j++)
      {
         sum += peaks[100 - 1 - j];
      }
      
      return sum / countToAverage;
   }
   return 0; // Fallback se nessun picco trovato
}

//--- Calcola e aggiorna i picchi per tutti i cross attivi
void UpdateDynamicPeaks()
{
   Print("[PEAK] Inizio calcolo picchi dinamici per i 28 cross...");
   for(int i = 0; i < g_dataCount; i++)
   {
      string sym = g_symbol[i];
      double avgPeak = CalculateAveragePeak(sym, 1000); // scansione di 1000 barre M15 (~10 giorni)
      if(avgPeak > 15.0 && avgPeak < 150.0)
      {
         g_dynamicReversalRV[i] = NormalizeDouble(avgPeak, 1);
         Print("[PEAK] ", sym, " picco dinamico calcolato: ", DoubleToString(g_dynamicReversalRV[i], 1));
      }
      else
      {
         g_dynamicReversalRV[i] = InpReversalRV; // Fallback al valore di input fisso
         Print("[PEAK] ", sym, " nessun picco trovato, usato fallback: ", InpReversalRV);
      }
   }
   Print("[PEAK] Fine calcolo picchi dinamici.");
}
