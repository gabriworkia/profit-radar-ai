//+------------------------------------------------------------------+
// |  HISTOGRAM TRACKING                                               |
//+------------------------------------------------------------------+
void UpdateHistogramTracking()
{
   for(int i = 0; i < g_dataCount; i++)
   {
      int current = g_histogramState[i];
      int prev    = g_prevHistogram[i];

      if(!g_histogramTracked)
      {
         g_lightStreak[i]  = 0;
         g_prevWasGray[i]  = (current == HS_GRAY);
         g_prevHistogram[i] = current;
         continue;
      }

      bool curIsGreenLight = (current == HS_GREEN_LIGHT);
      bool curIsRedLight   = (current == HS_RED_LIGHT);
      bool curIsLight      = (curIsGreenLight || curIsRedLight);
      bool prevIsGreenLight = (prev == HS_GREEN_LIGHT);
      bool prevIsRedLight   = (prev == HS_RED_LIGHT);

      bool sameColorLight = false;
      if(curIsGreenLight && prevIsGreenLight) sameColorLight = true;
      if(curIsRedLight   && prevIsRedLight)   sameColorLight = true;

      if(curIsLight && sameColorLight)
      {
         g_lightStreak[i] = g_lightStreak[i] + 1;
      }
      else if(curIsLight && !sameColorLight)
      {
         g_lightStreak[i] = 1;
         g_prevWasGray[i] = (prev == HS_GRAY);
      }
      else
      {
         if(prev == HS_GRAY || current == HS_GRAY)
            g_prevWasGray[i] = true;
         else
            g_prevWasGray[i] = false;
         g_lightStreak[i] = 0;
      }

      g_prevHistogram[i] = current;
   }

   g_histogramTracked = true;
}

//+------------------------------------------------------------------+
// |  HISTOGRAM SEQUENCE FEATURES — Analizza ultime 8 candele          |
// |  Estrae 8 feature numeriche per LightGBM e GPT                    |
//+------------------------------------------------------------------+
//+------------------------------------------------------------------+
// |  CALCOLA FEATURE ISTOGRAMMA PER SIMBOLO                           |
// |  Funzione riutilizzabile: sia per export che per tracking         |
//+------------------------------------------------------------------+
void CalcHistFeatures(string sym,
                      int &outConsec, int &outSinceGray, int &outCycles, int &outCrossedZero,
                      double &outSlope, double &outPullback, int &outSeqEnc, double &outBarRatio,
                      double &outColorNow, double &outColorSlope, double &outColorCurve,
                      double &outColorR2, double &outColorCentroid, int &outColorSum)
{
   //--- Leggi ultime 30 candele dell'istogramma (per consecutive, cycles, pullback)
   //--- Ma solo ultime 8 per slope e ratio (più sensibili al recente)
   #define HIST_LOOKBACK 30
   #define HIST_RECENT   8
   int    states[HIST_LOOKBACK];
   double values[HIST_LOOKBACK];
   ArrayInitialize(states, HS_UNKNOWN);   // default = dato mancante, NON grigio
   ArrayInitialize(values, 0);

   //--- Lettura dati + conteggio dati mancanti (NONE/UNKNOWN)
   int missing = 0;
   for(int b = 0; b < HIST_LOOKBACK; b++)
   {
      string histSt;
      GetRadarData(sym, b + 1, values[b], histSt);
      states[b] = ParseHistogramState(histSt);
      if(states[b] == HS_UNKNOWN) missing++;   // "NONE" -> HS_UNKNOWN
   }

   //--- DOUBLE-CHECK validita': se la candela attuale manca, o se piu' di
   //    1/3 della finestra e' mancante, i dati non sono affidabili.
   //    Azzeriamo TUTTE le feature per non addestrare il modello su dati falsi.
   bool dataValid = (states[0] != HS_UNKNOWN) && (missing <= HIST_LOOKBACK / 3);
   if(!dataValid)
   {
      outConsec = 0; outSinceGray = 0; outCycles = 0; outCrossedZero = 0;
      outSlope = 0; outPullback = 0; outSeqEnc = 0; outBarRatio = 1.0;
      outColorNow = 0; outColorSlope = 0; outColorCurve = 0;
      outColorR2 = 0; outColorCentroid = 0.5; outColorSum = 0;
      return;
   }

   //--- Le candele UNKNOWN sparse (sotto soglia) vengono trattate come GRAY
   //    per i calcoli, cosi' non rompono slope/seq (gia' code=0 per UNKNOWN).

   //--- Feature 1: candele consecutive stesso colore (fino a 30)
   outConsec = 0;
   if(states[0] != HS_GRAY)
   {
      bool curIsGreen = (states[0] == HS_GREEN_LIGHT || states[0] == HS_GREEN_DARK);
      outConsec = 1;
      for(int b = 1; b < HIST_LOOKBACK; b++)
      {
         bool bIsGreen = (states[b] == HS_GREEN_LIGHT || states[b] == HS_GREEN_DARK);
         if(curIsGreen == bIsGreen && states[b] != HS_GRAY)
            outConsec++;
         else
            break;
      }
   }

   //--- Feature 2: candele dall'ultimo GRAY (fino a 30)
   outSinceGray = 0;
   for(int b = 0; b < HIST_LOOKBACK; b++)
   {
      if(states[b] == HS_GRAY) break;
      outSinceGray++;
   }

   //--- Feature 3: micro-cicli (ogni cambio di stato esatto nelle ultime 30)
   //    GREEN_LIGHT→GREEN_DARK conta come ciclo (indebolimento)
   //    GREEN→GRAY→RED conta come ciclo (inversione)
   //    GREEN_LIGHT→GREEN_LIGHT NON conta (stesso stato)
   outCycles = 0;
   for(int b = 1; b < HIST_LOOKBACK; b++)
   {
      if(states[b] != states[b-1])
         outCycles++;
   }

   //--- Feature 4: ha attraversato lo zero nelle ultime 30 candele
   outCrossedZero = 0;
   for(int b = 1; b < HIST_LOOKBACK; b++)
   {
      if(values[b] != 0 && values[b-1] != 0)
      {
         if((values[b] > 0 && values[b-1] < 0) || (values[b] < 0 && values[b-1] > 0))
         {
            outCrossedZero = 1;
            break;
         }
      }
   }

   //--- Feature 5: slope altezza barre (regressione lineare ultime 5)
   outSlope = 0;
   {
      int n = 5;
      double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
      for(int b = 0; b < n; b++)
      {
         double av = MathAbs(values[b]);
         sumX  += b;
         sumY  += av;
         sumXY += b * av;
         sumX2 += b * b;
      }
      double denom = n * sumX2 - sumX * sumX;
      if(denom != 0)
         outSlope = (n * sumXY - sumX * sumY) / denom;
   }

   //--- Feature 6: profondità pullback basata sui VALORI, non sul colore
   //    Cerca il minimo relativo (barra più bassa) tra il max e la barra attuale
   //    Misura quanto il trend si è ritirato dal suo massimo
   outPullback = 0;
   {
      double maxVal = 0;
      int maxBar = 0;
      // Trova il massimo assoluto nelle ultime 30
      for(int b = 0; b < HIST_LOOKBACK; b++)
      {
         if(MathAbs(values[b]) > maxVal)
         {
            maxVal = MathAbs(values[b]);
            maxBar = b;
         }
      }

      // Trova il minimo dopo il massimo (pullback dal picco)
      double minAfterMax = maxVal;
      for(int b = maxBar - 1; b >= 0; b--)
      {
         if(MathAbs(values[b]) < minAfterMax)
            minAfterMax = MathAbs(values[b]);
      }

      if(maxVal > 0)
         outPullback = (1.0 - minAfterMax / maxVal) * 100.0;
   }

   //--- Feature 7: sequenza ultime 5 candele encoded (5 stati, base 5)
   //    GRAY=0, GREEN_LIGHT=1, GREEN_DARK=2, RED_LIGHT=3, RED_DARK=4
   outSeqEnc = 0;
   {
      int mult = 1;
      for(int b = 0; b < 5; b++)
      {
         int code = 0;
         if(states[b] == HS_GREEN_LIGHT)      code = 1;
         else if(states[b] == HS_GREEN_DARK)  code = 2;
         else if(states[b] == HS_RED_LIGHT)   code = 3;
         else if(states[b] == HS_RED_DARK)    code = 4;
         outSeqEnc += code * mult;
         mult *= 5;
      }
   }

   //--- Feature 8: rapporto barra attuale / media ultime 7
   outBarRatio = 1.0;
   {
      double currentAbs = MathAbs(values[0]);
      double sumAbs = 0;
      int count = 0;
      for(int b = 1; b < HIST_RECENT; b++)
      {
         if(MathAbs(values[b]) > 0)
         {
            sumAbs += MathAbs(values[b]);
            count++;
         }
      }
      if(count > 0 && sumAbs > 0)
         outBarRatio = currentAbs / (sumAbs / count);
   }

   //--- Feature 9-14: FORMA dell'istogramma (codifica colore-pesata, ultime 15)
   //    Ogni candela -> valore: GL=+2, GD=+1, GRAY=0, RD=-1, RL=-2
   //    Fit quadratico y = a*x^2 + b*x + c con x=0 (vecchia) .. n-1 (recente)
   //      outColorSlope = b  -> direzione (verso verde o rosso)
   //      outColorCurve = a  -> accelera (>0) o si esaurisce (<0)
   //      outColorR2         -> quanto la forma e' pulita/regolare
   //      outColorCentroid   -> dove si concentra l'energia (0=passato, 1=ora)
   //      outColorSum        -> bilancio verde vs rosso
   //      outColorNow        -> colore della candela attuale
   outColorNow = 0; outColorSlope = 0; outColorCurve = 0;
   outColorR2 = 0; outColorCentroid = 0.5; outColorSum = 0;
   {
      int NSHAPE = 15;
      if(NSHAPE > HIST_LOOKBACK) NSHAPE = HIST_LOOKBACK;
      double cv[15];   // valori colore, cv[0]=piu' recente
      ArrayInitialize(cv, 0);
      for(int b = 0; b < NSHAPE; b++)
      {
         double code = 0;
         if(states[b] == HS_GREEN_LIGHT)      code =  2;
         else if(states[b] == HS_GREEN_DARK)  code =  1;
         else if(states[b] == HS_RED_DARK)    code = -1;
         else if(states[b] == HS_RED_LIGHT)   code = -2;
         else                                 code =  0;   // GRAY o sconosciuto
         cv[b] = code;
      }

      outColorNow = cv[0];

      //--- somma (bilancio) e baricentro energia
      double sumCode = 0, sumAbsW = 0, sumPosW = 0;
      for(int b = 0; b < NSHAPE; b++)
      {
         sumCode += cv[b];
         double w = MathAbs(cv[b]);
         sumAbsW += w;
         // posizione 0..1 dove 1 = candela piu' recente (b=0)
         double pos = (NSHAPE > 1) ? (double)(NSHAPE - 1 - b) / (NSHAPE - 1) : 0.5;
         sumPosW += pos * w;
      }
      outColorSum = (int)MathRound(sumCode);
      outColorCentroid = (sumAbsW > 0) ? (sumPosW / sumAbsW) : 0.5;

      //--- Fit quadratico (minimi quadrati). x: 0=piu' vecchia .. NSHAPE-1=recente
      //    Quindi y[x] = cv[NSHAPE-1-x]  (inverto perche' cv[0] e' la recente)
      int n = NSHAPE;
      double Sx=0, Sx2=0, Sx3=0, Sx4=0, Sy=0, Sxy=0, Sx2y=0;
      for(int x = 0; x < n; x++)
      {
         double yv = cv[n - 1 - x];
         double x2 = (double)x * x;
         Sx   += x;
         Sx2  += x2;
         Sx3  += x2 * x;
         Sx4  += x2 * x2;
         Sy   += yv;
         Sxy  += x * yv;
         Sx2y += x2 * yv;
      }

      //--- Risolvi sistema 3x3 (Cramer) per a,b,c
      //    | Sx4 Sx3 Sx2 | |a|   |Sx2y|
      //    | Sx3 Sx2 Sx  | |b| = |Sxy |
      //    | Sx2 Sx  n   | |c|   |Sy  |
      double m11=Sx4, m12=Sx3, m13=Sx2;
      double m21=Sx3, m22=Sx2, m23=Sx;
      double m31=Sx2, m32=Sx,  m33=n;
      double det = m11*(m22*m33 - m23*m32)
                 - m12*(m21*m33 - m23*m31)
                 + m13*(m21*m32 - m22*m31);

      double aa = 0, bb = 0, cc = 0;
      if(MathAbs(det) > 1e-9)
      {
         double detA = Sx2y*(m22*m33 - m23*m32)
                     - m12*(Sxy*m33 - m23*Sy)
                     + m13*(Sxy*m32 - m22*Sy);
         double detB = m11*(Sxy*m33 - m23*Sy)
                     - Sx2y*(m21*m33 - m23*m31)
                     + m13*(m21*Sy - Sxy*m31);
         double detC = m11*(m22*Sy - Sxy*m32)
                     - m12*(m21*Sy - Sxy*m31)
                     + Sx2y*(m21*m32 - m22*m31);
         aa = detA / det;
         bb = detB / det;
         cc = detC / det;
      }
      outColorSlope = bb;
      outColorCurve = aa;

      //--- R^2 del fit
      double ybar = Sy / n;
      double ssTot = 0, ssRes = 0;
      for(int x = 0; x < n; x++)
      {
         double yv = cv[n - 1 - x];
         double yhat = aa*x*x + bb*x + cc;
         ssTot += (yv - ybar) * (yv - ybar);
         ssRes += (yv - yhat) * (yv - yhat);
      }
      if(ssTot > 1e-9)
      {
         outColorR2 = 1.0 - ssRes / ssTot;
         if(outColorR2 < 0) outColorR2 = 0;
      }
      else
         outColorR2 = 1.0;   // sequenza piatta = forma perfettamente regolare
   }
}


void ExtractHistogramFeatures_all()
{
   datetime barTime = iTime(Symbol(), PERIOD_M15, 0);

   for(int i = 0; i < g_dataCount; i++)
   {
      //--- Stato attuale del simbolo (candela shift 1)
      double tmpVal; string tmpSt;
      GetRadarData(g_symbol[i], 1, tmpVal, tmpSt);
      int curState = ParseHistogramState(tmpSt);

      //--- CACHE: se la candela attuale e' COLORATA (stabile) e abbiamo gia'
      //    calcolato per questa candela con lo stesso stato -> riusa la cache.
      //    I GRAY/NONE (incerti) NON usano cache: ricalcolo sempre.
      bool isStable = (curState == HS_GREEN_LIGHT || curState == HS_GREEN_DARK ||
                       curState == HS_RED_LIGHT   || curState == HS_RED_DARK);
      bool cacheHit = isStable &&
                      g_histCacheTime[i] == barTime &&
                      g_histCacheState[i] == curState;
      if(cacheHit)
         continue;   // valori gia' in g_hist*[i], niente ricalcolo

      int hConsec, hSinceGray, hCycles, hCrossedZero, hSeqEnc;
      double hSlope, hPullback, hBarRatio;
      double hColorNow, hColorSlope, hColorCurve, hColorR2, hColorCentroid;
      int hColorSum;
      CalcHistFeatures(g_symbol[i],
                       hConsec, hSinceGray, hCycles, hCrossedZero,
                       hSlope, hPullback, hSeqEnc, hBarRatio,
                       hColorNow, hColorSlope, hColorCurve, hColorR2, hColorCentroid, hColorSum);

      g_histConsecColor[i]   = hConsec;
      g_histBarsSinceGray[i] = hSinceGray;
      g_histCycleCount[i]    = hCycles;
      g_histCrossedZero[i]   = (hCrossedZero == 1);
      g_histBarSlope[i]      = hSlope;
      g_histPullbackDepth[i] = hPullback;
      g_histSeqEncoded[i]    = hSeqEnc;
      g_histBarRatio[i]      = hBarRatio;
      g_histColorNow[i]      = hColorNow;
      g_histColorSlope[i]    = hColorSlope;
      g_histColorCurve[i]    = hColorCurve;
      g_histColorR2[i]       = hColorR2;
      g_histColorCentroid[i] = hColorCentroid;
      g_histColorSum[i]      = hColorSum;

      //--- Aggiorna cache SOLO se lo stato e' stabile (colorato)
      if(isStable)
      {
         g_histCacheTime[i]  = barTime;
         g_histCacheState[i] = curState;
      }
      else
      {
         g_histCacheTime[i]  = 0;   // invalida cache per GRAY/NONE
         g_histCacheState[i] = curState;
      }
   }
}

//+------------------------------------------------------------------+
// |  REVERSAL TRACKING                                                |
//+------------------------------------------------------------------+
void UpdateReversalTracking()
{
   for(int i = 0; i < g_dataCount; i++)
   {
      string sym = g_symbol[i];

      g_prev2RV[i] = g_prevRV[i];
      g_prevRV[i]  = g_radarValue[i];
      g_emaGapPctPrev[i] = g_emaGapPct[i];  // Salva gap per slope

      double highMax = 0;
      double lowMin  = 999999;
      for(int b = 1; b <= InpRevDivergBars; b++)
      {
         double h = iHigh(sym, PERIOD_M15, b);
         double l = iLow(sym, PERIOD_M15, b);
         if(h > highMax) highMax = h;
         if(l < lowMin && l > 0) lowMin = l;
      }
      g_swingHigh[i] = highMax;
      g_swingLow[i]  = lowMin;

      int curHist  = g_histogramState[i];
      int prevHist = g_prevHistogram[i];

      if(curHist == HS_RED_DARK && prevHist == HS_RED_LIGHT)
         g_histFlipBar[i] = 0;
      else if(curHist == HS_GREEN_DARK && prevHist == HS_GREEN_LIGHT)
         g_histFlipBar[i] = 0;
      else if(curHist == HS_GRAY && (prevHist == HS_RED_LIGHT || prevHist == HS_GREEN_LIGHT))
         g_histFlipBar[i] = 0;
      else
      {
         if(g_histFlipBar[i] < 999)
            g_histFlipBar[i] = g_histFlipBar[i] + 1;
      }
   }

   g_reversalTracked = true;
}

//+------------------------------------------------------------------+
// |  MOMENTUM METRICS — Normalized Momentum System                    |
// |  NM = (EMA8 - EMA21) / ATR14                                     |
// |  Signal = EMA(NM, 5)                                              |
// |  Acceleration = NM - NM[1]                                        |
// |  Distance = abs(NM - Signal)                                      |
// |  Compression: Distance < 0.15 AND ATR decreasing                 |
//+------------------------------------------------------------------+
void CalculateMomentumMetrics()
{
   for(int i = 0; i < g_dataCount; i++)
   {
      string sym = g_symbol[i];

      //--- Calcola NM per ultimi 5 bar
      double nm[5];
      ArrayInitialize(nm, 0);

      for(int bar = 0; bar < 5; bar++)
      {
         double ema8  = iMA(sym, PERIOD_M15, 8, 0, MODE_EMA, PRICE_CLOSE, bar);
         double ema21 = iMA(sym, PERIOD_M15, 21, 0, MODE_EMA, PRICE_CLOSE, bar);
         double atr   = iATR(sym, PERIOD_M15, 14, bar);

         if(atr > 0)
            nm[bar] = (ema8 - ema21) / atr;
         else
            nm[bar] = 0;
      }

      //--- Normalized Momentum corrente
      g_normMomentum[i] = nm[0];

      //--- Signal = EMA(5) manuale partendo dal piu' vecchio
      double k = 2.0 / 6.0;  // k = 2/(period+1) = 2/6
      double sig = nm[4];     // seed = valore piu' vecchio
      sig = nm[3] * k + sig * (1.0 - k);
      sig = nm[2] * k + sig * (1.0 - k);
      sig = nm[1] * k + sig * (1.0 - k);
      sig = nm[0] * k + sig * (1.0 - k);
      g_momentumSignal[i] = sig;

      //--- Acceleration = NM - NM[1]
      g_momentumAccel[i] = nm[0] - nm[1];

      //--- Distance = abs(NM - Signal)
      g_momentumDist[i] = MathAbs(nm[0] - sig);

      //--- Compression: Distance < 0.15 AND ATR decreasing
      double atrNow  = iATR(sym, PERIOD_M15, 14, 0);
      double atrPrev = iATR(sym, PERIOD_M15, 14, 4);
      g_isCompressing[i] = (g_momentumDist[i] < 0.15 && atrNow > 0 && atrNow < atrPrev);
   }
}

//+------------------------------------------------------------------+
// |  WEEKEND / FRIDAY CHECK                                           |
//+------------------------------------------------------------------+
bool IsWeekend()
{
   int dow = GetItalyDayOfWeek();
   //--- Sabato: sempre chiuso
   if(dow == 6) return true;
   //--- Domenica: chiuso solo se prima dell'orario di inizio
   if(dow == 0)
   {
      int h = GetItalyHour();
      // Se InpSundayStartH = 23 e sono le 23:00 di domenica -> non e' piu' weekend!
      // Se InpSundayStartH = 0 (midnight) -> domenica e' sempre weekend (inizia lunedi)
      if(h >= InpSundayStartH && InpSundayStartH > 0)
         return false;   // Domenica sera: mercato aperto!
      return true;        // Domenica mattina/pomeriggio: chiuso
   }
   return false;
}

int GetItalyHour()
{
   int h = (int)TimeHour(TimeCurrent()) + InpTimeOffset;
   while(h >= 24) h -= 24;
   while(h < 0)   h += 24;
   return h;
}

int GetItalyDayOfWeek()
{
   int dow = DayOfWeek();
   int h = (int)TimeHour(TimeCurrent()) + InpTimeOffset;
   if(h < 0)  { dow--; if(dow < 0) dow = 6; }
   if(h >= 24) { dow++; if(dow > 6) dow = 0; }
   return dow;
}

bool IsFridayEvening()
{
   if(GetItalyDayOfWeek() != 5) return false;
   int h = GetItalyHour();
   int m = (int)TimeMinute(TimeCurrent());
   if(h > InpFriForceCloseH) return true;
   if(h == InpFriForceCloseH && m >= InpFriForceCloseM) return true;
   return false;
}

bool IsFridayProfitClose()
{
   if(GetItalyDayOfWeek() != 5) return false;
   int h = GetItalyHour();
   int m = (int)TimeMinute(TimeCurrent());
   if(h > InpFriCloseProfitH) return true;
   if(h == InpFriCloseProfitH && m >= InpFriCloseProfitM) return true;
   return false;
}

bool IsFridayLossClose()
{
   if(GetItalyDayOfWeek() != 5) return false;
   int h = GetItalyHour();
   int m = (int)TimeMinute(TimeCurrent());
   if(h > InpFriCloseLossH) return true;
   if(h == InpFriCloseLossH && m >= InpFriCloseLossM) return true;
   return false;
}

//+------------------------------------------------------------------+
// |  TRADE SLOT - NO TRADE VENERDI DOPO LE 15:00 ITALIA              |
//+------------------------------------------------------------------+
int GetTradeSlot()
{
   if(IsWeekend())       return 0;
   if(IsFridayEvening()) return 0;  // chiusura forzata venerdi sera (ore 22:30 Italia)
   //--- Lunedi: NO nuovi trade (dati TradeLog: -2.63 EUR, WR 36%)
   if(InpNoMondayTrade && GetItalyDayOfWeek() == 1) return 0;
   //--- Venerdi: se il lotto venerdi e' 0.00, nessun nuovo trade
   if(InpFridayLots <= 0 && GetItalyDayOfWeek() == 5) return 0;
   //--- Blocco notturno (bassa liquidita', spread larghi)
   if(IsNightTime()) return 0;
   return 1;
}

