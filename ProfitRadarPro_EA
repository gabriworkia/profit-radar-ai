   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;

      int ticket = OrderTicket();

      //--- Cerca nei nostri slot
      for(int s = 0; s < g_fbCount; s++)
      {
         if(g_fbTicket[s] != ticket) continue;
         if(g_fbSent[s]) continue;

         //--- Trovato! Prepara e invia feedback
         double profit = OrderProfit() + OrderSwap() + OrderCommission();
         double entryPrc = OrderOpenPrice();
         double exitPrc  = OrderClosePrice();
         bool won = (profit > 0);

         //--- Calcola pips
         string sym = OrderSymbol();
         int digits = (int)MarketInfo(sym, MODE_DIGITS);
         double point = MarketInfo(sym, MODE_POINT);
         double pipMult = (digits == 3 || digits == 5) ? 10.0 : 1.0;
         double pips = 0;
         if(point > 0)
         {
            if(OrderType() == OP_BUY)
               pips = (exitPrc - entryPrc) / point / pipMult;
            else
               pips = (entryPrc - exitPrc) / point / pipMult;
         }

         //--- Invia al server
         string json = BuildFeedbackJSON(
            ticket, g_fbSymbol[s], g_fbDirection[s], g_fbModule[s],
            profit, pips, won,
            g_fbRV[s], g_fbADX[s], g_fbADRPct[s], g_fbHist[s],
            g_fbAIConf[s], g_fbAISignal[s], g_fbEntryPrice[s], exitPrc,
            g_fbNormMom[s], g_fbMomAccel[s], g_fbMomDist[s], g_fbCompress[s]);

         //--- Usa endpoint /feedback invece di /predict
         string feedbackUrl = InpAIUrl;
         StringReplace(feedbackUrl, "/predict", "/feedback");
         string response = AICallFeedback(json, feedbackUrl);

         if(response != "")
         {
            g_fbSent[s] = true;
            g_fbSentCount++;
            Print("[FEEDBACK] #", ticket, " ", g_fbSymbol[s],
                  " | ", (won ? "WIN" : "LOSS"), " ", DoubleToString(profit, 2), " EUR",
                  " | ", DoubleToString(pips, 1), " pips",
                  " | Inviato! (totale: ", g_fbSentCount, ")");

            //--- Logga anche su CSV locale (per trade chiusi via TP/SL broker)
            LogTradeToCSV(ticket);
         }
         else
         {
            Print("[FEEDBACK] #", ticket, " Errore invio - riprovo al prossimo tick");
         }
         break;
      }
   }
}

//+------------------------------------------------------------------+
// |  BUILD FEEDBACK JSON                                              |
//+------------------------------------------------------------------+
string BuildFeedbackJSON(int ticket, string sym, string direction, string module,
                         double profit, double pips, bool won,
                         double rv, double adx, double adrPct, string hist,
                         int aiConf, string aiSignal, double entryPrc, double exitPrc,
                         double normMom, double momAccel, double momDist, bool isCompress)
{
   string json = "{";
   json += "\"ticket\":" + IntegerToString(ticket) + ",";
   json += "\"symbol\":\"" + sym + "\",";
   json += "\"direction\":\"" + direction + "\",";
   json += "\"module\":\"" + module + "\",";
   json += "\"entry_price\":" + DoubleToString(entryPrc, 5) + ",";
   json += "\"exit_price\":" + DoubleToString(exitPrc, 5) + ",";
   json += "\"profit\":" + DoubleToString(profit, 2) + ",";
   json += "\"pips\":" + DoubleToString(pips, 1) + ",";
   json += "\"won\":" + (won ? "true" : "false") + ",";
   json += "\"ai_confidence\":" + IntegerToString(aiConf) + ",";
   json += "\"ai_signal\":\"" + aiSignal + "\",";
   json += "\"rv\":" + DoubleToString(rv, 2) + ",";
   json += "\"adx\":" + DoubleToString(adx, 1) + ",";
   json += "\"adr_pct\":" + DoubleToString(adrPct, 1) + ",";
   json += "\"hist\":\"" + hist + "\",";
   json += "\"nm\":" + DoubleToString(normMom, 4) + ",";
   json += "\"nm_accel\":" + DoubleToString(momAccel, 4) + ",";
   json += "\"nm_dist\":" + DoubleToString(momDist, 4) + ",";
   json += "\"is_compressing\":" + (isCompress ? "true" : "false");
   json += "}";
   return json;
}

//--- Vecchia funzione mantenuta per compatibilita'
void AISendFeedback(int ticket, bool won)
{
   if(!InpUseAI) return;

   if(won)
      Print("[AI][FEEDBACK] Ticket #", ticket, " = WIN");
   else
      Print("[AI][FEEDBACK] Ticket #", ticket, " = LOSS");
}

//+------------------------------------------------------------------+
// |  LOG TRADE TO CSV — Storico locale persistente                    |
// |  File: MQL4/Files/PRP_TradeLog.csv                               |
// |  Aggiornato automaticamente ad ogni trade chiuso                  |
//+------------------------------------------------------------------+
void LogTradeToCSV(int ticket)
{
   //--- Evita duplicati: controlla se gia' loggato
   for(int c = 0; c < g_fbCount; c++)
   {
      if(g_fbTicket[c] == ticket && g_fbLogged[c]) return;
   }

   if(!OrderSelect(ticket, SELECT_BY_TICKET)) return;

   string csvFile = "PRP_TradeLog.csv";

   //--- Dati ordine
   int    ot        = OrderType();
   string sym       = OrderSymbol();
   double lots      = OrderLots();
   double entryPrc  = OrderOpenPrice();
   double exitPrc   = OrderClosePrice();
   double sl        = OrderStopLoss();
   double tp        = OrderTakeProfit();
   double profit    = OrderProfit() + OrderSwap() + OrderCommission();
   string openTime  = TimeToString(OrderOpenTime(), TIME_DATE | TIME_MINUTES);
   string closeTime = TimeToString(OrderCloseTime(), TIME_DATE | TIME_MINUTES);
   string comment   = OrderComment();

   bool isLong = (ot == OP_BUY);
   string direction = isLong ? "BUY" : "SELL";

   //--- Calcola pips
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);
   double pipMult = (digits == 3 || digits == 5) ? 10.0 : 1.0;
   double pips = 0;
   if(point > 0)
   {
      if(isLong) pips = (exitPrc - entryPrc) / point / pipMult;
      else       pips = (entryPrc - exitPrc) / point / pipMult;
   }

   //--- Estrai modulo dal commento (es: "PRP_STD_2026.06.06" -> "STD")
   string module = "UNK";
   int modPos = StringFind(comment, "PRP_");
   if(modPos >= 0)
   {
      string sub = StringSubstr(comment, modPos + 4);
      int usPos = StringFind(sub, "_");
      if(usPos > 0)
         module = StringSubstr(sub, 0, usPos);
      else
         module = sub;
   }

   //--- Cerca dati AI nei feedback track
   int    aiConf   = 0;
   string aiSignal = "";
   double rv       = 0;
   double adx      = 0;
   double adrPct   = 0;
   string hist     = "";

   for(int s = 0; s < g_fbCount; s++)
   {
      if(g_fbTicket[s] == ticket)
      {
         aiConf   = g_fbAIConf[s];
         aiSignal = g_fbAISignal[s];
         rv       = g_fbRV[s];
         adx      = g_fbADX[s];
         adrPct   = g_fbADRPct[s];
         hist     = g_fbHist[s];
         break;
      }
   }

   bool won = (profit > 0);

   //--- Scrivi su CSV
   int handle = FileOpen(csvFile, FILE_CSV | FILE_READ | FILE_WRITE, ';');
   if(handle == INVALID_HANDLE)
   {
      Print("[TRADELOG] Errore apertura file: ", csvFile);
      return;
   }

   //--- Controlla se il file e' vuoto (serve header)
   bool needHeader = true;
   if(FileSize(handle) > 10)
   {
      FileSeek(handle, 0, SEEK_SET);
      string firstLine = FileReadString(handle);
      if(StringFind(firstLine, "Ticket") >= 0)
         needHeader = false;
   }

   //--- Vai alla fine
   FileSeek(handle, 0, SEEK_END);

   if(needHeader)
   {
      FileWrite(handle,
         "Ticket", "Symbol", "Direction", "Module",
         "Lots", "EntryPrice", "ExitPrice", "SL", "TP",
         "Profit", "Pips", "Won",
         "AI_Conf", "AI_Signal",
         "RV", "ADX", "ADR%", "Hist",
         "OpenTime", "CloseTime", "Comment");
   }

   FileWrite(handle,
      IntegerToString(ticket),
      sym,
      direction,
      module,
      DoubleToString(lots, 2),
      DoubleToString(entryPrc, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(exitPrc, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(sl, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(tp, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(profit, 2),
      DoubleToString(pips, 1),
      won ? "true" : "false",
      IntegerToString(aiConf),
      aiSignal,
      DoubleToString(rv, 2),
      DoubleToString(adx, 1),
      DoubleToString(adrPct, 1),
      hist,
      openTime,
      closeTime,
      comment);

   FileClose(handle);

   //--- Segna come loggato per evitare duplicati
   for(int c = 0; c < g_fbCount; c++)
   {
      if(g_fbTicket[c] == ticket) { g_fbLogged[c] = true; break; }
   }

   Print("[TRADELOG] #", ticket, " ", sym, " ", direction,
         " | ", (won ? "WIN" : "LOSS"), " ", DoubleToString(profit, 2), " EUR",
         " | ", DoubleToString(pips, 1), " pips",
         " | AI:", aiConf, "%",
         " | RV:", DoubleToString(rv, 1),
         " | loggato su ", csvFile);
}

//+------------------------------------------------------------------+
// |  A/B TEST GPT CALL — Chiama GPT senza bloccare il trade         |
// |  Ogni candidato trade viene inviato anche a GPT-4o-mini          |
// |  Il risultato viene loggato ma NON influisce sulla decisione      |
// |  Dopo 100 trade confronteremo chi aveva più ragione              |
//+------------------------------------------------------------------+
void ABTestGPTCall(int idx, string tag, string lgbmSignal, int lgbmConf)
{
   //--- Costruisci URL /predict_gpt
   string gptUrl = InpAIUrl;
   StringReplace(gptUrl, "/predict", "/predict_gpt");

   //--- Riutilizza lo stesso JSON della richiesta LightGBM + aggiungi ai_confidence
   string json = BuildAIRequestJSON(idx, tag);
   // Rimuovi l'ultima } e aggiungi il campo
   json = StringSubstr(json, 0, StringLen(json) - 1);
   json += ",\"ai_confidence\":" + IntegerToString(lgbmConf);
   json += "}";

   //--- Invia (silenzioso, non blocca)
   string headers = "Content-Type: application/json\r\n";
   char postData[];
   int len = StringLen(json);
   ArrayResize(postData, len);
   for(int i = 0; i < len; i++)
      postData[i] = (char)StringGetCharacter(json, i);

   char result[];
   string resultHeaders;

   int res = WebRequest("POST", gptUrl, headers, 8000, postData, result, resultHeaders);

   if(res == -1) return; // Silenzioso

   //--- Parse risposta GPT
   string respStr = "";
   int resultLen = ArraySize(result);
   for(int i = 0; i < resultLen; i++)
      respStr += CharToString(result[i]);

   g_abGptCalls++;

   //--- Estrai segnale GPT
   string gptSignal = "";
   int sigPos = StringFind(respStr, "\"signal\"");
   if(sigPos >= 0)
   {
      int colonP = StringFind(respStr, ":", sigPos);
      if(colonP >= 0)
      {
         int startQ = StringFind(respStr, "\"", colonP);
         int endQ = StringFind(respStr, "\"", startQ + 1);
         if(startQ >= 0 && endQ > startQ)
            gptSignal = StringSubstr(respStr, startQ + 1, endQ - startQ - 1);
      }
   }

   //--- Estrai confidenza GPT
   int gptConf = 0;
   int confPos = StringFind(respStr, "\"confidence\"");
   if(confPos >= 0)
   {
      int colonP = StringFind(respStr, ":", confPos);
      if(colonP >= 0)
      {
         string numStr = "";
         for(int c = colonP + 1; c < StringLen(respStr) && c < colonP + 10; c++)
         {
            string ch = StringSubstr(respStr, c, 1);
            if((ch >= "0" && ch <= "9") || ch == ".") numStr += ch;
            else if(StringLen(numStr) > 0) break;
         }
         if(StringLen(numStr) > 0) gptConf = (int)StringToDouble(numStr);
      }
   }

   //--- Confronta
   bool agree = (gptSignal == lgbmSignal);
   if(agree) g_abGptAgree++;
   else g_abGptDisagree++;

   Print("[AB TEST] #", g_abGptCalls, " ", NormSym(g_symbol[idx]),
         " | LightGBM: ", lgbmSignal, " ", lgbmConf, "%",
         " | GPT: ", gptSignal, " ", gptConf, "%",
         " | ", (agree ? "CONCORDI" : "DISCORDI"));
}

