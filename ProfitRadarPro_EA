//+------------------------------------------------------------------+
// |  FILTRO IPERCONSERVATIVO — whitelist + 6 criteri rigidi         |
// |  Attivo solo se InpHyperOn = true                               |
// |  SE TUTTI 6 ✅ → APRI | SE ANCHE 1 ❌ → SALTA                   |
//+------------------------------------------------------------------+
bool CheckHyperConservative(int idx)
{
   //--- Criterio 1: simbolo nella whitelist
   string sym = g_symbol[idx];
   if(StringFind(InpHyperSymbols, sym) < 0)
   {
      Print("[IPER] ", sym, " SCARTATO: non in whitelist");
      return false;
   }

   //--- Criterio 2: AI confidenza (se AI > 0, deve essere 80-89%)
   if(g_aiLastConf > 0)
   {
      if(g_aiLastConf < 80 || g_aiLastConf > 89)
      {
         Print("[IPER] ", sym, " SCARTATO: AI conf=", g_aiLastConf, "% (serve 80-89%)");
         return false;
      }
   }

   //--- Criterio 3: ADX tra 25 e 60
   if(g_adx[idx] < 25 || g_adx[idx] > 60)
   {
      Print("[IPER] ", sym, " SCARTATO: ADX=", DoubleToString(g_adx[idx], 1), " (serve 25-60)");
      return false;
   }

   //--- Criterio 4: ADR% tra 50 e 150
   if(g_adrPercent[idx] < 50 || g_adrPercent[idx] > 150)
   {
      Print("[IPER] ", sym, " SCARTATO: ADR%=", DoubleToString(g_adrPercent[idx], 1), " (serve 50-150)");
      return false;
   }

   //--- Criterio 5: |RV| > 20
   if(MathAbs(g_radarValue[idx]) <= 20)
   {
      Print("[IPER] ", sym, " SCARTATO: |RV|=", DoubleToString(MathAbs(g_radarValue[idx]), 1), " (serve >20)");
      return false;
   }

   //--- Criterio 6: direction ≠ REV (gia' garantito: chiamato solo in STD)
   // Questo filtro viene applicato SOLO in CheckStandardFilters, quindi module = STD

   //--- Tutti i criteri passati
   Print("[IPER] ", sym, " ✅ TUTTI 6 CRITERI PASSATI → TRADE APPROVATO");
   return true;
}

bool CheckStandardFilters(int idx, int &qualityCount, string &details)
{
   qualityCount = 0;
   details = "";

   //=== MODALITA' IPERCONSERVATIVA: 6 criteri rigidi, bypassa filtri normali ===
   if(InpHyperOn)
   {
      if(!CheckHyperConservative(idx)) return false;
      // Se passa, forza qualityCount al massimo cosi' ProcessStandard non lo scarta
      // (altrimenti qualityCount rimane 0 e il trade viene bloccato dal filtro aggressivita')
      qualityCount = 99;
      return true;
   }

   if(g_radarType[idx] != RT_LONG && g_radarType[idx] != RT_SHORT)
   {
      details = "Nessuna direzione";
      return false;
   }

   bool isLong = (g_radarType[idx] == RT_LONG);

   //=== VETO COERENZA: la direzione DEVE combaciare con l'istogramma ===
   // Rete di sicurezza: mai BUY su istogramma rosso o SELL su verde.
   // (Difesa contro dati corrotti/disallineati che invertirebbero la direzione.)
   bool histGreen = (g_histogramState[idx] == HS_GREEN_LIGHT || g_histogramState[idx] == HS_GREEN_DARK);
   bool histRed   = (g_histogramState[idx] == HS_RED_LIGHT   || g_histogramState[idx] == HS_RED_DARK);
   if((isLong && histRed) || (!isLong && histGreen))
   {
      details = "VETO incoerenza: " + (isLong ? "BUY" : "SELL") + " ma hist=" + HistStateStr(g_histogramState[idx]);
      return false;
   }

   //=== VETO ADR%: NON entrare a mercato saturo ===
   // I dati storici mostrano che entrare con ADR% alto = perdita quasi certa
   // (vincenti entrano in media a ~31% ADR, perdenti a ~71%).
   // Questo e' un VETO assoluto: se il range giornaliero e' gia' troppo
   // consumato, il trade viene SCARTATO a prescindere dagli altri filtri.
   //--- Calcola EMA gap e slope (serve per i VETO e il quality count)
   double emaGapAbs = MathAbs(g_emaGapPct[idx]);
   double emaSlopeNow = g_emaGapPct[idx] - g_emaGapPctPrev[idx];
   //=== VETO CONSECUTIVE: trend troppo maturo (esaurito) ===
   if(g_histConsecColor[idx] > InpMaxConsecutive)
   {
      details = "VETO consecutive=" + IntegerToString(g_histConsecColor[idx]) + " > " + IntegerToString(InpMaxConsecutive) + " (trend esaurito)";
      return false;
   }
   //=== VETO EMA SLOPE: trend perde forza (convergenza) ===
   if(emaSlopeNow < 0 && MathAbs(emaSlopeNow) > 0.01)
   {
      details = "VETO slope=" + DoubleToString(emaSlopeNow, 4) + " (trend perde forza)";
      return false;
   }
   //=== VETO EMA GAP: gap troppo piccolo = trend debole ===
   if(emaGapAbs < InpMinEMAGapPct)
   {
      details = "VETO emaGap=" + DoubleToString(emaGapAbs, 3) + "% < " + DoubleToString(InpMinEMAGapPct, 2) + "% (trend debole)";
      return false;
   }
   if(g_adrPercent[idx] >= InpADR_Max)
   {
      details = "VETO ADR=" + DoubleToString(g_adrPercent[idx], 0) + "% >= " + DoubleToString(InpADR_Max, 0) + "% (mercato saturo)";
      return false;
   }

   if(g_adrPercent[idx] < InpADR_Max)
      qualityCount++;
   else
      StringConcatenate(details, details, "ADR=" + DoubleToString(g_adrPercent[idx], 0) + "% ");

   //=== VETO COMBINATO RV+ADX: se entrambi alti → trend troppo maturo ===
   // Dati: quando RV>=25 E ADX>=20, WR STD crolla al 20-24%
   double stdRV = MathAbs(g_radarValue[idx]);
   if(stdRV >= 25 && g_adx[idx] >= 20)
   {
      details = "VETO RV+ADX: RV=" + DoubleToString(stdRV, 0) + " ADX=" + DoubleToString(g_adx[idx], 0) + " (trend troppo maturo)";
      return false;
   }

   if(stdRV < InpRV_Max)
      qualityCount++;
   else
      StringConcatenate(details, details, "RV=" + DoubleToString(stdRV, 0) + " ");
   // EMA gap: piu' e' grande, piu' il trend e' definito
   if(emaGapAbs >= InpMinEMAGapPct * 2)
      qualityCount++;  // Gap doppio = trend forte
   else if(emaGapAbs >= InpMinEMAGapPct)
      qualityCount++;  // Gap sufficiente
   else
      StringConcatenate(details, details, "EMAGap=" + DoubleToString(emaGapAbs, 3) + "% ");
   // EMA slope: positivo = divergenza (trend forte), negativo = convergenza (debole)
   if(emaSlopeNow > 0)
      qualityCount++;  // Trend si rafforza
   else
      StringConcatenate(details, details, "Slope=" + DoubleToString(emaSlopeNow, 4) + " ");

   if(isLong && g_emaPosition[idx] == 1)
      qualityCount++;
   else if(!isLong && g_emaPosition[idx] == -1)
      qualityCount++;
   else
      StringConcatenate(details, details, "EMA! ");

   if(isLong && g_histogramState[idx] == HS_GREEN_LIGHT)
      qualityCount++;
   else if(!isLong && g_histogramState[idx] == HS_RED_LIGHT)
      qualityCount++;
   else
      StringConcatenate(details, details, "Hist=" + HistStateStr(g_histogramState[idx]) + " ");

   //=== BUY PENALTY: i BUY perdono molto di piu' dei SELL ===
   // Dati: BUY -17€, SELL +6€. I BUY richiedono qualita' extra.
   int buyMinQuality = 5;  // BUY serve 5/6
   int sellMinQuality = 4; // SELL basta 4/6
   int minQ = isLong ? buyMinQuality : sellMinQuality;
   
   if(qualityCount < minQ)
   {
      details = "QUALITY: " + IntegerToString(qualityCount) + "/" + (isLong ? "6 (BUY need 5)" : "6 (SELL need 4)") + " insufficiente";
      return false;
   }

   return true;
}

//+------------------------------------------------------------------+
// |  BREAKOUT FILTERS                                                 |
//+------------------------------------------------------------------+
bool CheckBreakoutFilters(int idx, int &qualityCount, string &details)
{
   qualityCount = 0;
   details = "";

   bool isLong = (g_histogramState[idx] == HS_GREEN_LIGHT);

   if(g_histogramState[idx] != HS_GREEN_LIGHT && g_histogramState[idx] != HS_RED_LIGHT)
   { details = "Non LIGHT"; return false; }

   if(!g_prevWasGray[idx])
   { details = "Non da GRAY"; return false; }

   if(g_lightStreak[idx] >= InpBreakoutMinLIGHT)
      qualityCount++;
   else
      StringConcatenate(details, details, "Streak=" + IntegerToString(g_lightStreak[idx]) + " ");

   if(g_close[idx] > 0)
   {
      double emaGapPct = MathAbs(g_ema21[idx] - g_ema200[idx]) / g_close[idx] * 100.0;
      if(emaGapPct < InpBreakoutEMAGapPct) qualityCount++;
      else StringConcatenate(details, details, "EMAgap=" + DoubleToString(emaGapPct, 2) + "% ");
   }

   double absRV = MathAbs(g_radarValue[idx]);
   if(absRV < InpBreakoutMaxRV) qualityCount++;
   else StringConcatenate(details, details, "RV=" + DoubleToString(absRV, 0) + " ");

   if(g_adx[idx] < InpBreakoutMaxADX) qualityCount++;
   else StringConcatenate(details, details, "ADX=" + DoubleToString(g_adx[idx], 0) + " ");

   if(g_adrPercent[idx] < InpBreakoutMaxADR) qualityCount++;
   else StringConcatenate(details, details, "ADR=" + DoubleToString(g_adrPercent[idx], 0) + "% ");

   string sym = g_symbol[idx];
   double atrNow  = iATR(sym, PERIOD_M15, InpATR_Period, 1);
   double atrPrev = iATR(sym, PERIOD_M15, InpATR_Period, 4);
   if(atrNow > 0 && atrPrev > 0 && atrNow > atrPrev) qualityCount++;
   else StringConcatenate(details, details, "ATRflat ");

   if(isLong && g_close[idx] >= g_ema21[idx]) qualityCount++;
   else if(!isLong && g_close[idx] <= g_ema21[idx]) qualityCount++;
   else StringConcatenate(details, details, "PriceEMA! ");

   double atr = iATR(sym, PERIOD_M15, InpATR_Period, 1);
   if(atr > 0)
   {
      double open0    = iOpen(sym, PERIOD_M15, 1);
      double body     = MathAbs(g_close[idx] - open0);
      double bodyRatio = body / atr;
      if(bodyRatio >= InpBreakoutMinBody) qualityCount++;
      else StringConcatenate(details, details, "Body=" + DoubleToString(bodyRatio, 2) + " ");
   }

   return true;
}

//+------------------------------------------------------------------+
// |  SCORING                                                          |
//+------------------------------------------------------------------+
int CalculateStandardScore(int idx)
{
   int score = 0;
   double absRV = MathAbs(g_radarValue[idx]);
   if(absRV < 10)       score += 0;
   else if(absRV < 20)  score += 100;
   else                 score += 200;

   if(g_adrPercent[idx] < 40)      score += 0;
   else if(g_adrPercent[idx] < 50) score += 10;
   else                             score += 20;

   if(g_adx[idx] > 25) score += 0;
   else if(g_adx[idx] > 20) score += 2;
   else score += 5;

   if(g_close[idx] > 0)
   {
      double emaGap = MathAbs(g_ema21[idx] - g_ema200[idx]) / g_close[idx] * 10000;
      if(emaGap < 20)      score += 0;
      else if(emaGap < 50) score += 3;
      else                 score += 6;
   }

   return score;
}

int CalculateBreakoutScore(int idx)
{
   int score = InpBreakoutScoreBonus;
   double absRV = MathAbs(g_radarValue[idx]);
   if(absRV < 5)        score -= 40;
   else if(absRV < 10)  score -= 20;

   if(g_close[idx] > 0)
   {
      double emaGapPct = MathAbs(g_ema21[idx] - g_ema200[idx]) / g_close[idx] * 100.0;
      if(emaGapPct < 0.05)      score -= 30;
      else if(emaGapPct < 0.10) score -= 15;
   }

   if(g_lightStreak[idx] >= 4)      score -= 20;
   else if(g_lightStreak[idx] >= 3) score -= 10;

   if(g_adrPercent[idx] < 30) score -= 10;
   if(g_adx[idx] < 15) score -= 10;

   return score;
}

//+------------------------------------------------------------------+
// |  FRACTAL SL / ATR SL                                              |
//+------------------------------------------------------------------+
double FindFractalSL(string sym, bool isLong)
{
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);
   double currentPrice = iClose(sym, PERIOD_M15, 0);

   //--- Pip multiplier
   double pipMult = 1.0;
   if(digits == 3 || digits == 5) pipMult = 10.0;
   double pipSize = point * pipMult;

   //--- SL massimo: 50 pip
   double maxSLPips = 50.0;
   double maxSLDist = maxSLPips * pipSize;

   //--- Cerca fractal più vicino
   for(int i = 2; i <= InpFractalBars; i++)
   {
      if(isLong)
      {
         double fracLow = iFractals(sym, PERIOD_M15, MODE_LOWER, i);
         if(fracLow > 0 && fracLow < currentPrice)
         {
            double slDist = currentPrice - fracLow;
            if(slDist <= maxSLDist)
               return NormalizeDouble(fracLow, digits);
            else
            {
               Print("[SL] ", sym, " fractal troppo lontano: ", DoubleToString(slDist/pipSize, 0), " pips > max ", DoubleToString(maxSLPips, 0));
               break; // Fractal troppo lontano, usa ATR
            }
         }
      }
      else
      {
         double fracHigh = iFractals(sym, PERIOD_M15, MODE_UPPER, i);
         if(fracHigh > 0 && fracHigh > currentPrice)
         {
            double slDist = fracHigh - currentPrice;
            if(slDist <= maxSLDist)
               return NormalizeDouble(fracHigh, digits);
            else
            {
               Print("[SL] ", sym, " fractal troppo lontano: ", DoubleToString(slDist/pipSize, 0), " pips > max ", DoubleToString(maxSLPips, 0));
               break; // Fractal troppo lontano, usa ATR
            }
         }
      }
   }

   //--- Fallback: ATR con cappello
   double slPrice = CalculateATR_SL(sym, isLong);
   double slDist = MathAbs(currentPrice - slPrice);
   if(slDist > maxSLDist)
   {
      Print("[SL] ", sym, " ATR SL troppo largo: ", DoubleToString(slDist/pipSize, 0), " pips -> cappello a ", DoubleToString(maxSLPips, 0));
      if(isLong)
         slPrice = NormalizeDouble(currentPrice - maxSLDist, digits);
      else
         slPrice = NormalizeDouble(currentPrice + maxSLDist, digits);
   }
   return slPrice;
}

double CalculateATR_SL(string sym, bool isLong)
{
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double atr = iATR(sym, PERIOD_M15, InpATR_Period, 1);
   if(atr <= 0) return 0;
   double price = iClose(sym, PERIOD_M15, 0);
   if(isLong)
      return NormalizeDouble(price - atr * InpATR_Mult, digits);
   else
      return NormalizeDouble(price + atr * InpATR_Mult, digits);
}

//+------------------------------------------------------------------+
// |  TP CALCULATION                                                   |
//+------------------------------------------------------------------+
double CalculateTP(string sym, double entryPrice, double slPrice, bool isLong, int dataIdx, double minRR)
{
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);
   if(point <= 0) return 0;

   // Pip multiplier: 5-digit = 10, 3-digit = 10, 4-digit = 1
   double pipMult = 1.0;
   if(digits == 3 || digits == 5) pipMult = 10.0;
   double pipSize = point * pipMult;  // dimensione di 1 pip in prezzo

   double pipResidui = g_media10gg[dataIdx] - g_pipFatti[dataIdx];
   if(pipResidui <= 0) return 0;

   //=== TP ADATTIVO: la % di ADR usata scala con la FORZA del segnale ===
   //    Trend forte (RV sano + ADX alto) -> TP al 35% ADR (raggiungibile)
   //    Trend debole/esausto             -> TP al 20% ADR (trade piccoli ma frequenti)
   double tpPercent = InpTPPercent;
   if(InpTPAdaptive)
   {
      double absRV = MathAbs(g_radarValue[dataIdx]);
      double adx   = g_adx[dataIdx];

      //--- Punteggio forza da RV (0..1): sweet spot 10-40, penalizza debole/esausto
      double rvScore;
      if(absRV >= 10 && absRV <= 40)      rvScore = 1.0;   // trend sano
      else if(absRV >= 5 && absRV < 10)   rvScore = 0.6;
      else if(absRV > 40 && absRV <= 55)  rvScore = 0.7;
      else if(absRV > 55)                 rvScore = 0.3;   // esausto
      else                                rvScore = 0.3;   // troppo debole (<5)

      //--- Punteggio forza da ADX (0..1)
      double adxScore;
      if(adx >= 30)      adxScore = 1.0;
      else if(adx >= 22) adxScore = 0.7;
      else if(adx >= 18) adxScore = 0.5;
      else               adxScore = 0.3;

      double strength = (rvScore + adxScore) / 2.0;   // 0..1
      tpPercent = InpTPPercentMin + (InpTPPercent - InpTPPercentMin) * strength;
   }

   double tpPips = pipResidui * (tpPercent / 100.0);
   
   //--- TP massimo assoluto in pip (protezione contro TP troppo alto)
   if(InpMaxTPPips > 0 && tpPips > InpMaxTPPips)
   {
      Print("[TP] ", sym, " TP limitato: calcolato ", DoubleToString(tpPips,1), " pip -> max ", InpMaxTPPips, " pip");
      tpPips = InpMaxTPPips;
   }
   
   double tpDistance = tpPips * pipSize;  // ← FIX: pipSize invece di point
   double slDistance = MathAbs(entryPrice - slPrice);
   if(slDistance <= 0) return 0;

   double rr = tpDistance / slDistance;
   if(rr < minRR)
   {
      Print("[TP] ", sym, " RR=", DoubleToString(rr, 2), " < min ", DoubleToString(minRR, 1),
            " | tpPips=", DoubleToString(tpPips, 1), " slDist=", DoubleToString(slDistance/pipSize, 1),
            " pips | TP%=", DoubleToString(tpPercent, 0), " (forza segnale)");
      return 0;
   }

   if(isLong)
      return NormalizeDouble(entryPrice + tpDistance, digits);
   else
      return NormalizeDouble(entryPrice - tpDistance, digits);
}

//+------------------------------------------------------------------+
// |  LOT SIZE                                                         |
//+------------------------------------------------------------------+
//+------------------------------------------------------------------+
// |  WIN RATE RECENTE DA TRADELOG (per lotto dinamico)               |
//+------------------------------------------------------------------+
double GetRecentWinRate(int lookback)
{
   int handle = FileOpen("PRP_TradeLog.csv", FILE_CSV | FILE_READ | FILE_ANSI, ';');
   if(handle == INVALID_HANDLE) return 0.5;  // default neutro

   int total = 0, wins = 0;
   bool firstLine = true;
   string rows[];
   int rowCount = 0;

   while(!FileIsEnding(handle))
   {
      string line = FileReadString(handle);
      if(firstLine) { firstLine = false; continue; }
      if(StringLen(line) < 5) continue;
      if(rowCount >= ArraySize(rows)) ArrayResize(rows, rowCount + 100);
      rows[rowCount++] = line;
   }
   FileClose(handle);

   int start = MathMax(0, rowCount - lookback);
   for(int i = start; i < rowCount; i++)
   {
      // Estrai colonna Won (11° campo, indice 10)
      string parts[];
      int n = StringSplit(rows[i], ';', parts);
      if(n < 12) continue;
      string wonStr = parts[10];
      total++;
      if(StringFind(wonStr, "true") >= 0 || wonStr == "1") wins++;
   }

   if(total == 0) return 0.5;
   return (double)wins / (double)total;
}

//+------------------------------------------------------------------+
// |  LOT SIZE                                                         |
//+------------------------------------------------------------------+
double GetLotSize(string sym)
{
   double minLot  = MarketInfo(sym, MODE_MINLOT);
   double maxLot  = MarketInfo(sym, MODE_MAXLOT);
   double lotStep = MarketInfo(sym, MODE_LOTSTEP);
   double lots = InpFixedLots;

   //--- Fasce orarie a rischio: usa il lotto ridotto (il MINORE tra quelle attive)
   //    Venerdi (fino alla chiusura forzata) e pomeriggio (fuori sessione principale)
   int italyDow = GetItalyDayOfWeek();
   bool isFriday = (italyDow == 5);
   bool isAfternoon = !IsSessionTime();  // fuori dalla sessione principale = pomeriggio
   double specialLot = -1.0;
   if(isFriday && !IsFridayEvening() && InpFridayLots > 0.0)
      specialLot = InpFridayLots;
   if(isAfternoon && InpAfternoonLots > 0.0)
   {
      if(specialLot < 0.0 || InpAfternoonLots < specialLot)
         specialLot = InpAfternoonLots;
   }
   if(specialLot >= 0.0)
   {
      lots = specialLot;
      Print("[LOT-FASCIA] ", sym, " usa lotto ridotto ", DoubleToString(lots, 2),
            (isFriday ? " (Venerdi)" : ""), (isAfternoon ? " (Pomeriggio)" : ""));
   }

   //--- Lotto dinamico: scala in base al win rate delle ultime N operazioni
   if(InpDynamicLotsOn)
   {
      double wr = GetRecentWinRate(InpDynamicLookback);
      if(wr >= 0.55)
         lots = InpFixedLots;                 // WR alto -> lotto pieno
      else if(wr >= 0.45)
         lots = InpFixedLots * 0.7;            // WR medio -> ridotto
      else if(wr >= 0.35)
         lots = InpFixedLots * 0.5;            // WR basso -> dimezzato
      else
         lots = InpFixedLots * 0.3;            // WR molto basso -> minimo

      Print("[LOT-DYN] WR recente ", DoubleToString(wr*100,1), "% -> lotto ", DoubleToString(lots, 2));
   }

   lots = MathFloor(lots / lotStep) * lotStep;
   lots = NormalizeDouble(lots, 2);
   if(lots < minLot) lots = minLot;
   if(lots > maxLot) lots = maxLot;

   //--- Safety cap: non supera mai InpMaxLotsCap
   if(InpMaxLotsCap > 0 && lots > InpMaxLotsCap)
   {
      Print("[LOT-CAP] ", sym, " lotto ", DoubleToString(lots,2), " ridotto a max ", DoubleToString(InpMaxLotsCap,2));
      lots = InpMaxLotsCap;
   }

   return lots;
}

//+------------------------------------------------------------------+
// |  UTILITY TRADE CHECKS                                             |
//+------------------------------------------------------------------+
string NormSym(string sym)
{
   StringReplace(sym, "+", "");
   if(StringLen(sym) > 6)
      sym = StringSubstr(sym, 0, 6);
   return sym;
}

bool SpreadOK(string sym)
{
   double spread = MarketInfo(sym, MODE_SPREAD);   // in points

   //--- Backup grezzo: blocco assoluto se lo spread e' enorme
   if(spread > InpMaxSpread) return false;

   //--- Filtro dinamico: blocca se lo spread e' molto sopra la SUA media normale
   if(InpSpreadDynMult > 0)
   {
      int idx = FindSymbolIndex(sym);
      if(idx >= 0)
      {
         if(!g_spreadInit[idx])
         {
            //--- Prima lettura: inizializza la media (non blocca)
            g_spreadAvg[idx]  = spread;
            g_spreadInit[idx] = true;
         }
         else
         {
            //--- Se lo spread attuale e' > N x la media -> probabile news/notte -> blocca
            if(g_spreadAvg[idx] > 0 && spread > g_spreadAvg[idx] * InpSpreadDynMult)
            {
               if(InpAILog)
                  Print("[SPREAD] ", sym, " BLOCCATO: spread ", DoubleToString(spread, 0),
                        " > ", DoubleToString(InpSpreadDynMult, 1), "x media ",
                        DoubleToString(g_spreadAvg[idx], 1));
               return false;
            }
            //--- Aggiorna la media (EMA leggera: 95% vecchia + 5% nuova)
            g_spreadAvg[idx] = g_spreadAvg[idx] * 0.95 + spread * 0.05;
         }
      }
   }

   return true;
}

//+------------------------------------------------------------------+
// |  BLOCCO NOTTURNO — niente trade nelle ore di bassa liquidita'     |
//+------------------------------------------------------------------+
bool IsNightTime()
{
   if(!InpNoNightTrade) return false;
   int h = GetItalyHour();
   //--- Fascia che attraversa la mezzanotte (es. 23 -> 7)
   if(InpNightStartH > InpNightEndH)
      return (h >= InpNightStartH || h < InpNightEndH);
   //--- Fascia normale (es. 1 -> 6)
   return (h >= InpNightStartH && h < InpNightEndH);
}

//+------------------------------------------------------------------+
//|  FILTRO SESSIONE — blocca trade fuori orario europeo (UTC)       |
//+------------------------------------------------------------------+
bool IsSessionTime()
{
   if(!InpSessionFilterOn) return true;  // Filtro disattivato = sempre OK
   int h = TimeHour(TimeCurrent());
   // UTC del broker potrebbe essere diverso, ma usiamo TimeCurrent() come riferimento
   if(h >= InpSessionStartUTC && h < InpSessionEndUTC)
      return true;
   return false;
}

bool MarketOpen(string sym)
{
   return (MarketInfo(sym, MODE_BID) > 0);
}

bool HasOpenPosition(string sym)
{
   string normSym = NormSym(sym);
   int count = 0;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;
      if(NormSym(OrderSymbol()) == normSym) count++;
   }
   if(count >= InpMaxPerPair) return true;
   return false;
}

int CountOpenPositions()
{
   int count = 0;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() <= OP_SELL) count++;
   }
   return count;
}

bool WouldDoubleExpose(string sym, bool isLong)
{
   string normSym  = NormSym(sym);
   string baseCCY  = StringSubstr(normSym, 0, 3);
   string quoteCCY = StringSubstr(normSym, 3, 3);
   string ourLongCCY  = isLong ? baseCCY : quoteCCY;
   string ourShortCCY = isLong ? quoteCCY : baseCCY;

   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;

      string oSym = NormSym(OrderSymbol());
      if(oSym == normSym) return true;

      string oBase  = StringSubstr(oSym, 0, 3);
      string oQuote = StringSubstr(oSym, 3, 3);
      bool oIsLong  = (OrderType() == OP_BUY);
      string oLongCCY  = oIsLong ? oBase : oQuote;
      string oShortCCY = oIsLong ? oQuote : oBase;

      if(ourLongCCY == oLongCCY || ourShortCCY == oShortCCY) return true;
   }
   return false;
}

//+------------------------------------------------------------------+
// |  PROCESS STANDARD                                                 |
//+------------------------------------------------------------------+
void ProcessStandard()
{
   if(GetTradeSlot() == 0) return;
   int openCount = CountOpenPositions();

   int candidates[MAX_PAIRS];
   int candidateCount = 0;

   for(int i = 0; i < g_dataCount; i++)
   {
      int qCount = 0;
      string details = "";
      if(!CheckStandardFilters(i, qCount, details)) continue;

      if(qCount < g_stdMinQuality)
      {
         Print("[STD] ", g_symbol[i], " filtri: ", qCount, "/5 < min ", g_stdMinQuality);
         continue;
      }

      g_valid[i]  = true;
      g_score[i]  = CalculateStandardScore(i) - (qCount * 20);
      g_origin[i] = ORIGIN_STD;
      candidates[candidateCount] = i;
      candidateCount++;

      Print("[STD] ", g_symbol[i], " qualifica: ", qCount, "/4 | score: ", g_score[i]);
   }

   if(candidateCount == 0) return;

   SortCandidates(candidates, candidateCount);

   for(int c = 0; c < candidateCount && openCount < InpMaxConcurrent; c++)
   {
      int idx = candidates[c];
      if(TryOpenTrade(idx, ORIGIN_STD, InpMinRR))
         openCount++;
   }
}

//+------------------------------------------------------------------+
// |  PROCESS BREAKOUT                                                 |
//+------------------------------------------------------------------+
