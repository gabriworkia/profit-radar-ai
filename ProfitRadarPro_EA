//+------------------------------------------------------------------+
// |  AI WARMUP PING — Mantiene il server Render.com attivo            |
// |  Chiama /health ogni 10 minuti via WebRequest GET                 |
// |  Render free tier va in sleep dopo 15 min di inattivita'          |
// |  Questo ping previene il cold start (che puo' durare 30-50 sec)   |
//+------------------------------------------------------------------+
void AIWarmupPing()
{
   //--- Costruisci URL /health dall'URL /predict
   string healthUrl = InpAIUrl;
   StringReplace(healthUrl, "/predict", "/health");

   string headers = "Content-Type: application/json\r\n";
   char postData[];       // vuoto per GET
   char result[];
   string resultHeaders;

   Print("[WARMUP] Ping ", healthUrl, " ...");

   //--- Timeout 20s: un ping di risveglio deve aspettare che Render esca dal sleep
   int res = WebRequest("GET", healthUrl, headers, 20000, postData, result, resultHeaders);

   if(res == -1)
   {
      int err = GetLastError();
      g_warmupTotalFail++;
      g_warmupOK = false;
      Print("[WARMUP] FALLITO! err=", err, " (", ErrDesc(err), ")");
      Print("[WARMUP] Verifica: Strumenti > Opzioni > Expert Advisors > Allow WebRequest");
      Print("[WARMUP] Aggiungi: ", healthUrl);
   }
   else
   {
      //--- Converti risposta da byte array a stringa
      string respStr = "";
      int resultLen = ArraySize(result);
      for(int i = 0; i < resultLen; i++)
         respStr += CharToString(result[i]);

      g_warmupOK = true;
      g_warmupLastTime = TimeCurrent();
      g_warmupTotalOK++;

      //--- Parse status per conferma
      int posStatus = StringFind(respStr, "\"status\"");
      if(posStatus >= 0)
      {
         string statusSnippet = StringSubstr(respStr, posStatus, 30);
         if(StringFind(statusSnippet, "ok") >= 0)
            Print("[WARMUP] OK! Server attivo (ping #", g_warmupTotalOK, ")");
         else
            Print("[WARMUP] Risposta strana: ", StringSubstr(respStr, 0, 80));
      }
      else
      {
         Print("[WARMUP] Risposta ricevuta (", resultLen, " bytes)");
      }
   }
}

