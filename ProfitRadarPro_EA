//--- Barra ASCII per valori interi (es. loss di fila 1/2 -> [#-])
string MakeBar(int value, int maxValue)
{
   int slots = 10;
   if(maxValue <= 0) return "[----------]";
   int filled = (int)MathRound((double)value / maxValue * slots);
   if(filled > slots) filled = slots;
   if(filled < 0) filled = 0;
   string bar = "[";
   for(int i = 0; i < slots; i++)
      bar += (i < filled) ? "#" : "-";
   bar += "]";
   return bar;
}

//--- Barra ASCII percentuale (es. perse 6/12 EUR -> [#####-----] 50%)
string MakeBarPct(double value, double maxValue)
{
   int slots = 10;
   if(maxValue <= 0) return "[----------] 0%";
   double pct = value / maxValue;
   if(pct > 1.0) pct = 1.0;
   if(pct < 0.0) pct = 0.0;
   int filled = (int)MathRound(pct * slots);
   string bar = "[";
   for(int i = 0; i < slots; i++)
      bar += (i < filled) ? "#" : "-";
   bar += "] " + IntegerToString((int)MathRound(pct * 100)) + "%";
   return bar;
}

