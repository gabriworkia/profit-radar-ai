void UpdateTradeResults()
{
   datetime dayStart = StringToTime(TimeToString(TimeCurrent(), TIME_DATE));
   int losses = 0, wins = 0;
   double winAmount = 0, lossAmount = 0;

   //--- "trailing streak": perdite consecutive PIU' RECENTI (dall'ultimo trade
   //    andando indietro). Si ferma al primo trade vinto.
   //    Cosi' se hai 2 perse e poi una vincita, lo streak torna a 0.
   int recentStreak = 0;
   bool streakActive = true;

   //--- Scansiona dal trade PIU' RECENTE verso il passato
   for(int i = OrdersHistoryTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderCloseTime() < dayStart) break;
      if(OrderType() > OP_SELL) continue;

      double pnl = OrderProfit() + OrderSwap() + OrderCommission();
      if(pnl < 0)
      {
         losses++;
         lossAmount += MathAbs(pnl);
         if(streakActive) recentStreak++;   // conta solo finche' non trova una vincita
      }
      else
      {
         wins++;
         winAmount += pnl;
         streakActive = false;              // prima vincita -> stop conteggio streak
      }
   }

   g_dailyLosses       = losses;
   g_dailyWins         = wins;
   g_dailyWinAmount    = winAmount;
   g_dailyLossAmount   = lossAmount;
   g_consecutiveLosses = recentStreak;      // perdite consecutive ATTUALI (non il max)

   //--- Auto-sblocco: se il daily stop era attivo ma le condizioni non sono
   //    piu' verificate (es. una nuova vincita ha riportato il bilancio sotto
   //    soglia, o lo streak si e' azzerato), riattiva il trading.
   if(g_dailyStopped)
   {
      bool consecOK = (g_consecutiveLosses < InpMaxConsecLoss);
      bool ratioOK  = (g_dailyWinAmount <= 0.0) ||
                      (g_dailyLossAmount <= g_dailyWinAmount * InpLossWeight);
      if(consecOK && ratioOK)
      {
         g_dailyStopped = false;
         Print("[DAILY] Stop RIMOSSO: condizioni rientrate ",
               "(consec ", g_consecutiveLosses, "/", InpMaxConsecLoss,
               " | perse ", DoubleToString(g_dailyLossAmount, 2),
               "€ <= soglia ", DoubleToString(g_dailyWinAmount * InpLossWeight, 2), "€)");
      }
   }
}

bool CanTrade()
{
   //--- Interruttore Daily Stop: se OFF, salta TUTTA la logica di stop giornaliero
   //    (resta solo il blocco weekend/venerdi). Utile per test o sessioni libere.
   if(!InpDailyStopOn)
   {
      g_dailyStopped = false;   // forza disattivo
      if(IsWeekend() || IsFridayEvening()) return false;
      return true;
   }

   if(g_dailyStopped) return false;

   //--- Stop consecutivi (hard limit di sicurezza)
   if(g_consecutiveLosses >= InpMaxConsecLoss)
   {
      Print("Stop: ", g_consecutiveLosses, " loss consecutivi");
      g_dailyStopped = true;
      return false;
   }

   //=== SISTEMA W/L RATIO PESATO (importi €, non conteggi) ===
   // L'unico stop "di mercato" si basa sul BILANCIO in euro tra vincite e
   // perdite, con le PERDITE che pesano piu' delle vincite (InpLossWeight).
   //
   // Regola: STOP se  PerditeTotali€  >  VincititeTotali€ × InpLossWeight
   //
   // Esempi con InpLossWeight = 1.5:
   //   - Vinto 8.00€ (8 trade da 1€), perso 2.50€  → soglia 12.0€ → OK (2 perse non fermano!)
   //   - Vinto 8.00€, perso 12.50€                 → soglia 12.0€ → STOP
   //   - Vinto 1.00€, perso 2.00€                  → soglia 1.5€  → STOP
   //   - Vinto 3.00€, perso 4.00€                  → soglia 4.5€  → OK continua
   //
   // Caso 0 vincite: la soglia sarebbe 0 → la prima perdita fermerebbe subito.
   // In quel caso ci affidiamo SOLO al safety dei loss consecutivi (sopra),
   // cosi' non ti blocchi alla prima sfortuna di inizio giornata.

   if(g_dailyWinAmount > 0.0)
   {
      double lossThreshold = g_dailyWinAmount * InpLossWeight;
      if(g_dailyLossAmount > lossThreshold)
      {
         Print("Stop W/L pesato: perse ", DoubleToString(g_dailyLossAmount, 2),
               "€ > soglia ", DoubleToString(lossThreshold, 2),
               "€ (vinte ", DoubleToString(g_dailyWinAmount, 2),
               "€ × ", DoubleToString(InpLossWeight, 1), ")");
         Print("  Vincite: ", DoubleToString(g_dailyWinAmount, 2), "€ (", g_dailyWins, " trade)");
         Print("  Perdite: ", DoubleToString(g_dailyLossAmount, 2), "€ (", g_dailyLosses, " trade)");
         g_dailyStopped = true;
         return false;
      }
   }

   if(IsWeekend() || IsFridayEvening()) return false;

   return true;
}

