void ResetDailyStats()
{
   int today = TimeDay(TimeCurrent());
   if(today != g_currentDay)
   {
      g_currentDay        = today;
      g_dailyLosses       = 0;
      g_dailyWins         = 0;
      g_dailyWinAmount    = 0;
      g_dailyLossAmount   = 0;
      g_dailyStartBalance = AccountBalance();
      g_dailyStopped      = false;
      g_consecutiveLosses = 0;
      Print("Nuovo giorno | Balance: ", DoubleToString(g_dailyStartBalance, 2));
   }
}

void UpdateTradeResults()
{
   datetime dayStart = StringToTime(TimeToString(TimeCurrent(), TIME_DATE));
   int losses = 0, wins = 0, consecLoss = 0, maxConsecLoss = 0;
   double winAmount = 0, lossAmount = 0;

   for(int i = OrdersHistoryTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderCloseTime() < dayStart) break;
      if(OrderType() > OP_SELL) continue;

      double pnl = OrderProfit() + OrderSwap() + OrderCommission();
      if(pnl < 0) { losses++; consecLoss++; if(consecLoss > maxConsecLoss) maxConsecLoss = consecLoss; lossAmount += MathAbs(pnl); }
      else { wins++; consecLoss = 0; winAmount += pnl; }
   }

   g_dailyLosses       = losses;
   g_dailyWins         = wins;
   g_dailyWinAmount    = winAmount;
   g_dailyLossAmount   = lossAmount;
   g_consecutiveLosses = maxConsecLoss;
}

bool CanTrade()
{
   if(g_dailyStopped) return false;

   //--- Stop consecutivi (hard limit di sicurezza)
   if(g_consecutiveLosses >= InpMaxConsecLoss)
   {
      Print("Stop: ", g_consecutiveLosses, " loss consecutivi");
      g_dailyStopped = true;
      return false;
   }

   //=== NUOVO SISTEMA: bilancio vincite vs perdite ===
   // Non si ferma dopo N perdite — si ferma quando le perdite superano le vincite
   // di un fattore configurabile (max_daily_loss diventa il "loss ratio" max)
   //
   // Esempi con max_daily_loss = 3 (significa: perdite possono essere 3x le vincite):
   //   - Vinto 1.00€, perso 0.30€ → ratio 0.30 → OK continua
   //   - Vinto 0.50€, perso 1.50€ → ratio 3.0  → STOP (perdite = 3x vincite)
   //   - Vinto 2.00€, perso 1.50€ → ratio 0.75 → OK continua (le vincite coprono)
   //   - Perso 1.50€, vinto 0€    → ratio ∞    → STOP se netto sotto soglia
   //
   // Inoltre: se il netto giornaliero (vincite - perdite) scende sotto
   // il -X% del balance → STOP (protezione assoluta)

   double dailyPnL      = g_dailyWinAmount - g_dailyLossAmount;
   double dailyPnLPct   = (g_dailyStartBalance > 0) ? (dailyPnL / g_dailyStartBalance) * 100.0 : 0;

   //--- Protezione 1: limite netto giornaliero (es: -3% del balance)
   //    InpMaxDailyLoss ora = max drawdown % prima di fermarsi
   if(g_dailyLosses > 0 && dailyPnLPct <= -(double)InpMaxDailyLoss)
   {
      Print("Stop drawdown: ", DoubleToString(dailyPnLPct, 2), "% (limite -", InpMaxDailyLoss, "%)");
      Print("  Vincite: ", DoubleToString(g_dailyWinAmount, 2), "€ (", g_dailyWins, " trade)");
      Print("  Perdite: ", DoubleToString(g_dailyLossAmount, 2), "€ (", g_dailyLosses, " trade)");
      g_dailyStopped = true;
      return false;
   }

   //--- Protezione 2: se non hai ancora vinto niente, stop dopo 3 perdite
   //    (evita di perdere subito all'inizio della giornata)
   if(g_dailyWins == 0 && g_dailyLosses >= 3)
   {
      Print("Stop: ", g_dailyLosses, " perse senza vincite (", DoubleToString(g_dailyLossAmount, 2), "€)");
      g_dailyStopped = true;
      return false;
   }

   //--- Protezione 3: perdite superano le vincite per troppo margine
   //    Se le perdite sono più del triplo delle vincite → fermati
   if(g_dailyWinAmount > 0 && g_dailyLossAmount > g_dailyWinAmount * 3.0)
   {
      Print("Stop ratio: perse ", DoubleToString(g_dailyLossAmount, 2), "€ > 3x vinte ", DoubleToString(g_dailyWinAmount, 2), "€");
      g_dailyStopped = true;
      return false;
   }

   //--- Target giornaliero raggiunto
   if(dailyPnLPct >= InpMaxDailyProfit)
   {
      Print("Target raggiunto: +", DoubleToString(dailyPnLPct, 2), "%");
      Print("  Vincite: ", DoubleToString(g_dailyWinAmount, 2), "€ (", g_dailyWins, " trade)");
      Print("  Perdite: ", DoubleToString(g_dailyLossAmount, 2), "€ (", g_dailyLosses, " trade)");
      g_dailyStopped = true;
      return false;
   }

   if(IsWeekend() || IsFridayEvening()) return false;

   return true;
}

