// |  EXPORT DATA FROM EA                                              |
//+------------------------------------------------------------------+
void ExportDataFromEA()
{
   datetime startTime = TimeCurrent();

   int handle = FileOpen(InpCSVFile, FILE_CSV | FILE_WRITE, ';');
   if(handle == INVALID_HANDLE)
   {
      Print("[EXPORT] Errore apertura file: ", InpCSVFile);
      return;
   }

   FileWrite(handle, "Symbol", "Close", "EMA21", "EMA200", "EMA_Position",
      "ADX", "RadarValue", "HistogramState", "ADR",
      "HistConsecColor", "HistBarsSinceGray", "HistCycleCount", "HistCrossedZero",
      "HistBarSlope", "HistPullbackDepth", "HistSeqEncoded", "HistBarRatio",
      "HistColorNow", "HistColorSlope", "HistColorCurve", "HistColorR2",
      "HistColorCentroid", "HistColorSum");

   int exported = 0;
   for(int p = 0; p < 28; p++)
   {
      ShowExportProgress(p + 1, 28);

      string sym = PAIRS[p];
      int shift = 1;

      double close_now = iClose(sym, PERIOD_M15, shift);
      if(close_now <= 0) continue;

      double ema21  = iMA(sym, PERIOD_M15, 21, 0, MODE_EMA, PRICE_CLOSE, shift);
      double ema200 = iMA(sym, PERIOD_M15, 200, 0, MODE_EMA, PRICE_CLOSE, shift);
      double adx    = iADX(sym, PERIOD_M15, 14, PRICE_CLOSE, MODE_MAIN, shift);
      int emaPosition = (ema21 > ema200) ? 1 : -1;

      double radarValue = 0;
      string histState = "NONE";
      GetRadarDataForExport(sym, radarValue, histState);

      string adrValue = GetADRForExport(sym);
      int digits = (int)MarketInfo(sym, MODE_DIGITS);

      //--- Feature istogramma calcolate direttamente dal simbolo
      int hConsec, hSinceGray, hCycles, hCrossedZero, hSeqEnc;
      double hSlope, hPullback, hBarRatio;
      double hColorNow, hColorSlope, hColorCurve, hColorR2, hColorCentroid;
      int hColorSum;
      CalcHistFeatures(sym,
                       hConsec, hSinceGray, hCycles, hCrossedZero,
                       hSlope, hPullback, hSeqEnc, hBarRatio,
                       hColorNow, hColorSlope, hColorCurve, hColorR2, hColorCentroid, hColorSum);

      FileWrite(handle,
          sym,
          NormalizeDouble(close_now, digits),
          NormalizeDouble(ema21, digits),
          NormalizeDouble(ema200, digits),
          emaPosition,
          NormalizeDouble(adx, 1),
          NormalizeDouble(radarValue, 2),
          histState,
          adrValue,
          hConsec,
          hSinceGray,
          hCycles,
          hCrossedZero,
          DoubleToString(hSlope, 6),
          DoubleToString(hPullback, 1),
          hSeqEnc,
          DoubleToString(hBarRatio, 3),
          DoubleToString(hColorNow, 0),
          DoubleToString(hColorSlope, 4),
          DoubleToString(hColorCurve, 4),
          DoubleToString(hColorR2, 3),
          DoubleToString(hColorCentroid, 3),
          hColorSum);

      exported++;
      if((p + 1) % 7 == 0) Sleep(200);
   }

   FileClose(handle);

   int elapsed = (int)(TimeCurrent() - startTime);
   Print("[EXPORT] Completato! ", exported, " cross in ", elapsed, " secondi");

   g_dataValidated = false;
   g_validBars = 0;
   g_usingFallback = true;
   g_activeDataSource = "CSV";
   g_autoFailCount = 0;

   bool loadOK = ReadCSV();
   if(loadOK)
   {
      Print("[EXPORT] CSV caricato: ", g_dataCount, " cross");
      bool valid = ValidateMarketData();
      if(valid)
         Print("[EXPORT] >>> DATI VALIDATI! <<<");
      else
         Print("[EXPORT] Validazione fallita");
   }
   else
   {
      Print("[EXPORT] ERRORE: impossibile rileggere il CSV");
   }
}

//+------------------------------------------------------------------+
// |  GET RADAR DATA PER EXPORT                                        |
//+------------------------------------------------------------------+
void GetRadarDataForExport(string sym, double &value, string &histState)
{
   int shift = 1;
   double buffers[5];
   ArrayInitialize(buffers, 0);

   for(int i = 0; i < 5; i++)
   {
      buffers[i] = iCustom(sym, PERIOD_M15, InpRadarIndicator, i, shift);
      if(MathAbs(buffers[i]) > 1000) buffers[i] = 0;
   }

   value = 0;
   histState = "NONE";

   if(buffers[0] > 0 && buffers[1] == 0 && buffers[2] == 0 && buffers[3] == 0)
   { value = buffers[0]; histState = "GREEN_LIGHT"; return; }

   if(buffers[1] > 0 && buffers[0] == 0 && buffers[2] == 0 && buffers[3] == 0)
   { value = buffers[1]; histState = "GREEN_DARK"; return; }

   if(buffers[2] < 0 && buffers[0] == 0 && buffers[1] == 0 && buffers[3] == 0)
   { value = buffers[2]; histState = "RED_LIGHT"; return; }

   if(buffers[3] < 0 && buffers[0] == 0 && buffers[1] == 0 && buffers[2] == 0)
   { value = buffers[3]; histState = "RED_DARK"; return; }

   if(buffers[4] != 0)
   { value = buffers[4]; histState = "GRAY"; return; }
}

//+------------------------------------------------------------------+
// |  GET ADR PER EXPORT                                               |
//+------------------------------------------------------------------+
string GetADRForExport(string sym)
{
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);
   double pipMult = 1.0;
   if(digits == 3 || digits == 5) pipMult = 10.0;

   double todayHigh = iHigh(sym, PERIOD_D1, 0);
   double todayLow  = iLow(sym, PERIOD_D1, 0);
   if(todayHigh == 0 || todayLow == 0) return "0/0";

   double todayRange = (todayHigh - todayLow) / point / pipMult;

   double sum = 0;
   int countedDays = 0;
   for(int i = 1; i <= 10; i++)
   {
      double h = iHigh(sym, PERIOD_D1, i);
      double l = iLow(sym, PERIOD_D1, i);
      if(h == 0 || l == 0) continue;
      sum += (h - l) / point / pipMult;
      countedDays++;
   }

   double adr = (countedDays > 0) ? sum / countedDays : 0;
   return IntegerToString((int)todayRange) + "/" + IntegerToString((int)adr);
}

//+------------------------------------------------------------------+
// |  CSV READER                                                       |
//+------------------------------------------------------------------+
bool ReadCSV()
{
   int handle = FileOpen(InpCSVFile, FILE_CSV | FILE_READ | FILE_ANSI, ';');
   if(handle == INVALID_HANDLE)
   {
      static datetime lastWarn = 0;
      if(TimeCurrent() - lastWarn > 60)
      {
         Print("[CSV] FILE NON TROVATO: MQL4/Files/", InpCSVFile);
         lastWarn = TimeCurrent();
      }
      return false;
   }

   datetime fileModTime = (datetime)FileGetInteger(handle, FILE_MODIFY_DATE);
   int fileAge = (int)(TimeCurrent() - fileModTime);
   if(InpCSVMaxAgeSec > 0 && fileAge > InpCSVMaxAgeSec)
   {
      FileClose(handle);
      return false;
   }

   g_dataCount = 0;

   //--- Il CSV ha 23 colonne (9 base + 14 feature istogramma).
   //    Leggiamo TUTTE le celle della riga per non disallineare le righe.
   #define CSV_COLS 23

   while(!FileIsEnding(handle) && g_dataCount < MAX_PAIRS)
   {
      string fields[CSV_COLS];
      bool rowComplete = true;

      for(int f = 0; f < CSV_COLS; f++)
      {
         if(FileIsEnding(handle) && f < CSV_COLS - 1) { rowComplete = false; break; }
         fields[f] = FileReadString(handle);
      }

      if(!rowComplete) break;

      for(int f = 0; f < CSV_COLS; f++)
      {
         StringTrimLeft(fields[f]);
         StringTrimRight(fields[f]);
      }

      if(StringFind(fields[0], "Symbol") >= 0) continue;
      if(StringLen(fields[0]) < 6) continue;

      StringToUpper(fields[7]);
      StringReplace(fields[7], " ", "_");
      if(fields[7] != "GREEN_LIGHT" && fields[7] != "GREEN_DARK" &&
         fields[7] != "RED_LIGHT"   && fields[7] != "RED_DARK"   &&
         fields[7] != "GRAY")
         continue;

      string firstChar = StringSubstr(fields[0], 0, 1);
      if(firstChar >= "0" && firstChar <= "9") continue;

      int idx = g_dataCount;

      g_symbol[idx]         = fields[0];
      g_close[idx]          = StringToDouble(fields[1]);
      g_ema21[idx]          = StringToDouble(fields[2]);
      g_ema200[idx]         = StringToDouble(fields[3]);
      g_emaPosition[idx]    = (int)StringToDouble(fields[4]);
      //--- Calcola gap EMA (%) da CSV
      if(g_close[idx] > 0)
         g_emaGapPct[idx] = (g_ema21[idx] - g_ema200[idx]) / g_close[idx] * 100.0;
      else
         g_emaGapPct[idx] = 0;
      g_adx[idx]            = StringToDouble(fields[5]);

      double parsedRV = StringToDouble(fields[6]);
      if(MathAbs(parsedRV) > 10000)
      {
         Print("[CSV] RV corrotto per ", fields[0], " = ", DoubleToString(parsedRV, 0), " -> SCARTATO");
         continue;
      }

      g_radarValue[idx]     = parsedRV;
      g_histogramState[idx] = ParseHistogramState(fields[7]);
      g_radarType[idx]      = DeriveRadarType(g_histogramState[idx], parsedRV);
      ParseADR(fields[8], g_pipFatti[idx], g_media10gg[idx]);

      //--- Calcolo autonomo e reale del Filtro RX via Price Action (calcolato su 10 GIORNI D1)
      g_rxType[idx]    = RX_NONE;
      g_rxAge[idx]     = 0;
      g_rxPresent[idx] = false;

      int highestIdx_csv = iHighest(fields[0], PERIOD_D1, MODE_HIGH, 10, 1);
      int lowestIdx_csv  = iLowest(fields[0], PERIOD_D1, MODE_LOW, 10, 1);
      if(highestIdx_csv >= 0 && lowestIdx_csv >= 0)
      {
         double highestHigh = iHigh(fields[0], PERIOD_D1, highestIdx_csv);
         double lowestLow   = iLow(fields[0], PERIOD_D1, lowestIdx_csv);
         double curPrice    = iClose(fields[0], PERIOD_M15, 1);

         if(curPrice > highestHigh)
         {
            g_rxType[idx]    = RX_NEW_H;
            g_rxPresent[idx] = true;
            g_rxAge[idx]     = 1;
         }
         else if(curPrice < lowestLow)
         {
            g_rxType[idx]    = RX_NEW_L;
            g_rxPresent[idx] = true;
            g_rxAge[idx]     = 1;
         }
      }

      if(g_media10gg[idx] > 0)
         g_adrPercent[idx] = (g_pipFatti[idx] / g_media10gg[idx]) * 100.0;
      else
         g_adrPercent[idx] = 999.9;

      g_valid[idx]  = true;
      g_score[idx]  = 99999;
      g_origin[idx] = ORIGIN_STD;

      //--- Carica le feature istogramma dal CSV (colonne 9..22)
      g_histConsecColor[idx]   = (int)StringToDouble(fields[9]);
      g_histBarsSinceGray[idx] = (int)StringToDouble(fields[10]);
      g_histCycleCount[idx]    = (int)StringToDouble(fields[11]);
      g_histCrossedZero[idx]   = ((int)StringToDouble(fields[12]) == 1);
      g_histBarSlope[idx]      = StringToDouble(fields[13]);
      g_histPullbackDepth[idx] = StringToDouble(fields[14]);
      g_histSeqEncoded[idx]    = (int)StringToDouble(fields[15]);
      g_histBarRatio[idx]      = StringToDouble(fields[16]);
      g_histColorNow[idx]      = StringToDouble(fields[17]);
      g_histColorSlope[idx]    = StringToDouble(fields[18]);
      g_histColorCurve[idx]    = StringToDouble(fields[19]);
      g_histColorR2[idx]       = StringToDouble(fields[20]);
      g_histColorCentroid[idx] = StringToDouble(fields[21]);
      g_histColorSum[idx]      = (int)StringToDouble(fields[22]);

      g_dataCount++;
   }

   FileClose(handle);

   if(g_dataCount == 0) return false;

   int nonGrayCSV = 0;
   for(int c = 0; c < g_dataCount; c++)
      if(g_histogramState[c] != HS_GRAY) nonGrayCSV++;

   Print("[CSV] Caricato: ", g_dataCount, " cross | Non-GRAY: ", nonGrayCSV, "/28");
   return true;
}

//+------------------------------------------------------------------+
// |  PARSE HELPERS                                                    |
//+------------------------------------------------------------------+
int ParseRadarType(string s)
{
   StringToUpper(s);
   if(s == "LONG")  return RT_LONG;
   if(s == "SHORT") return RT_SHORT;
   if(s == "RISE")  return RT_RISE;
   if(s == "FALL")  return RT_FALL;
   return RT_UNKNOWN;
}

int ParseHistogramState(string s)
{
   StringToUpper(s);
   StringReplace(s, " ", "_");
   if(s == "GREEN_LIGHT") return HS_GREEN_LIGHT;
   if(s == "GREEN_DARK")  return HS_GREEN_DARK;
   if(s == "RED_LIGHT")   return HS_RED_LIGHT;
   if(s == "RED_DARK")    return HS_RED_DARK;
   if(s == "GRAY")        return HS_GRAY;
   return HS_UNKNOWN;
}

void ParseADR(string s, double &pipFatti, double &media10gg)
{
   int pos = StringFind(s, "/");
   if(pos < 0) { pipFatti = 0; media10gg = 0; return; }
   pipFatti  = StringToDouble(StringSubstr(s, 0, pos));
   media10gg = StringToDouble(StringSubstr(s, pos + 1));
}

void ParseRX(string s, int &rxType, int &rxAge, bool &rxPresent)
{
   StringToUpper(s);
   StringTrimLeft(s);
   StringTrimRight(s);
   rxType = RX_NONE; rxAge = 0; rxPresent = false;
   if(StringLen(s) == 0 || s == "-" || s == "--" || s == "---") return;

   int posH = StringFind(s, "NEW-H");
   if(posH >= 0)
   {
      rxType = RX_NEW_H; rxPresent = true;
      int age = (int)StringToDouble(StringSubstr(s, posH + 5));
      rxAge = (age >= 1 && age <= 4) ? age : 1;
      return;
   }

   int posL = StringFind(s, "NEW-L");
   if(posL >= 0)
   {
      rxType = RX_NEW_L; rxPresent = true;
      int age = (int)StringToDouble(StringSubstr(s, posL + 5));
      rxAge = (age >= 1 && age <= 4) ? age : 1;
      return;
   }
}

//+------------------------------------------------------------------+
// |  AGGRESSIVENESS PRESET                                            |
//+------------------------------------------------------------------+
void ApplyAggressiveness()
{
   //=== AGGRESSIVITA' = SOLO QUANTI FILTRI SERVONO (non i loro valori) ===
   // NON tocca: lotti, rischio (peso perdite, loss consecutivi), RR, BE,
   //            trailing, TP  -> controllo manuale.
   // NON tocca: i VALORI dei filtri (InpRV_Max, InpADR_Max, InpReversalRV)
   //            -> uguali per tutte le modalita', li imposti TU a mano.
   //
   // Cambia SOLO la soglia minima di filtri soddisfatti per ogni modulo:
   //   1=Conservativo -> tutti i filtri        (STD 4/4, BRK 8/8, REV 4/4)
   //   2=Moderato     -> tutti i filtri -1     (STD 3/4, BRK 7/8, REV 3/4)
   //   3=Aggressivo   -> tutti i filtri -2     (STD 2/4, BRK 6/8, REV 2/4)

   Print(">>> Aggressivita': ", AggressivenessStr(), " (", InpAggressiveness,
         ") - SOLO numero filtri (valori invariati)");

   if(InpAggressiveness == AGGR_CONSERVATIVO)
   {
      //--- CONSERVATIVO: tutti i filtri devono passare
      g_stdMinQuality      = 4;      // STANDARD: serve 4/4 (tutti)
      g_brkMinQuality      = 8;      // BREAKOUT: serve 8/8 (tutti)
      g_revMinQuality      = 5;      // REVERSAL: serve 5/5 (tutti: ADR, ADX, Hist+RX, EMA, Decel)
   }
   else if(InpAggressiveness == AGGR_MODERATO)
   {
      //--- MODERATO: un filtro puo' saltare (tutti -1)
      g_stdMinQuality      = 3;      // STANDARD: serve 3/4 (tutti -1)
      g_brkMinQuality      = 7;      // BREAKOUT: serve 7/8 (tutti -1)
      g_revMinQuality      = 4;      // REVERSAL: serve 4/5 (tutti -1)
   }
   else if(InpAggressiveness == AGGR_AGGRESSIVO)
   {
      //--- AGGRESSIVO: due filtri possono saltare (tutti -2)
      g_stdMinQuality      = 2;      // STANDARD: basta 2/4 (tutti -2)
      g_brkMinQuality      = 6;      // BREAKOUT: basta 6/8 (tutti -2)
      g_revMinQuality      = 3;      // REVERSAL: basta 3/5 (tutti -2)
   }
   else if(InpAggressiveness == AGGR_IPERCONSERVATIVO)
   {
      //--- IPERCONSERVATIVO: usa i criteri della whitelist (6 filtri rigidi)
      g_stdMinQuality      = 6;      // STANDARD: serve 6/6 (tutti)
      g_brkMinQuality      = 8;      // BREAKOUT: tutti
      g_revMinQuality      = 5;      // REVERSAL: tutti
   }
   else
   {
      Print("  WARNING: Aggressivita' non valida. Uso Moderato.");
      InpAggressiveness = AGGR_MODERATO;
      ApplyAggressiveness();
      return;
   }
}

string AggressivenessStr()
{
   switch(InpAggressiveness)
   {
      case AGGR_CONSERVATIVO:  return "CONSERVATIVO";
      case AGGR_MODERATO:      return "MODERATO";
      case AGGR_AGGRESSIVO:    return "AGGRESSIVO";
      case AGGR_IPERCONSERVATIVO: return "IPERCONSERVATIVO";
      default:                 return "SCONOSCIUTO";
   }
}

//+------------------------------------------------------------------+
// |  TEST TRADE                                                       |
//+------------------------------------------------------------------+
void CheckTestTrade()
{
   if(!InpTestTrade) return;
   if(g_testTradeDone) return;

   g_testTradeDone = true;
   InpTestTrade = false;

   string sym    = Symbol();
   int    digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point  = MarketInfo(sym, MODE_POINT);
   double minLot = MarketInfo(sym, MODE_MINLOT);
   double lotStep = MarketInfo(sym, MODE_LOTSTEP);
   double ask    = MarketInfo(sym, MODE_ASK);

   if(ask <= 0 || point <= 0) return;

   double lots = MathFloor(minLot / lotStep) * lotStep;
   if(lots < minLot) lots = minLot;
   lots = NormalizeDouble(lots, 2);

   double pipMult = (digits == 3 || digits == 5) ? 10.0 : 1.0;
   double slDist  = 50 * point * pipMult;
   double tpDist  = 100 * point * pipMult;
   double slPrice = NormalizeDouble(ask - slDist, digits);
   double tpPrice = NormalizeDouble(ask + tpDist, digits);

   Print(">>> TEST TRADE: BUY ", sym, " Lots:", DoubleToString(lots, 2));

   int ticket = OrderSend(sym, OP_BUY, lots, NormalizeDouble(ask, digits),
                           InpMaxSlippage, 0, 0, "PRP_TEST", InpMagicNumber, 0, clrLime);

   if(ticket < 0)
   {
      Print(">>> TEST FALLITO: err ", GetLastError());
      return;
   }

   Print(">>> Ticket #", ticket, " aperto");

   Sleep(300);
   RefreshRates();

   if(OrderSelect(ticket, SELECT_BY_TICKET))
   {
      double openPrice = OrderOpenPrice();
      if(!OrderModify(ticket, openPrice, slPrice, tpPrice, 0, clrBlue))
      {
         Sleep(1000);
         RefreshRates();
         if(!OrderModify(ticket, openPrice, slPrice, tpPrice, 0, clrBlue))
            Print("[TEST] OrderModify retry fallito: err ", GetLastError());
      }
   }

   Print(">>> TEST TRADE COMPLETATO");
}

//+------------------------------------------------------------------+
// |  VALIDATE DATA                                                    |
//+------------------------------------------------------------------+
bool ValidateMarketData()
{
   if(g_dataValidated) return true;

   g_nonGrayCount = 0;
   int nonZeroRV  = 0;
   int differentHist = 0;
   int lastHist   = -999;

   for(int i = 0; i < g_dataCount; i++)
   {
      if(g_histogramState[i] != HS_GRAY) g_nonGrayCount++;
      if(MathAbs(g_radarValue[i]) > 0.01) nonZeroRV++;
      if(g_histogramState[i] != lastHist) { differentHist++; lastHist = g_histogramState[i]; }
   }

   Print("[VALIDAZIONE] Cross: ", g_dataCount, " | Non-GRAY: ", g_nonGrayCount,
         " | RV!=0: ", nonZeroRV, " | Hist diversi: ", differentHist);

   if(g_nonGrayCount < 1) { Print("[VALIDAZIONE] FALLITA: nessun cross non-GRAY"); return false; }
   if(nonZeroRV < 1)      { Print("[VALIDAZIONE] FALLITA: nessun RV non-zero"); return false; }
   if(differentHist < 1)  { Print("[VALIDAZIONE] FALLITA: un solo stato istogramma"); return false; }

   g_dataValidated = true;
   Print("[VALIDAZIONE] >>> OK! Dati verificati! <<<");
   return true;
}

//+------------------------------------------------------------------+
// |  AUTO DATA COLLECTION                                             |
//+------------------------------------------------------------------+
void CollectMarketData()
{
   g_dataCount = 0;

   for(int p = 0; p < 28; p++)
   {
      string sym = PAIRS[p];
      int shift = 1;

      double closePrice = iClose(sym, PERIOD_M15, shift);
      if(closePrice <= 0) continue;

      int idx = g_dataCount;

      g_symbol[idx]      = sym;
      g_close[idx]       = closePrice;
      g_ema21[idx]       = iMA(sym, PERIOD_M15, 21, 0, MODE_EMA, PRICE_CLOSE, shift);
      g_ema200[idx]      = iMA(sym, PERIOD_M15, 200, 0, MODE_EMA, PRICE_CLOSE, shift);
      g_adx[idx]         = iADX(sym, PERIOD_M15, 14, PRICE_CLOSE, MODE_MAIN, shift);
      g_emaPosition[idx] = (g_ema21[idx] > g_ema200[idx]) ? 1 : -1;
      //--- Calcola gap EMA (%)
      if(g_close[idx] > 0)
         g_emaGapPct[idx] = (g_ema21[idx] - g_ema200[idx]) / g_close[idx] * 100.0;
      else
         g_emaGapPct[idx] = 0;

      double radarVal = 0;
      string histState = "GRAY";
      GetRadarData(sym, shift, radarVal, histState);

      if(MathAbs(radarVal) > 10000)
      {
         Print("[AUTO] RV corrotto per ", sym, " -> SCARTATO");
         continue;
      }

      g_radarValue[idx] = radarVal;
      g_histogramState[idx] = ParseHistogramState(histState);
      g_radarType[idx] = DeriveRadarType(g_histogramState[idx], radarVal);

      GetADR(sym, g_pipFatti[idx], g_media10gg[idx]);
      if(g_media10gg[idx] > 0)
         g_adrPercent[idx] = (g_pipFatti[idx] / g_media10gg[idx]) * 100.0;
      else
         g_adrPercent[idx] = 999.9;

      //--- Recupero del Filtro RX dall'oggetto grafico del Radar (con fallback Price Action)
      g_rxType[idx]    = RX_NONE;
      g_rxAge[idx]     = 0;
      g_rxPresent[idx] = false;

      string rx_objName = "RadarRX_" + IntegerToString(p);
      bool rxFoundInChart = false;

      if(ObjectFind(0, rx_objName) >= 0)
      {
         string rxText = ObjectGetString(0, rx_objName, OBJPROP_TEXT);
         if(StringLen(rxText) > 0 && rxText != "-" && rxText != "--" && rxText != "---")
         {
            ParseRX(rxText, g_rxType[idx], g_rxAge[idx], g_rxPresent[idx]);
            if(g_rxPresent[idx])
            {
               rxFoundInChart = true;
               Print("[RX] ", sym, " segnale letto da grafico (", rx_objName, "): ", rxText);
            }
         }
      }

      //--- Fallback autonomo via Price Action se l'oggetto grafico del Radar non viene trovato o e' vuoto (calcolato su 10 GIORNI)
      if(!rxFoundInChart)
      {
         int highestIdx_d = iHighest(sym, PERIOD_D1, MODE_HIGH, 10, 1);
         int lowestIdx_d  = iLowest(sym, PERIOD_D1, MODE_LOW, 10, 1);
         if(highestIdx_d >= 0 && lowestIdx_d >= 0)
         {
            double highestHigh = iHigh(sym, PERIOD_D1, highestIdx_d);
            double lowestLow   = iLow(sym, PERIOD_D1, lowestIdx_d);
            double curPrice    = iClose(sym, PERIOD_M15, shift);

            if(curPrice > highestHigh)
            {
               g_rxType[idx]    = RX_NEW_H;
               g_rxPresent[idx] = true;
               g_rxAge[idx]     = 1;
               Print("[RX] ", sym, " segnale calcolato via Price Action (10 GIORNI): NEW-H (eta' 1)");
            }
            else if(curPrice < lowestLow)
            {
               g_rxType[idx]    = RX_NEW_L;
               g_rxPresent[idx] = true;
               g_rxAge[idx]     = 1;
               Print("[RX] ", sym, " segnale calcolato via Price Action (10 GIORNI): NEW-L (eta' 1)");
            }
         }
      }
      g_valid[idx]  = true;
      g_score[idx]  = 99999;
      g_origin[idx] = ORIGIN_STD;

      g_dataCount++;
   }

   int activeCross = 0;
   for(int c = 0; c < g_dataCount; c++)
      if(g_histogramState[c] != HS_GRAY) activeCross++;

   if(InpExportCSV && g_dataCount > 0)
      ExportCSVLog();

   if(g_dataCount > 0)
      Print("[AUTO] Dati: ", g_dataCount, " cross | Non-GRAY: ", activeCross, "/28");

   if(g_dataCount > 0)
   {
      if(!g_peaksCalculated || TimeCurrent() - g_lastPeakCalcTime > 14400)
      {
         UpdateDynamicPeaks();
         g_peaksCalculated = true;
         g_lastPeakCalcTime = TimeCurrent();
      }
   }
}

//+------------------------------------------------------------------+
// |  GET RADAR DATA                                                   |
//+------------------------------------------------------------------+
void GetRadarData(string sym, int shift, double &value, string &histState)
{
   double buf[5];
   ArrayInitialize(buf, 0);
   for(int i = 0; i < 5; i++)
   {
      buf[i] = iCustom(sym, PERIOD_M15, InpRadarIndicator, i, shift);
      if(MathAbs(buf[i]) > 1000) buf[i] = 0;
   }

   value = 0;
   histState = "GRAY";

   if(buf[0] > 0 && buf[1] == 0 && buf[2] == 0 && buf[3] == 0)
   { value = buf[0]; histState = "GREEN_LIGHT"; return; }

   if(buf[1] > 0 && buf[0] == 0 && buf[2] == 0 && buf[3] == 0)
   { value = buf[1]; histState = "GREEN_DARK"; return; }

   if(buf[2] < 0 && buf[0] == 0 && buf[1] == 0 && buf[3] == 0)
   { value = buf[2]; histState = "RED_LIGHT"; return; }

   if(buf[3] < 0 && buf[0] == 0 && buf[1] == 0 && buf[2] == 0)
   { value = buf[3]; histState = "RED_DARK"; return; }

   if(buf[4] != 0)
   { value = buf[4]; histState = "GRAY"; return; }

   //--- Tutti i buffer = 0: NON e' grigio vero, e' DATO MANCANTE.
   //    Ritorniamo "NONE" cosi' le feature non vengono falsate.
   value = 0;
   histState = "NONE";

   static datetime lastBufWarn = 0;
   if(TimeCurrent() - lastBufWarn > 300)
   {
      lastBufWarn = TimeCurrent();
      Print("[RADAR] ATTENZIONE: ", sym, " tutti i buffer = 0 (dato mancante, non GRAY)");
   }
}

//+------------------------------------------------------------------+
// |  DERIVE RADAR TYPE                                                |
//+------------------------------------------------------------------+
int DeriveRadarType(int histState, double rv)
{
   if(histState == HS_GREEN_LIGHT || histState == HS_GREEN_DARK) return RT_LONG;
   if(histState == HS_RED_LIGHT   || histState == HS_RED_DARK)   return RT_SHORT;
   if(rv > 0)  return RT_RISE;
   if(rv < 0)  return RT_FALL;
   return RT_UNKNOWN;
}

//+------------------------------------------------------------------+
// |  GET ADR                                                          |
//+------------------------------------------------------------------+
void GetADR(string sym, double &pipFatti, double &media10gg)
{
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);
   if(point <= 0) { pipFatti = 0; media10gg = 0; return; }

   double pipMult = 1.0;
   if(digits == 3 || digits == 5) pipMult = 10.0;

   double todayHigh = iHigh(sym, PERIOD_D1, 0);
   double todayLow  = iLow(sym, PERIOD_D1, 0);
   if(todayHigh == 0 || todayLow == 0) { pipFatti = 0; media10gg = 0; return; }

   pipFatti = (todayHigh - todayLow) / point / pipMult;

   double sum = 0;
   int countedDays = 0;
   for(int i = 1; i <= 10; i++)
   {
      double h = iHigh(sym, PERIOD_D1, i);
      double l = iLow(sym, PERIOD_D1, i);
      if(h == 0 || l == 0) continue;
      sum += (h - l) / point / pipMult;
      countedDays++;
   }
   media10gg = (countedDays > 0) ? sum / countedDays : 0;
}

