//+------------------------------------------------------------------+
// |  LOG TRADE TO CSV — Storico locale persistente                    |
// |  File: MQL4/Files/PRP_TradeLog.csv                               |
// |  Aggiornato automaticamente ad ogni trade chiuso                  |
//+------------------------------------------------------------------+
void LogTradeToCSV(int ticket)
{
   //--- Evita duplicati: controlla se gia' loggato
   for(int c = 0; c < g_fbCount; c++)
   {
      if(g_fbTicket[c] == ticket && g_fbLogged[c]) return;
   }

   if(!OrderSelect(ticket, SELECT_BY_TICKET)) return;

   string csvFile = "PRP_TradeLog.csv";

   //--- Dati ordine
   int    ot        = OrderType();
   string sym       = OrderSymbol();
   double lots      = OrderLots();
   double entryPrc  = OrderOpenPrice();
   double exitPrc   = OrderClosePrice();
   double sl        = OrderStopLoss();
   double tp        = OrderTakeProfit();
   double profit    = OrderProfit() + OrderSwap() + OrderCommission();
   string openTime  = TimeToString(OrderOpenTime(), TIME_DATE | TIME_MINUTES | TIME_SECONDS);
   string closeTime = TimeToString(OrderCloseTime(), TIME_DATE | TIME_MINUTES | TIME_SECONDS);
   string comment   = OrderComment();

   bool isLong = (ot == OP_BUY);
   string direction = isLong ? "BUY" : "SELL";

   //--- Calcola pips
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);
   double pipMult = (digits == 3 || digits == 5) ? 10.0 : 1.0;
   double pips = 0;
   if(point > 0)
   {
      if(isLong) pips = (exitPrc - entryPrc) / point / pipMult;
      else       pips = (entryPrc - exitPrc) / point / pipMult;
   }

   //--- Estrai modulo dal commento (es: "PRP_STD_2026.06.06" -> "STD")
   string module = "UNK";
   int modPos = StringFind(comment, "PRP_");
   if(modPos >= 0)
   {
      string sub = StringSubstr(comment, modPos + 4);
      int usPos = StringFind(sub, "_");
      if(usPos > 0)
         module = StringSubstr(sub, 0, usPos);
      else
         module = sub;
   }

   //--- Cerca dati AI nei feedback track
   int    aiConf   = 0;
   string aiSignal = "";
   double rv       = 0;
   double adx      = 0;
   double adrPct   = 0;
   string hist     = "";

   for(int s = 0; s < g_fbCount; s++)
   {
      if(g_fbTicket[s] == ticket)
      {
         aiConf   = g_fbAIConf[s];
         aiSignal = g_fbAISignal[s];
         rv       = g_fbRV[s];
         adx      = g_fbADX[s];
         adrPct   = g_fbADRPct[s];
         hist     = g_fbHist[s];
         break;
      }
   }

   bool won = (profit > 0);

   //--- Scrivi su CSV
   int handle = FileOpen(csvFile, FILE_CSV | FILE_READ | FILE_WRITE, ';');
   if(handle == INVALID_HANDLE)
   {
      Print("[TRADELOG] Errore apertura file: ", csvFile);
      return;
   }

   //--- Controlla se il file e' vuoto (serve header)
   bool needHeader = true;
   if(FileSize(handle) > 10)
   {
      FileSeek(handle, 0, SEEK_SET);
      string firstLine = FileReadString(handle);
      if(StringFind(firstLine, "Ticket") >= 0)
         needHeader = false;
   }

   //--- Vai alla fine
   FileSeek(handle, 0, SEEK_END);

   if(needHeader)
   {
      FileWrite(handle,
         "Ticket", "Symbol", "Direction", "Module",
         "Lots", "EntryPrice", "ExitPrice", "SL", "TP",
         "Profit", "Pips", "Won",
         "AI_Conf", "AI_Signal",
         "RV", "ADX", "ADR%", "Hist",
         "OpenTime", "CloseTime", "Comment");
   }

   FileWrite(handle,
      IntegerToString(ticket),
      sym,
      direction,
      module,
      DoubleToString(lots, 2),
      DoubleToString(entryPrc, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(exitPrc, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(sl, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(tp, (int)MarketInfo(sym, MODE_DIGITS)),
      DoubleToString(profit, 2),
      DoubleToString(pips, 1),
      won ? "true" : "false",
      IntegerToString(aiConf),
      aiSignal,
      DoubleToString(rv, 2),
      DoubleToString(adx, 1),
      DoubleToString(adrPct, 1),
      hist,
      openTime,
      closeTime,
      comment);

   FileClose(handle);

   //--- Segna come loggato per evitare duplicati
   for(int c = 0; c < g_fbCount; c++)
   {
      if(g_fbTicket[c] == ticket) { g_fbLogged[c] = true; break; }
   }

   Print("[TRADELOG] #", ticket, " ", sym, " ", direction,
         " | ", (won ? "WIN" : "LOSS"), " ", DoubleToString(profit, 2), " EUR",
         " | ", DoubleToString(pips, 1), " pips",
         " | AI:", aiConf, "%",
         " | RV:", DoubleToString(rv, 1),
         " | loggato su ", csvFile);
}

//+------------------------------------------------------------------+
// |  TICKET GIA' NEL CSV? — anti-duplicato robusto per il backup     |
//+------------------------------------------------------------------+
bool TradeAlreadyInLog(int ticket)
{
   int handle = FileOpen("PRP_TradeLog.csv", FILE_CSV | FILE_READ | FILE_ANSI, ';');
   if(handle == INVALID_HANDLE) return false;   // file non esiste -> non c'e'

   string target = IntegerToString(ticket);
   bool found = false;
   bool firstCol = true;

   while(!FileIsEnding(handle))
   {
      string cell = FileReadString(handle);
      //--- La prima colonna di ogni riga e' il Ticket
      if(firstCol)
      {
         if(cell == target) { found = true; break; }
         firstCol = false;
      }
      if(FileIsLineEnding(handle))
         firstCol = true;   // prossima cella sara' inizio riga
   }

   FileClose(handle);
   return found;
}

//+------------------------------------------------------------------+
// |  BACKUP ORARIO PRP_TradeLog — recupera trade chiusi mancanti      |
// |  Riscansiona lo storico di OGGI e logga i trade non presenti      |
// |  (es. chiusi via TP/SL broker mentre l'EA era offline)            |
//+------------------------------------------------------------------+
void BackupTradeLog()
{
   datetime dayStart = StringToTime(TimeToString(TimeCurrent(), TIME_DATE));
   int recovered = 0;
   int scanned = 0;

   for(int i = OrdersHistoryTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;            // solo BUY/SELL
      if(OrderCloseTime() < dayStart) break;          // solo oggi (storico ordinato)

      scanned++;
      int ticket = OrderTicket();

      //--- Salta se gia' presente nel file (anti-duplicato robusto)
      if(TradeAlreadyInLog(ticket)) continue;

      LogTradeToCSV(ticket);
      recovered++;
   }

   if(recovered > 0)
      Print("[TRADELOG-BACKUP] Recuperati ", recovered, " trade mancanti su ", scanned, " scansionati");
   else
      Print("[TRADELOG-BACKUP] OK, nessun trade mancante (", scanned, " verificati)");
}

