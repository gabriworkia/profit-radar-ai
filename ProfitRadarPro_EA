void CloseAllOrders()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() <= OP_SELL) CloseOrder(OrderTicket());
      else { if(!OrderDelete(OrderTicket())) Print("[CLOSE] OrderDelete fallito: err ", GetLastError()); }
   }
}

bool CloseOrder(int ticket)
{
   if(!OrderSelect(ticket, SELECT_BY_TICKET)) return false;

   string sym    = OrderSymbol();
   int    digits = (int)MarketInfo(sym, MODE_DIGITS);

   if(OrderType() == OP_BUY)
   {
      double price = NormalizeDouble(MarketInfo(sym, MODE_BID), digits);
      if(OrderClose(ticket, OrderLots(), price, InpMaxSlippage, clrOrange))
      {
         Print("Chiuso BUY #", ticket, " ", sym, " | P&L: ", DoubleToString(OrderProfit(), 2));
         LogTradeToCSV(ticket);
         return true;
      }
   }
   else if(OrderType() == OP_SELL)
   {
      double price = NormalizeDouble(MarketInfo(sym, MODE_ASK), digits);
      if(OrderClose(ticket, OrderLots(), price, InpMaxSlippage, clrOrange))
      {
         Print("Chiuso SELL #", ticket, " ", sym, " | P&L: ", DoubleToString(OrderProfit(), 2));
         LogTradeToCSV(ticket);
         return true;
      }
   }

   Print("Chiusura fallita #", ticket, " | Err: ", GetLastError());
   return false;
}

