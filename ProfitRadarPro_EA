// |  FEEDBACK GIA' INVIATO? — tracciamento persistente su file        |
// |  File: PRP_FeedbackSent.csv (solo lista ticket gia' inviati)      |
//+------------------------------------------------------------------+
bool FeedbackAlreadySent(int ticket)
{
   int h = FileOpen("PRP_FeedbackSent.csv", FILE_CSV | FILE_READ | FILE_ANSI, ';');
   if(h == INVALID_HANDLE) return false;
   string target = IntegerToString(ticket);
   bool found = false;
   while(!FileIsEnding(h))
   {
      string cell = FileReadString(h);
      if(cell == target) { found = true; break; }
   }
   FileClose(h);
   return found;
}

void MarkFeedbackSent(int ticket)
{
   int h = FileOpen("PRP_FeedbackSent.csv", FILE_CSV | FILE_READ | FILE_WRITE, ';');
   if(h == INVALID_HANDLE) return;
   FileSeek(h, 0, SEEK_END);
   FileWrite(h, IntegerToString(ticket));
   FileClose(h);
}

//+------------------------------------------------------------------+
// |  RECUPERA FEEDBACK MANCANTI — invia esiti dei trade chiusi che    |
// |  non hanno ancora mandato feedback (es. aperti prima di un riavvio)|
// |  Le feature di mercato non sono recuperabili -> feedback con esito |
//+------------------------------------------------------------------+
void RecoverMissedFeedback()
{
   if(!InpUseAI && !InpSendFeedback) return;

   datetime dayStart = StringToTime(TimeToString(TimeCurrent(), TIME_DATE));
   string feedbackUrl = InpAIUrl;
   StringReplace(feedbackUrl, "/predict", "/feedback");
   int recovered = 0;

   for(int i = OrdersHistoryTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;
      if(OrderCloseTime() < dayStart) break;   // solo oggi

      int ticket = OrderTicket();

      //--- Gia' inviato? (memoria O file di tracciamento)
      bool inMem = false;
      for(int s = 0; s < g_fbCount; s++)
         if(g_fbTicket[s] == ticket && g_fbSent[s]) { inMem = true; break; }
      if(inMem) continue;
      if(FeedbackAlreadySent(ticket)) continue;

      //--- Dati del trade chiuso
      double profit = OrderProfit() + OrderSwap() + OrderCommission();
      double entryPrc = OrderOpenPrice();
      double exitPrc  = OrderClosePrice();
      bool won = (profit > 0);
      string sym = OrderSymbol();
      string comment = OrderComment();

      //--- Modulo dal commento (PRP_STD_... / PRP_REV_... / PRP_BRK_...)
      string module = "UNK";
      int modPos = StringFind(comment, "PRP_");
      if(modPos >= 0)
      {
         string sub = StringSubstr(comment, modPos + 4);
         int usPos = StringFind(sub, "_");
         module = (usPos > 0) ? StringSubstr(sub, 0, usPos) : sub;
      }

      //--- Pips
      int digits = (int)MarketInfo(sym, MODE_DIGITS);
      double point = MarketInfo(sym, MODE_POINT);
      double pipMult = (digits == 3 || digits == 5) ? 10.0 : 1.0;
      double pips = 0;
      if(point > 0)
         pips = (OrderType() == OP_BUY) ? (exitPrc - entryPrc)/point/pipMult
                                        : (entryPrc - exitPrc)/point/pipMult;

      //--- Feedback minimale (esito + modulo). Feature non recuperabili -> "".
      string json = BuildFeedbackJSON(ticket, NormSym(sym),
                       (OrderType() == OP_BUY ? "BUY" : "SELL"), module,
                       profit, pips, won, 0, 0, 0, "", 0, "", entryPrc, exitPrc,
                       0, 0, 0, false, "");

      string response = AICallFeedback(json, feedbackUrl);
      if(response != "")
      {
         MarkFeedbackSent(ticket);
         recovered++;
         Print("[FEEDBACK-RECOVER] #", ticket, " ", sym, " ", module,
               " | ", (won ? "WIN" : "LOSS"), " ", DoubleToString(profit, 2), " EUR | recuperato");
      }
   }

   if(recovered > 0)
      Print("[FEEDBACK-RECOVER] Totale recuperati: ", recovered);
}

//+------------------------------------------------------------------+
// |  A/B TEST GPT CALL — Chiama GPT senza bloccare il trade         |
// |  Ogni candidato trade viene inviato anche a GPT-4o-mini          |
// |  Il risultato viene loggato ma NON influisce sulla decisione      |
// |  Dopo 100 trade confronteremo chi aveva più ragione              |
//+------------------------------------------------------------------+
void ABTestGPTCall(int idx, string tag, string lgbmSignal, int lgbmConf)
{
   //--- Costruisci URL /predict_gpt
   string gptUrl = InpAIUrl;
   StringReplace(gptUrl, "/predict", "/predict_gpt");

   //--- Riutilizza lo stesso JSON della richiesta LightGBM + aggiungi ai_confidence
   string json = BuildAIRequestJSON(idx, tag);
   // Rimuovi l'ultima } e aggiungi il campo
   json = StringSubstr(json, 0, StringLen(json) - 1);
   json += ",\"ai_confidence\":" + IntegerToString(lgbmConf);
   json += "}";

   //--- Invia (silenzioso, non blocca)
   string headers = "Content-Type: application/json\r\n";
   char postData[];
   int len = StringLen(json);
   ArrayResize(postData, len);
   for(int i = 0; i < len; i++)
      postData[i] = (char)StringGetCharacter(json, i);

   char result[];
   string resultHeaders;

   int res = WebRequest("POST", gptUrl, headers, 8000, postData, result, resultHeaders);

   if(res == -1) return; // Silenzioso

   //--- Parse risposta GPT
   string respStr = "";
   int resultLen = ArraySize(result);
   for(int i = 0; i < resultLen; i++)
      respStr += CharToString(result[i]);

   g_abGptCalls++;

   //--- Estrai segnale GPT
   string gptSignal = "";
   int sigPos = StringFind(respStr, "\"signal\"");
   if(sigPos >= 0)
   {
      int colonP = StringFind(respStr, ":", sigPos);
      if(colonP >= 0)
      {
         int startQ = StringFind(respStr, "\"", colonP);
         int endQ = StringFind(respStr, "\"", startQ + 1);
         if(startQ >= 0 && endQ > startQ)
            gptSignal = StringSubstr(respStr, startQ + 1, endQ - startQ - 1);
      }
   }

   //--- Estrai confidenza GPT
   int gptConf = 0;
   int confPos = StringFind(respStr, "\"confidence\"");
   if(confPos >= 0)
   {
      int colonP = StringFind(respStr, ":", confPos);
      if(colonP >= 0)
      {
         string numStr = "";
         for(int c = colonP + 1; c < StringLen(respStr) && c < colonP + 10; c++)
         {
            string ch = StringSubstr(respStr, c, 1);
            if((ch >= "0" && ch <= "9") || ch == ".") numStr += ch;
            else if(StringLen(numStr) > 0) break;
         }
         if(StringLen(numStr) > 0) gptConf = (int)StringToDouble(numStr);
      }
   }

   //--- Confronta
   bool agree = (gptSignal == lgbmSignal);
   if(agree) g_abGptAgree++;
   else g_abGptDisagree++;

   Print("[AB TEST] #", g_abGptCalls, " ", NormSym(g_symbol[idx]),
         " | LightGBM: ", lgbmSignal, " ", lgbmConf, "%",
         " | GPT: ", gptSignal, " ", gptConf, "%",
         " | ", (agree ? "CONCORDI" : "DISCORDI"));
}

