int OnInit()
{
   g_consecutiveLosses = 0;
   g_dailyStartBalance = AccountBalance();
   g_currentDay        = TimeDay(TimeCurrent());
   g_dailyStopped      = false;
   g_dataCount         = 0;
   g_lastBarTime       = 0;
   g_histogramTracked  = false;
   g_reversalTracked   = false;
   g_testTradeDone     = false;
   g_validBars         = 0;
   g_dataValidated     = false;
   g_nonGrayCount      = 0;
   g_autoFailCount     = 0;
   g_usingFallback     = false;
   g_activeDataSource  = "";

   ArrayInitialize(g_prevHistogram, HS_UNKNOWN);
   ArrayInitialize(g_lightStreak, 0);
   ArrayInitialize(g_prevWasGray, false);
   ArrayInitialize(g_histConsecColor, 0);
   ArrayInitialize(g_histBarsSinceGray, 0);
   ArrayInitialize(g_histCycleCount, 0);
   ArrayInitialize(g_histCrossedZero, false);
   ArrayInitialize(g_histBarSlope, 0);
   ArrayInitialize(g_histPullbackDepth, 0);
   ArrayInitialize(g_histSeqEncoded, 0);
   ArrayInitialize(g_histBarRatio, 0);

   ArrayInitialize(g_prevRV, 0);
   ArrayInitialize(g_prev2RV, 0);
   ArrayInitialize(g_swingHigh, 0);
   ArrayInitialize(g_swingLow, 0);
   ArrayInitialize(g_histFlipBar, 999);

   ArrayInitialize(g_normMomentum, 0);
   ArrayInitialize(g_momentumSignal, 0);
   ArrayInitialize(g_momentumAccel, 0);
   ArrayInitialize(g_momentumDist, 0);
   ArrayInitialize(g_isCompressing, false);

   ArrayInitialize(g_fbTicket, 0);
   ArrayInitialize(g_fbRV, 0);
   ArrayInitialize(g_fbADX, 0);
   ArrayInitialize(g_fbADRPct, 0);
   ArrayInitialize(g_fbAIConf, 0);
   ArrayInitialize(g_fbEntryPrice, 0);
   ArrayInitialize(g_fbSent, false);
   ArrayInitialize(g_fbLogged, false);
   ArrayInitialize(g_fbNormMom, 0);
   ArrayInitialize(g_fbMomAccel, 0);
   ArrayInitialize(g_fbMomDist, 0);
   ArrayInitialize(g_fbCompress, false);
   g_fbCount = 0;
   g_fbSentCount = 0;

   g_warmupCounter    = 0;
   g_warmupOK         = false;
   g_warmupLastTime   = 0;
   g_warmupTotalOK    = 0;
   g_warmupTotalFail  = 0;
   g_aiMissedTrades   = 0;
   g_aiMissedLastSymbol = "";
   g_aiMissedLastModule = 0;

   //--- Primo warm-up immediato (non aspettare 10 minuti)
   if(InpUseAI)
   {
      Print("[WARMUP] Ping iniziale...");
      AIWarmupPing();
      if(!g_warmupOK)
      {
         // Server probabilmente in cold start — riprova tra 45 secondi
         g_warmupCounter = g_warmupInterval - 45;
         Print("[WARMUP] Server non risponde (cold start?). Riprovo tra 45 sec...");
      }
      else
      {
         // Warm-up OK → prova subito il sync con dashboard
         Print("[INIT] Warm-up OK, sync immediato con dashboard...");
         SyncWithServer();
         if(g_remoteConfigLoaded)
            Print("[INIT] ✅ SYNC OK! Dashboard dovrebbe essere ONLINE");
         else
            Print("[INIT] ❌ SYNC fallito - controlla URL nella whitelist: https://profit-radar-ai.onrender.com/ea_status");
      }
   }

   ApplyAggressiveness();

   EventSetTimer(1);

   if(InpShowExportBtn) CreateExportButton();

   Print("==========================================");
   Print("  PROFIT RADAR PRO EA v", VERSION_STR, " - Inizializzato");
   Print("  Aggressivita': ", AggressivenessStr());
   Print("  Max per cross: ", InpMaxPerPair, " | Max totali: ", InpMaxConcurrent);

   if(InpDataMode == 0 || InpDataMode == 2)
   {
      g_activeDataSource = "CSV";
      Print("  Data source: CSV FILE (forzato)");
   }
   else
   {
      g_activeDataSource = "AUTO";
      Print("  Data source: AUTO (indicatore)");
      Print("  Indicatore: ", InpRadarIndicator);
      if(InpAutoFallback)
         Print("  Fallback: se AUTO fallisce ", InpFallbackAfter, " volte, passa a CSV");
   }

   Print("  Lotto fisso: ", DoubleToString(InpFixedLots, 2));
   Print("  ----------------------------------------");
   Print("  PERCORSO CSV: MQL4/Files/", InpCSVFile);

   int testHandle = FileOpen(InpCSVFile, FILE_CSV | FILE_READ | FILE_ANSI, ';');
   if(testHandle != INVALID_HANDLE)
   {
      Print("  >>> CSV TROVATO! MQL4/Files/", InpCSVFile, " <<<");
      FileClose(testHandle);
   }
   else
   {
      Print("  >>> CSV NON TROVATO! MQL4/Files/", InpCSVFile, " <<<");
   }

   Print("  Venerdi: NO nuovi trade dalle 15:00 Italia");

   if(InpSundayStartH > 0 && InpSundayStartH < 24)
      Print("  Domenica: trading attivo dalle ", PadZero(InpSundayStartH), ":00 Italia");
   else
      Print("  Domenica: trading DISATTIVATO");

   //--- AI info
   if(InpUseAI)
   {
      Print("  ----------------------------------------");
      Print("  AI MODULE: ATTIVO");
      Print("  Server: ", InpAIUrl);
      Print("  Confidenza minima: ", InpAIMinConf, "%");
      Print("  >>> OBBLIGATORIO: nessun trade senza conferma AI <<<");
      Print("  Warm-up: ping /health ogni ", g_warmupInterval / 60, " minuti");
      Print("  IMPORTANTE: Aggiungi URL in MT4:");
      Print("  Strumenti > Opzioni > Expert Advisors > Allow WebRequest");
      Print("  1. https://profit-radar-ai.onrender.com/predict");
      Print("  2. https://profit-radar-ai.onrender.com/health");
      Print("  3. https://profit-radar-ai.onrender.com/ea_status");
      Print("  4. https://profit-radar-ai.onrender.com/feedback");
      Print("  5. https://profit-radar-ai.onrender.com/predict_gpt");
   }
   else
   {
      Print("  AI MODULE: disabilitato (InpUseAI=false)");
   }

   Print("==========================================");

   return(INIT_SUCCEEDED);
}

