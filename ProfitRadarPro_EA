//+------------------------------------------------------------------+
// |  MAIN TICK HANDLER                                                |
//+------------------------------------------------------------------+
void OnTick()
{
   ManageOpenTrades();
   CheckEarlyExit();      // real-time: chiude subito se l'istogramma si gira contro
   CheckTestTrade();
   CheckForceClose();

   //--- Feedback automatico trade chiusi al server (per addestrare il modello).
   //    Inviato anche con AI disattivata, cosi' si raccolgono dati per il training.
   if(InpUseAI || InpSendFeedback) CheckClosedTradesFeedback();

   datetime currentBarTime = iTime(Symbol(), PERIOD_M15, 0);
   if(currentBarTime == g_lastBarTime) return;
   g_lastBarTime = currentBarTime;

   ResetDailyStats();
   UpdateTradeResults();

   //--- Sync stats con dashboard + leggi config remota (SEMPRE, prima dei return)
   //    Gira anche con AI off: tiene la dashboard online e legge la config remota.
   if(InpUseAI || InpSendFeedback) SyncWithServer();

   //--- Il Reversal puo' girare anche se il Daily Stop ferma Standard/Breakout.
   //    Si ferma comunque per venerdi/weekend (gestito da GetTradeSlot in ProcessReversal).
   bool stdAllowed = CanTrade();
   bool revAllowed = (InpReversalOn || InpReversalObserve);

   //--- Se NE' lo standard NE' il reversal possono operare, esci subito
   if(!stdAllowed && !revAllowed) return;

   //=== AUTO-EXPORT ===
   if(InpAutoExport && !g_isExporting && !InpStrategyTest)
   {
      g_isExporting = true;
      ExportDataFromEA();
      g_isExporting = false;
      if(g_dataValidated)
      {
         UpdateHistogramTracking();
         ExtractHistogramFeatures_all();
         UpdateReversalTracking();
         CalculateMomentumMetrics();
         UpdateTradeResults();
         if(stdAllowed) ProcessStandard();
         if(stdAllowed && InpBreakoutOn) ProcessBreakout();
         if(revAllowed) ProcessReversal();
         return;
      }
   }

   bool dataOK = false;

   if(InpDataMode == 0 || InpDataMode == 2)
   {
      dataOK = ReadCSV();
   }
   else if(InpDataMode == 1)
   {
      if(g_usingFallback)
      {
         dataOK = ReadCSV();
      }
      else
      {
         CollectMarketData();
         dataOK = (g_dataCount > 0);

         if(dataOK)
         {
            int liveCross = 0;
            for(int v = 0; v < g_dataCount; v++)
            {
               if(g_histogramState[v] != HS_GRAY) liveCross++;
               else if(MathAbs(g_radarValue[v]) > 0.01) liveCross++;
            }

            if(liveCross < 3)
            {
               g_autoFailCount++;
               if(InpAutoFallback && g_autoFailCount >= InpFallbackAfter)
               {
                  g_usingFallback = true;
                  g_activeDataSource = "FALLBACK";
                  dataOK = ReadCSV();
               }
               else
               {
                  dataOK = false;
               }
            }
            else
            {
               g_autoFailCount = 0;
            }
         }
      }
   }
   if(!dataOK) return;

   UpdateHistogramTracking();
   ExtractHistogramFeatures_all();
   UpdateReversalTracking();
   CalculateMomentumMetrics();
   UpdateTradeResults();

   if(!ValidateMarketData())
   {
      ShowDashboard();
      return;
   }

   if(stdAllowed) ProcessStandard();
   if(stdAllowed && InpBreakoutOn) ProcessBreakout();
   if(revAllowed) ProcessReversal();
}

