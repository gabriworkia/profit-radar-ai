//--- Sync timer: manda stats ogni 5 minuti (non solo sulle candele M15)
int      g_syncCounter      = 0;
int      g_syncInterval     = 300;  // 5 minuti = 300 secondi
datetime g_lastSyncTime     = 0;

int      g_tradeLogCounter  = 0;
int      g_tradeLogInterval = 3600; // 1 ora = backup orario PRP_TradeLog

void OnTimer()
{
   ShowDashboard();

   //--- Warm-up + sync: girano anche con AI off (per tenere viva la dashboard
   //    e mantenere sveglio Render). Servono finche' raccogliamo dati/feedback.
   if(InpUseAI || InpSendFeedback)
   {
      g_warmupCounter++;
      if(g_warmupCounter >= g_warmupInterval)
      {
         g_warmupCounter = 0;
         AIWarmupPing();
      }

      //--- Sync stats ogni 5 minuti (non aspettare candele M15)
      g_syncCounter++;
      if(g_syncCounter >= g_syncInterval)
      {
         g_syncCounter = 0;
         SyncWithServer();
         RecoverMissedFeedback();   // recupera feedback dei trade chiusi non inviati
      }
   }

   //--- Backup orario PRP_TradeLog: riscansiona lo storico e logga i trade
   //    mancanti (es. chiusi via TP/SL broker mentre l'EA era offline).
   //    Funziona anche con AI disattivata.
   g_tradeLogCounter++;
   if(g_tradeLogCounter >= g_tradeLogInterval)
   {
      g_tradeLogCounter = 0;
      BackupTradeLog();
   }
}

