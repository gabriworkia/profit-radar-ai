   //--- Feedback automatico trade chiusi al server AI
   if(InpUseAI) CheckClosedTradesFeedback();

   datetime currentBarTime = iTime(Symbol(), PERIOD_M15, 0);
   if(currentBarTime == g_lastBarTime) return;
   g_lastBarTime = currentBarTime;

   ResetDailyStats();
   UpdateTradeResults();

   //--- Sync stats con dashboard + leggi config remota (SEMPRE, prima dei return)
   if(InpUseAI) SyncWithServer();

   if(!CanTrade()) return;

   //=== AUTO-EXPORT ===
   if(InpAutoExport && !g_isExporting && !InpStrategyTest)
   {
      g_isExporting = true;
      ExportDataFromEA();
      g_isExporting = false;
      if(g_dataValidated)
      {
         UpdateHistogramTracking();
         ExtractHistogramFeatures_all();
         UpdateReversalTracking();
         CalculateMomentumMetrics();
         CheckEarlyExit();
         UpdateTradeResults();
         ProcessStandard();
         if(InpBreakoutOn) ProcessBreakout();
         if(InpReversalOn)  ProcessReversal();
         return;
      }
   }

   bool dataOK = false;

   if(InpDataMode == 0 || InpDataMode == 2)
   {
      dataOK = ReadCSV();
   }
   else if(InpDataMode == 1)
   {
      if(g_usingFallback)
      {
         dataOK = ReadCSV();
      }
      else
      {
         CollectMarketData();
         dataOK = (g_dataCount > 0);

         if(dataOK)
         {
            int liveCross = 0;
            for(int v = 0; v < g_dataCount; v++)
            {
               if(g_histogramState[v] != HS_GRAY) liveCross++;
               else if(MathAbs(g_radarValue[v]) > 0.01) liveCross++;
            }

            if(liveCross < 3)
            {
               g_autoFailCount++;
               if(InpAutoFallback && g_autoFailCount >= InpFallbackAfter)
               {
                  g_usingFallback = true;
                  g_activeDataSource = "FALLBACK";
                  dataOK = ReadCSV();
               }
               else
               {
                  dataOK = false;
               }
            }
            else
            {
               g_autoFailCount = 0;
            }
         }
      }
   }
   if(!dataOK) return;

   UpdateHistogramTracking();
   ExtractHistogramFeatures_all();
   UpdateReversalTracking();
   CalculateMomentumMetrics();
   CheckEarlyExit();
   UpdateTradeResults();

   if(!ValidateMarketData())
   {
      ShowDashboard();
      return;
   }

   ProcessStandard();
   if(InpBreakoutOn) ProcessBreakout();
   if(InpReversalOn) ProcessReversal();
}

