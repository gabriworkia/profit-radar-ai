//--- Costruisce JSON con dati del cross candidato + contesto mercato
string BuildAIRequestJSON(int idx, string tag)
{
   //--- Dati del cross candidato
   string json = "{";

   //--- Simbolo e direzione proposta
   json += "\"symbol\":\"" + NormSym(g_symbol[idx]) + "\",";
   json += "\"module\":\"" + tag + "\",";
   json += "\"direction\":\"" + (g_radarType[idx] == RT_LONG || g_histogramState[idx] == HS_GREEN_LIGHT ? "BUY" : "SELL") + "\",";

   //--- Features del cross (9 valori)
   json += "\"rv\":" + DoubleToString(g_radarValue[idx], 2) + ",";
   json += "\"adx\":" + DoubleToString(g_adx[idx], 1) + ",";
   json += "\"adr_pct\":" + DoubleToString(g_adrPercent[idx], 1) + ",";
   json += "\"adr_pip\":" + DoubleToString(g_pipFatti[idx], 0) + ",";
   json += "\"adr_media\":" + DoubleToString(g_media10gg[idx], 0) + ",";
   json += "\"ema_pos\":" + IntegerToString(g_emaPosition[idx]) + ",";
   json += "\"hist\":\"" + HistStateStr(g_histogramState[idx]) + "\",";
   json += "\"close\":" + DoubleToString(g_close[idx], 5) + ",";
   json += "\"ema_gap_pct\":" + DoubleToString(
      (g_close[idx] > 0 ? MathAbs(g_ema21[idx] - g_ema200[idx]) / g_close[idx] * 100.0 : 0), 3) + ",";

   //--- Tracking data
   json += "\"rv_prev\":" + DoubleToString(g_prevRV[idx], 2) + ",";
   json += "\"rv_prev2\":" + DoubleToString(g_prev2RV[idx], 2) + ",";
   json += "\"light_streak\":" + IntegerToString(g_lightStreak[idx]) + ",";
   json += "\"was_gray\":" + (g_prevWasGray[idx] ? "true" : "false") + ",";
   json += "\"hist_flip_bar\":" + IntegerToString(g_histFlipBar[idx]) + ",";

   //--- Momentum metrics
   json += "\"nm\":" + DoubleToString(g_normMomentum[idx], 4) + ",";
   json += "\"nm_signal\":" + DoubleToString(g_momentumSignal[idx], 4) + ",";
   json += "\"nm_accel\":" + DoubleToString(g_momentumAccel[idx], 4) + ",";
   json += "\"nm_dist\":" + DoubleToString(g_momentumDist[idx], 4) + ",";
   json += "\"is_compressing\":" + (g_isCompressing[idx] ? "true" : "false") + ",";

   //--- Histogram sequence features (ultime 8 candele)
   json += "\"hist_consec_color\":" + IntegerToString(g_histConsecColor[idx]) + ",";
   json += "\"hist_bars_since_gray\":" + IntegerToString(g_histBarsSinceGray[idx]) + ",";
   json += "\"hist_cycle_count\":" + IntegerToString(g_histCycleCount[idx]) + ",";
   json += "\"hist_crossed_zero\":" + (g_histCrossedZero[idx] ? "1" : "0") + ",";
   json += "\"hist_bar_slope\":" + DoubleToString(g_histBarSlope[idx], 6) + ",";
   json += "\"hist_pullback_depth\":" + DoubleToString(g_histPullbackDepth[idx], 1) + ",";
   json += "\"hist_seq_encoded\":" + IntegerToString(g_histSeqEncoded[idx]) + ",";
   json += "\"hist_bar_ratio\":" + DoubleToString(g_histBarRatio[idx], 3) + ",";
   json += "\"hist_color_now\":" + DoubleToString(g_histColorNow[idx], 0) + ",";
   json += "\"hist_color_slope\":" + DoubleToString(g_histColorSlope[idx], 4) + ",";
   json += "\"hist_color_curve\":" + DoubleToString(g_histColorCurve[idx], 4) + ",";
   json += "\"hist_color_r2\":" + DoubleToString(g_histColorR2[idx], 3) + ",";
   json += "\"hist_color_centroid\":" + DoubleToString(g_histColorCentroid[idx], 3) + ",";
   json += "\"hist_color_sum\":" + IntegerToString(g_histColorSum[idx]) + ",";

   //--- Contesto mercato (riassunto 28 cross)
   int nonGray = 0, greenCount = 0, redCount = 0;
   double sumAbsRV = 0, avgRV = 0;
   int extremeRV = 0; // cross con |RV| > 60

   for(int i = 0; i < g_dataCount; i++)
   {
      if(g_histogramState[i] != HS_GRAY) nonGray++;
      if(g_histogramState[i] == HS_GREEN_LIGHT || g_histogramState[i] == HS_GREEN_DARK) greenCount++;
      if(g_histogramState[i] == HS_RED_LIGHT   || g_histogramState[i] == HS_RED_DARK)   redCount++;
      sumAbsRV += MathAbs(g_radarValue[i]);
      if(MathAbs(g_radarValue[i]) > 60) extremeRV++;
   }

   if(g_dataCount > 0) avgRV = sumAbsRV / g_dataCount;

   json += "\"context\":{";
   json += "\"total\":" + IntegerToString(g_dataCount) + ",";
   json += "\"non_gray\":" + IntegerToString(nonGray) + ",";
   json += "\"green\":" + IntegerToString(greenCount) + ",";
   json += "\"red\":" + IntegerToString(redCount) + ",";
   json += "\"avg_abs_rv\":" + DoubleToString(avgRV, 1) + ",";
   json += "\"extreme_rv\":" + IntegerToString(extremeRV);
   json += "}";

   json += "}";

   return json;
}

//--- Chiama il server AI e ritorna confidenza (0-100) o -1 se errore
int GetAIConfirmation(int idx, string tag)
{
   g_aiCalls++;

   //--- Costruisci richiesta
   string json = BuildAIRequestJSON(idx, tag);

   if(InpAILog)
      Print("[AI] Request: ", StringSubstr(json, 0, 200), "...");

   //--- Chiama server
   string response = AICallServer(json);

   if(response == "")
   {
      g_aiErrors++;
      g_aiLastError = "Nessuna risposta dal server";
      Print("[AI] ERRORE: ", g_aiLastError);
      return -1;
   }

   if(InpAILog)
      Print("[AI] Response: ", StringSubstr(response, 0, 150));

   //--- Parse risposta
   int confidence = AIParseConfidence(response);
   string signal  = AIParseSignal(response);

   g_aiLastConf   = confidence;
   g_aiLastSignal = signal;

   //--- A/B Test: chiama GPT in parallelo (non blocca il trade)
   if(g_abGptEnabled)
   {
      ABTestGPTCall(idx, tag, signal, confidence);
   }

   //--- Verifica che il segnale sia coerente con la direzione proposta
   bool isLong = (g_radarType[idx] == RT_LONG || g_histogramState[idx] == HS_GREEN_LIGHT);
   if(signal != "")
   {
      if(isLong && signal == "SELL")
      {
         Print("[AI] DISCORDANTE: proposta BUY ma AI dice SELL (conf: ", confidence, "%)");
         return 0; // Zero = non confermato
      }
      if(!isLong && signal == "BUY")
      {
         Print("[AI] DISCORDANTE: proposta SELL ma AI dice BUY (conf: ", confidence, "%)");
         return 0;
      }
   }

   return confidence;
}

//--- Esegue WebRequest verso il server AI
string AICallServer(string json)
{
   string headers = "Content-Type: application/json\r\n";
   string response = "";
   char post[];
   char result[];
   string resultHeaders;

   //--- Converti string a byte array
   int len = StringLen(json);
   ArrayResize(post, len);
   for(int i = 0; i < len; i++)
      post[i] = (char)StringGetCharacter(json, i);

   //--- WebRequest
   int res = WebRequest("POST", InpAIUrl, headers, InpAITimeout, post, result, resultHeaders);

   if(res == -1)
   {
      int err = GetLastError();
      g_aiLastError = "WebRequest err=" + IntegerToString(err) + " " + ErrDesc(err);
      Print("[AI] WebRequest fallito: ", g_aiLastError);
      Print("[AI] Verifica: Strumenti > Opzioni > Expert Advisors > Allow WebRequest");
      Print("[AI] Aggiungi URL: ", InpAIUrl);
      return "";
   }

   //--- Converti risposta a string
   response = "";
   int resultLen = ArraySize(result);
   for(int i = 0; i < resultLen; i++)
      response += CharToString(result[i]);

   return response;
}

//--- Esegue WebRequest verso il server AI per feedback
string AICallFeedback(string json, string url)
{
   string headers = "Content-Type: application/json\r\n";
   char post[];
   char result[];
   string resultHeaders;

   int len = StringLen(json);
   ArrayResize(post, len);
   for(int i = 0; i < len; i++)
      post[i] = (char)StringGetCharacter(json, i);

   int res = WebRequest("POST", url, headers, InpAITimeout, post, result, resultHeaders);

   if(res == -1)
   {
      int err = GetLastError();
      Print("[FEEDBACK] WebRequest fallito: err=", err, " ", ErrDesc(err));
      return "";
   }

   string response = "";
   int resultLen = ArraySize(result);
   for(int i = 0; i < resultLen; i++)
      response += CharToString(result[i]);

   return response;
}

//--- Estrae confidence dalla risposta JSON
//    Cerca: "confidence":78  o  "confidence": 78
int AIParseConfidence(string response)
{
   //--- Cerca "confidence"
   int pos = StringFind(response, "\"confidence\"");
   if(pos < 0) pos = StringFind(response, "\"conf\"");
   if(pos < 0)
   {
      Print("[AI] PARSE: 'confidence' non trovato in risposta");
      return 0;
   }

   //--- Trova il due punti
   int colonPos = StringFind(response, ":", pos);
   if(colonPos < 0) return 0;

   //--- Trova il numero
   int start = colonPos + 1;
   string numStr = "";
   for(int i = start; i < StringLen(response); i++)
   {
      string ch = StringSubstr(response, i, 1);
      if((ch >= "0" && ch <= "9") || ch == ".")
         numStr += ch;
      else if(StringLen(numStr) > 0)
         break;
   }

   if(StringLen(numStr) == 0) return 0;

   return (int)StringToDouble(numStr);
}

//--- Estrae signal dalla risposta JSON
//    Cerca: "signal":"BUY"  o  "signal": "SELL"
string AIParseSignal(string response)
{
   int pos = StringFind(response, "\"signal\"");
   if(pos < 0) return "";

   int colonPos = StringFind(response, ":", pos);
   if(colonPos < 0) return "";

   //--- Trova le virgolette
   int startQ = StringFind(response, "\"", colonPos);
   if(startQ < 0) return "";
   int endQ = StringFind(response, "\"", startQ + 1);
   if(endQ < 0) return "";

   string sig = StringSubstr(response, startQ + 1, endQ - startQ - 1);
   StringToUpper(sig);
   return sig;
}

//+------------------------------------------------------------------+
// |  FEEDBACK TRACKING — Salva dati trade aperto per feedback futuro  |
//+------------------------------------------------------------------+
void StoreTradeForFeedback(int ticket, int idx, string tag, bool isLong)
{
   //--- Trova slot libero (o ricicla il piu' vecchio)
   int slot = -1;
   for(int i = 0; i < g_fbCount; i++)
   {
      if(g_fbTicket[i] == 0 || g_fbSent[i])
      {
         slot = i;
         break;
      }
   }
   if(slot < 0)
   {
      if(g_fbCount < MAX_TRADES_TRACK)
      {
         slot = g_fbCount;
         g_fbCount++;
      }
      else
      {
         // Sovrascrivi il piu' vecchio (primo slot)
         slot = 0;
      }
   }

   g_fbTicket[slot]    = ticket;
   g_fbSymbol[slot]    = NormSym(g_symbol[idx]);
   g_fbDirection[slot] = isLong ? "BUY" : "SELL";
   g_fbModule[slot]    = tag;
   g_fbRV[slot]        = g_radarValue[idx];
   g_fbADX[slot]       = g_adx[idx];
   g_fbADRPct[slot]    = g_adrPercent[idx];
   g_fbHist[slot]      = HistStateStr(g_histogramState[idx]);
   g_fbAIConf[slot]    = g_aiLastConf;
   g_fbAISignal[slot]  = g_aiLastSignal;
   g_fbEntryPrice[slot]= isLong ? MarketInfo(g_symbol[idx], MODE_ASK)
                                : MarketInfo(g_symbol[idx], MODE_BID);
   g_fbSent[slot]      = false;

   //--- Momentum metrics
   g_fbNormMom[slot]   = g_normMomentum[idx];
   g_fbMomAccel[slot]  = g_momentumAccel[idx];
   g_fbMomDist[slot]   = g_momentumDist[idx];
   g_fbCompress[slot]  = g_isCompressing[idx];

   //--- Salva JSON completo delle feature (stesse viste dal modello su /predict)
   g_fbFeaturesJSON[slot] = BuildAIRequestJSON(idx, tag);

   Print("[FEEDBACK] Salvato ticket #", ticket, " ", NormSym(g_symbol[idx]),
         " ", (isLong ? "BUY" : "SELL"), " | slot ", slot, "/", g_fbCount);
}

//+------------------------------------------------------------------+
// |  CHECK CLOSED TRADES — Invia feedback per trade chiusi            |
//+------------------------------------------------------------------+
void CheckClosedTradesFeedback()
{
   if(g_fbCount == 0) return;

   //--- Scansiona lo storico per trovare trade chiusi di recente
   for(int i = OrdersHistoryTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;

      int ticket = OrderTicket();

      //--- Cerca nei nostri slot
      for(int s = 0; s < g_fbCount; s++)
      {
         if(g_fbTicket[s] != ticket) continue;
         if(g_fbSent[s]) continue;

         //--- Trovato! Prepara e invia feedback
         double profit = OrderProfit() + OrderSwap() + OrderCommission();
         double entryPrc = OrderOpenPrice();
         double exitPrc  = OrderClosePrice();
         bool won = (profit > 0);

         //--- Calcola pips
         string sym = OrderSymbol();
         int digits = (int)MarketInfo(sym, MODE_DIGITS);
         double point = MarketInfo(sym, MODE_POINT);
         double pipMult = (digits == 3 || digits == 5) ? 10.0 : 1.0;
         double pips = 0;
         if(point > 0)
         {
            if(OrderType() == OP_BUY)
               pips = (exitPrc - entryPrc) / point / pipMult;
            else
               pips = (entryPrc - exitPrc) / point / pipMult;
         }

         //--- Invia al server: riusa il JSON feature salvato all'apertura
         //    e ci inietta l'esito del trade (profit/pips/won/exit_price)
         string json = BuildFeedbackJSON(
            ticket, g_fbSymbol[s], g_fbDirection[s], g_fbModule[s],
            profit, pips, won,
            g_fbRV[s], g_fbADX[s], g_fbADRPct[s], g_fbHist[s],
            g_fbAIConf[s], g_fbAISignal[s], g_fbEntryPrice[s], exitPrc,
            g_fbNormMom[s], g_fbMomAccel[s], g_fbMomDist[s], g_fbCompress[s],
            g_fbFeaturesJSON[s]);

         //--- Usa endpoint /feedback invece di /predict
         string feedbackUrl = InpAIUrl;
         StringReplace(feedbackUrl, "/predict", "/feedback");
         string response = AICallFeedback(json, feedbackUrl);

         if(response != "")
         {
            g_fbSent[s] = true;
            g_fbSentCount++;
            Print("[FEEDBACK] #", ticket, " ", g_fbSymbol[s],
                  " | ", (won ? "WIN" : "LOSS"), " ", DoubleToString(profit, 2), " EUR",
                  " | ", DoubleToString(pips, 1), " pips",
                  " | Inviato! (totale: ", g_fbSentCount, ")");

            //--- Logga anche su CSV locale (per trade chiusi via TP/SL broker)
            LogTradeToCSV(ticket);
         }
         else
         {
            Print("[FEEDBACK] #", ticket, " Errore invio - riprovo al prossimo tick");
         }
         break;
      }
   }
}

//+------------------------------------------------------------------+
// |  BUILD FEEDBACK JSON                                              |
//+------------------------------------------------------------------+
string BuildFeedbackJSON(int ticket, string sym, string direction, string module,
                         double profit, double pips, bool won,
                         double rv, double adx, double adrPct, string hist,
                         int aiConf, string aiSignal, double entryPrc, double exitPrc,
                         double normMom, double momAccel, double momDist, bool isCompress,
                         string featuresJSON)
{
   //--- Campi esito trade (sempre presenti)
   string outcome = "";
   outcome += "\"ticket\":" + IntegerToString(ticket) + ",";
   outcome += "\"entry_price\":" + DoubleToString(entryPrc, 5) + ",";
   outcome += "\"exit_price\":" + DoubleToString(exitPrc, 5) + ",";
   outcome += "\"profit\":" + DoubleToString(profit, 2) + ",";
   outcome += "\"pips\":" + DoubleToString(pips, 1) + ",";
   outcome += "\"won\":" + (won ? "true" : "false") + ",";
   outcome += "\"ai_confidence\":" + IntegerToString(aiConf) + ",";
   outcome += "\"ai_signal\":\"" + aiSignal + "\"";

   //--- Se abbiamo il JSON completo delle feature salvato all'apertura,
   //    lo riusiamo (contiene symbol/direction/module + tutte le 34 feature)
   //    e ci iniettiamo i campi esito subito dopo la "{".
   if(StringLen(featuresJSON) > 2)
   {
      string body = featuresJSON;
      int brace = StringFind(body, "{");
      if(brace >= 0)
      {
         string head = StringSubstr(body, 0, brace + 1);
         string rest = StringSubstr(body, brace + 1);
         return head + outcome + "," + rest;
      }
   }

   //--- Fallback: JSON minimale (se per qualche motivo il salvataggio mancasse)
   string json = "{";
   json += outcome + ",";
   json += "\"symbol\":\"" + sym + "\",";
   json += "\"direction\":\"" + direction + "\",";
   json += "\"module\":\"" + module + "\",";
   json += "\"rv\":" + DoubleToString(rv, 2) + ",";
   json += "\"adx\":" + DoubleToString(adx, 1) + ",";
   json += "\"adr_pct\":" + DoubleToString(adrPct, 1) + ",";
   json += "\"hist\":\"" + hist + "\",";
   json += "\"nm\":" + DoubleToString(normMom, 4) + ",";
   json += "\"nm_accel\":" + DoubleToString(momAccel, 4) + ",";
   json += "\"nm_dist\":" + DoubleToString(momDist, 4) + ",";
   json += "\"is_compressing\":" + (isCompress ? "true" : "false");
   json += "}";
   return json;
}

