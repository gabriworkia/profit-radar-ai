//+------------------------------------------------------------------+
// |  CHECK REVERSAL OUTCOMES — calcola l'esito dopo N candele         |
// |  Aggiorna PRP_ReversalSignals.csv: il reversal sarebbe andato OK? |
//+------------------------------------------------------------------+
void CheckReversalOutcomes()
{
   //--- Legge le righe PENDING direttamente dal CSV (robusto ai riavvii dell'EA).
   //    Per ogni segnale maturo (>= REV_OUTCOME_BARS candele), calcola l'esito.
   string file = "PRP_ReversalSignals.csv";
   int handle = FileOpen(file, FILE_CSV | FILE_READ | FILE_ANSI, ';');
   if(handle == INVALID_HANDLE) return;

   #define REV_TOT_COLS 42
   string pendTime[];   string pendSym[]; string pendDir[]; double pendEntry[];
   ArrayResize(pendTime, 0); ArrayResize(pendSym, 0); ArrayResize(pendDir, 0); ArrayResize(pendEntry, 0);

   int colIdx = 0;
   string cells[REV_TOT_COLS];
   for(int i = 0; i < REV_TOT_COLS; i++) cells[i] = "";

   //--- Scorri il CSV cella per cella, raccogli le righe con Outcome=PENDING
   while(!FileIsEnding(handle))
   {
      string cell = FileReadString(handle);
      if(colIdx < REV_TOT_COLS) cells[colIdx] = cell;
      colIdx++;
      if(FileIsLineEnding(handle))
      {
         //--- riga completa: e' un segnale PENDING valido? (col 41 = Outcome)
         if(colIdx >= REV_TOT_COLS && cells[41] == "PENDING" && cells[0] != "Time"
            && cells[1] != "TESTPAIR")
         {
            int n = ArraySize(pendTime);
            ArrayResize(pendTime, n+1); ArrayResize(pendSym, n+1);
            ArrayResize(pendDir, n+1);  ArrayResize(pendEntry, n+1);
            pendTime[n]  = cells[0];
            pendSym[n]   = cells[1];
            pendDir[n]   = cells[2];
            pendEntry[n] = StringToDouble(cells[34]);   // Entry
         }
         colIdx = 0;
         for(int k = 0; k < REV_TOT_COLS; k++) cells[k] = "";
      }
   }
   FileClose(handle);

   //--- Per ogni PENDING, se maturo calcola l'esito e aggiorna il CSV
   for(int p = 0; p < ArraySize(pendTime); p++)
   {
      string sym  = pendSym[p];
      datetime sigTime = StringToTime(pendTime[p]);
      int barsAgo = iBarShift(NormSym(sym), PERIOD_M15, sigTime, false);
      if(barsAgo < REV_OUTCOME_BARS) continue;   // non ancora maturo

      double entry = pendEntry[p];
      bool isLong = (pendDir[p] == "BUY");
      double priceNow = iClose(NormSym(sym), PERIOD_M15, 1);
      if(priceNow <= 0) continue;   // dato mancante, riprova al prossimo giro

      int digits = (int)MarketInfo(NormSym(sym), MODE_DIGITS);
      double point = MarketInfo(NormSym(sym), MODE_POINT);
      double pipMult = (digits == 3 || digits == 5) ? 10.0 : 1.0;
      double pipSize = point * pipMult;

      double move = isLong ? (priceNow - entry) : (entry - priceNow);
      double pips = (pipSize > 0) ? move / pipSize : 0;
      string outcome = (move > 0) ? "WIN" : "LOSS";

      UpdateReversalOutcome(sym, sigTime, priceNow, pips, outcome, digits);

      Print("[REV-OBS] Esito ", sym, " ", (isLong ? "BUY" : "SELL"),
            " dopo ", barsAgo, " candele: ", outcome,
            " (", DoubleToString(pips, 1), " pips)");
   }
}

//+------------------------------------------------------------------+
// |  UPDATE REVERSAL OUTCOME — riscrive la riga con l'esito calcolato |
//+------------------------------------------------------------------+
void UpdateReversalOutcome(string sym, datetime sigTime, double priceAfter,
                           double pips, string outcome, int digits)
{
   string file = "PRP_ReversalSignals.csv";
   string sigTimeStr = TimeToString(sigTime, TIME_DATE | TIME_MINUTES);

   //--- Leggi tutto il file in memoria, riga per riga (cella per cella)
   int handle = FileOpen(file, FILE_CSV | FILE_READ | FILE_ANSI, ';');
   if(handle == INVALID_HANDLE) return;

   #define REV_CSV_COLS 42   // colonne totali (le ultime 3 = PriceAfter, PipsMove, Outcome)
   string allRows[];
   ArrayResize(allRows, 0);
   int colIdx = 0;
   string rowCells[REV_CSV_COLS];
   for(int i = 0; i < REV_CSV_COLS; i++) rowCells[i] = "";

   while(!FileIsEnding(handle))
   {
      string cell = FileReadString(handle);
      if(colIdx < REV_CSV_COLS) rowCells[colIdx] = cell;
      colIdx++;
      if(FileIsLineEnding(handle))
      {
         int oC = REV_CSV_COLS - 1;   // Outcome
         int pC = REV_CSV_COLS - 2;   // PipsMove
         int paC = REV_CSV_COLS - 3;  // PriceAfter
         //--- Riga completa: e' quella da aggiornare? (match Time + Symbol, ancora PENDING)
         if(rowCells[0] == sigTimeStr && rowCells[1] == sym && rowCells[oC] == "PENDING")
         {
            rowCells[paC] = DoubleToString(priceAfter, digits);
            rowCells[pC]  = DoubleToString(pips, 1);
            rowCells[oC]  = outcome;
         }
         //--- Ricostruisci la riga (solo le colonne effettivamente lette)
         int lastCol = (colIdx < REV_CSV_COLS) ? colIdx : REV_CSV_COLS;
         string rebuilt = "";
         for(int k = 0; k < lastCol; k++)
         {
            rebuilt += rowCells[k];
            if(k < lastCol - 1) rebuilt += ";";
         }
         int sz = ArraySize(allRows);
         ArrayResize(allRows, sz + 1);
         allRows[sz] = rebuilt;
         //--- reset
         colIdx = 0;
         for(int k = 0; k < REV_CSV_COLS; k++) rowCells[k] = "";
      }
   }
   FileClose(handle);

   //--- Riscrivi il file (uso FileWriteString per scrivere la riga gia' formattata
   //    con i ';' senza che MQL4 aggiunga virgolette o separatori extra)
   int wh = FileOpen(file, FILE_BIN | FILE_WRITE | FILE_ANSI);
   if(wh == INVALID_HANDLE) return;
   for(int i = 0; i < ArraySize(allRows); i++)
      FileWriteString(wh, allRows[i] + "\r\n");
   FileClose(wh);
}

//+------------------------------------------------------------------+
// |  PROCESS REVERSAL                                                 |
//+------------------------------------------------------------------+
void ProcessReversal()
{
   //--- Gira se il Reversal e' attivo OPPURE in modalita' osservazione (solo log)
   if(!InpReversalOn && !InpReversalObserve) return;

   //--- Calcola gli esiti dei segnali Reversal passati (dopo REV_OUTCOME_BARS)
   CheckReversalOutcomes();

   if(GetTradeSlot() == 0) return;
   if(!g_reversalTracked) return;
   int openCount = CountOpenPositions();

   int candidates[MAX_PAIRS];
   int revScores[MAX_PAIRS];
   int revQuality[MAX_PAIRS];
   ArrayInitialize(candidates, 0);
   ArrayInitialize(revScores, 0);
   ArrayInitialize(revQuality, 0);
   int candidateCount = 0;

   for(int i = 0; i < g_dataCount; i++)
   {
      double absRV = MathAbs(g_radarValue[i]);
      double absPrevRV = MathAbs(g_prevRV[i]);

      double minRV = InpReversalRV;
      if(InpDynamicReversalOn && g_dynamicReversalRV[i] > 0)
      {
         minRV = g_dynamicReversalRV[i];
      }
      if(absRV < minRV)
      {
         Print("[REV] ", g_symbol[i], " SCARTATO: |RV|=", DoubleToString(absRV, 1), " < ", DoubleToString(minRV, 1), " (trend non estremo dinamico)");
         continue;
      }
      if(absRV > InpReversalRVMax)
      {
         Print("[REV] ", g_symbol[i], " SCARTATO: |RV|=", DoubleToString(absRV, 1), " > ", InpReversalRVMax, " (gia' invertito/corrotto)");
         continue;
      }
      if(g_radarValue[i] == 0) continue;

      if(absRV > 150)
      {
         Print("[REV] ", g_symbol[i], " SCARTATO: |RV|=", DoubleToString(absRV, 1), " > 150 (anomalo)");
         continue;
      }

      if(g_adx[i] < 20)
      {
         // ADX < 20 = trend troppo debole per un reversal sensato (mediana gruppo B = 28)
         Print("[REV] ", g_symbol[i], " SCARTATO: ADX=", DoubleToString(g_adx[i], 1), " < 20");
         continue;
      }

      //=== VETO EMA GAP: medie mobili devono essere distanti ===
      // Se EMA21 e EMA200 sono vicine, non c'e' un trend definito da invertire.
      double revEmaGap = MathAbs(g_emaGapPct[i]);
      if(revEmaGap < InpRevMinEMAGapPct)
      {
         Print("[REV] ", g_symbol[i], " SCARTATO: EMA gap=", DoubleToString(revEmaGap, 3), "% < ", DoubleToString(InpRevMinEMAGapPct, 2), "% (trend non definito)");
         continue;
      }

      int qCount = 0;
      string details = "";
      int hist = g_histogramState[i];

      // Q1
      if(g_adrPercent[i] >= InpReversalADR) qCount++;
      else StringConcatenate(details, details, "ADR=" + DoubleToString(g_adrPercent[i], 0) + "% ");

      // Q2 (ADX: trend deve essere maturo ma non debole)
      if(g_adx[i] >= 25) qCount++;
      else StringConcatenate(details, details, "ADX=" + DoubleToString(g_adx[i], 0) + " ");

      // Q3 - SEQUENZA COLORI: entrata SOLO al primo LIGHT dopo GRAY
      // Sequenza corretta reversal:
      //   RED_LIGHT -> RED_DARK (barre si accorciano) -> GRAY -> GREEN_LIGHT = LONG
      //   GREEN_LIGHT -> GREEN_DARK (barre si accorciano) -> GRAY -> RED_LIGHT = SHORT
      // GRAY da solo NON basta: e' solo un segnale di attesa.
      // DARK NON basta: il trend e' ancora forte.
      // Serve la PRIMA candela LIGHT dopo il GRAY.
      bool histOK = false;
      if(hist == HS_GRAY)
      {
         // GRAY = momentum azzerato, ma NON entrare ancora
         // Bisogna aspettare la conferma del nuovo colore
         StringConcatenate(details, details, "Hist=GRAY (aspetta conferma) ");
      }
      else if(hist == HS_GREEN_DARK || hist == HS_RED_DARK)
      {
         // DARK = trend ancora forte, non e' il momento
         StringConcatenate(details, details, "Hist=" + HistStateStr(hist) + " (trend forte, aspetta) ");
      }
      else if(hist == HS_GREEN_LIGHT || hist == HS_RED_LIGHT)
      {
         // Prima candela LIGHT dopo GRAY = momento dell'entrata
         // HARD LIMIT: se sono passate troppe candele dal GRAY, scarta
         if(g_histBarsSinceGray[i] > 3)
         {
            StringConcatenate(details, details, "Hist=" + HistStateStr(hist) + " (too late, " + IntegerToString(g_histBarsSinceGray[i]) + " bars>3) ");
         }
         else if(g_histBarsSinceGray[i] <= 1)
            histOK = true;
         else
         {
            // 2-3 bars = margine accettabile ma con warning
            histOK = true;
         }
      }
      
      if(histOK) qCount++;

      // Q3b - FILTRO RX: segnale R-X NEW-H/NEW-L
      if(InpRevReqRX)
      {
         if(g_rxPresent[i] && (g_rxType[i] == RX_NEW_H || g_rxType[i] == RX_NEW_L))
            qCount++;  // RX confermato
         else
            StringConcatenate(details, details, "RX=missing ");
      }
      else
         qCount++;  // RX non richiesto, punto automatico

      // Q4
      bool decelerating = false;
      bool hasDivergence = false;
      bool trendIsShort = (g_radarValue[i] < 0);

      if(absPrevRV > 0)
      {
         double decel = absPrevRV - absRV;
         if(decel >= InpRevMinDecel) decelerating = true;
      }

      if(g_prev2RV[i] != 0)
      {
         if(absRV < MathAbs(g_prev2RV[i])) hasDivergence = true;
      }
      else
      {
         hasDivergence = true;
      }

      if(decelerating || hasDivergence) qCount++;
      else StringConcatenate(details, details, "NoDecel ");

      if(qCount < g_revMinQuality)
      {
         Print("[REV] ", g_symbol[i], " filtri: ", qCount, "/5 < min ", g_revMinQuality);
         continue;
      }

      bool isLong = (g_radarValue[i] < 0);
      string sym = g_symbol[i];

      if(HasOpenPosition(sym)) continue;
      // doppia esposizione rimossa
      if(!SpreadOK(sym)) continue;
      if(!MarketOpen(sym)) continue;

      int score = -100;
      score -= (qCount * 25);
      if(absRV >= 80)      score -= 30;
      else if(absRV >= 65) score -= 20;
      else                 score -= 5;

      if(decelerating && absPrevRV > 0)
      {
         double decelAmt = absPrevRV - absRV;
         if(decelAmt >= 15)     score -= 25;
         else if(decelAmt >= 10) score -= 15;
      }

      if(g_histFlipBar[i] == 0)      score -= 20;
      else if(g_histFlipBar[i] == 1) score -= 10;

      if(hist == HS_GRAY) score -= 15;

      candidates[candidateCount] = i;
      revScores[candidateCount] = score;
      revQuality[candidateCount] = qCount;
      candidateCount++;

      Print("[REV] ", sym, " ", (isLong ? "BUY" : "SELL"),
            " | ", qCount, "/5 | RV=", DoubleToString(g_radarValue[i], 1),
            " | ADX=", DoubleToString(g_adx[i], 0),
            " | score=", score);
   }

   if(candidateCount == 0) return;

   // Sort per score
   for(int i = 0; i < candidateCount - 1; i++)
   {
      for(int j = i + 1; j < candidateCount; j++)
      {
         if(revScores[j] < revScores[i])
         {
            int tempS = revScores[i]; revScores[i] = revScores[j]; revScores[j] = tempS;
            int tempC = candidates[i]; candidates[i] = candidates[j]; candidates[j] = tempC;
            int tempQ = revQuality[i]; revQuality[i] = revQuality[j]; revQuality[j] = tempQ;
         }
      }
   }

   Print("[REV] Candidati: ", candidateCount, " | Best: ", g_symbol[candidates[0]]);

   // Apri trade reversal
   for(int c = 0; c < candidateCount && openCount < InpMaxConcurrent; c++)
   {
      int idx = candidates[c];
      bool revIsLong = (g_radarValue[idx] < 0);
      string revSym = g_symbol[idx];

      //--- Filtro NO BUY anche per Reversal
      if(InpNoBUY && revIsLong)
      {
         Print("[REV] ", revSym, " BLOCCATO: filtro NO BUY attivo");
         continue;
      }

      //--- Blacklist simboli anche per Reversal
      if(InpSymbolBlacklist != "" && StringFind(InpSymbolBlacklist, revSym) >= 0)
      {
         Print("[REV] ", revSym, " BLOCCATO: simbolo in blacklist");
         continue;
      }

      double revSL = CalculateATR_SL(revSym, revIsLong);
      double revEntry = revIsLong ? MarketInfo(revSym, MODE_ASK) : MarketInfo(revSym, MODE_BID);

      if(revIsLong && revSL >= revEntry) continue;
      if(!revIsLong && revSL <= revEntry) continue;

      double ema21 = iMA(revSym, PERIOD_M15, 21, 0, MODE_EMA, PRICE_CLOSE, 0);
      int revDigits = (int)MarketInfo(revSym, MODE_DIGITS);
      double revTP = NormalizeDouble(ema21, revDigits);

      double slDist = MathAbs(revEntry - revSL);
      double tpDist = MathAbs(revTP - revEntry);

      if(tpDist <= 0 || tpDist / slDist < InpMinRR)
      {
         tpDist = slDist * 2.0;
         if(revIsLong) revTP = NormalizeDouble(revEntry + tpDist, revDigits);
         else          revTP = NormalizeDouble(revEntry - tpDist, revDigits);
      }

      //--- Lotto Reversal: usa InpRevLots dedicato (se >0), altrimenti il lotto standard.
      //    Cosi' il Reversal puo' restare a lotto minimo (test) anche con Standard a lotto piu' alto.
      double revLots;
      if(InpRevLots > 0)
      {
         double minL = MarketInfo(revSym, MODE_MINLOT);
         double maxL = MarketInfo(revSym, MODE_MAXLOT);
         double step = MarketInfo(revSym, MODE_LOTSTEP);
         revLots = InpRevLots;
         if(step > 0) revLots = MathFloor(revLots / step) * step;
         revLots = NormalizeDouble(revLots, 2);
         if(revLots < minL) revLots = minL;
         if(revLots > maxL) revLots = maxL;
      }
      else
         revLots = GetLotSize(revSym);
      if(revLots <= 0) continue;

      //=== MODALITA' OSSERVAZIONE: logga il segnale ma NON apre trade ===
      //    Serve a raccogliere dati reali sul Reversal senza rischiare capitale.
      if(InpReversalObserve && !InpReversalOn)
      {
         int obsConf = -1;
         if(InpUseAI) obsConf = GetAIConfirmation(idx, "REV");
         LogReversalSignal(revSym, revIsLong, g_radarValue[idx], g_adx[idx],
                           g_adrPercent[idx], revEntry, revSL, revTP, obsConf,
                           revQuality[c], idx);
         Print("[REV-OBS] ", revSym, " ", (revIsLong ? "BUY" : "SELL"),
               " | RV=", DoubleToString(g_radarValue[idx], 1),
               " | conf=", obsConf, "% | SOLO LOG (no trade)");
         continue;
      }

      //=== AI CONFIRMATION per REVERSAL ===
      if(InpUseAI)
      {
         int revAIConf = GetAIConfirmation(idx, "REV");

         if(revAIConf < 0)
         {
            // Errore di connessione - NESSUN FALLBACK, trade saltato
            g_aiErrors++;
            g_aiMissedTrades++;
            g_aiMissedLastSymbol = revSym;
            g_aiMissedLastModule = 3; // REV
            Print("============================================");
            Print("[AI][REV] *** OPPORTUNITA' PERSA! ***");
            Print("[AI][REV] Trade SALTATO per ERRORE CONNESSIONE: ", revSym, " [REV]");
            Print("[AI][REV] Motivo: ", g_aiLastError);
            Print("[AI][REV] Totale opportunita' perse: ", g_aiMissedTrades);
            Print("============================================");
            continue;
         }
         else if(revAIConf < InpAIMinConf)
         {
            Print("[AI][REV] Conf ", revAIConf, "% < min ", InpAIMinConf, "% -> SKIP ", revSym);
            g_aiReject++;
            continue;
         }
         else
         {
            Print("[AI][REV] CONFERMATO ", revAIConf, "% -> procedo ", revSym);
            g_aiConfirm++;
         }
      }

      Print(">>> [REV] ", (revIsLong ? "BUY" : "SELL"), " ", revSym,
            " | SL: ", DoubleToString(revSL, revDigits),
            " | TP: ", DoubleToString(revTP, revDigits),
            " | RV: ", DoubleToString(g_radarValue[idx], 1));

      int ticket = OpenOrder(revSym, revIsLong, revLots, revSL, revTP, "REV");
      if(ticket > 0)
      {
         Print(">> Reversal aperto: #", ticket, " ", revSym);
         if(InpUseAI || InpSendFeedback) StoreTradeForFeedback(ticket, idx, "REV", revIsLong);
         openCount++;
      }
   }
}

//+------------------------------------------------------------------+
// |  TRY OPEN TRADE                                                   |
//+------------------------------------------------------------------+
bool TryOpenTrade(int idx, int origin, double minRR)
{
   bool isLong;
   if(origin == ORIGIN_BREAKOUT)
      isLong = (g_histogramState[idx] == HS_GREEN_LIGHT);
   else
      isLong = (g_radarType[idx] == RT_LONG);

   string sym = g_symbol[idx];
   string tag = (origin == ORIGIN_BREAKOUT) ? "BRK" : "STD";

   Print("[TRY] ", sym, " ", tag, " ", (isLong ? "BUY" : "SELL"), " | RV=", DoubleToString(g_radarValue[idx],1), " ADX=", DoubleToString(g_adx[idx],1), " ADR%=", DoubleToString(g_adrPercent[idx],1));

   //--- Filtro NO BUY (dati TradeLog: BUY -24, SELL -1.4)
   if(InpNoBUY && isLong)
   {
      Print("[TRY] ", sym, " BLOCCATO: filtro NO BUY attivo");
      return false;
   }

   //--- Blacklist simboli
   if(InpSymbolBlacklist != "")
   {
      if(StringFind(InpSymbolBlacklist, sym) >= 0)
      {
         Print("[TRY] ", sym, " BLOCCATO: simbolo in blacklist");
         return false;
      }
   }

   if(!SpreadOK(sym))        { Print("[TRY] ", sym, " BLOCCATO: spread troppo alto"); return false; }
   if(!MarketOpen(sym))      { Print("[TRY] ", sym, " BLOCCATO: mercato chiuso"); return false; }
   //--- Fuori sessione principale = pomeriggio. Se il lotto pomeriggio e' 0.00, blocca.
   if(!IsSessionTime())
   {
      if(InpAfternoonLots <= 0)
      {
         Print("[TRY] ", sym, " BLOCCATO: pomeriggio disattivato (sessione ", InpSessionStartUTC, "-", InpSessionEndUTC, " UTC)");
         return false;
      }
   }
   if(HasOpenPosition(sym))  { Print("[TRY] ", sym, " BLOCCATO: posizione già aperta"); return false; }
   // doppia esposizione rimossa

   double entryPrice = isLong ? MarketInfo(sym, MODE_ASK) : MarketInfo(sym, MODE_BID);
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);

   //--- Pip multiplier: broker 5/3 cifre = 10x
   double pipMult = 1.0;
   if(digits == 3 || digits == 5) pipMult = 10.0;
   double pipSize = point * pipMult;

   //--- Distanza minima stop dal broker (stops level + buffer)
   double stopLevelPips = (double)MarketInfo(sym, MODE_STOPLEVEL);
   double minSLDistPips = MathMax(stopLevelPips * 2.0, 10.0); // Minimo 10 pip reali
   double minSLDist = minSLDistPips * pipSize;

   double slPrice = FindFractalSL(sym, isLong);
   if(isLong && slPrice >= entryPrice)
   {
      slPrice = CalculateATR_SL(sym, true);
      if(slPrice >= entryPrice) { Print("[TRY] ", sym, " BLOCCATO: SL sopra entry (fractal+ATR)"); return false; }
   }
   if(!isLong && slPrice <= entryPrice)
   {
      slPrice = CalculateATR_SL(sym, false);
      if(slPrice <= entryPrice) { Print("[TRY] ", sym, " BLOCCATO: SL sotto entry (fractal+ATR)"); return false; }
   }

   //--- Verifica distanza minima SL dal broker (evita err 130)
   double slDist = MathAbs(entryPrice - slPrice);
   if(slDist < minSLDist)
   {
      Print("[TRY] ", sym, " SL troppo vicino: ", DoubleToString(slDist/pipSize, 1), " pips < min ", DoubleToString(minSLDistPips, 1), " -> allargo");
      if(isLong)
         slPrice = NormalizeDouble(entryPrice - minSLDist, digits);
      else
         slPrice = NormalizeDouble(entryPrice + minSLDist, digits);
   }

   double tpPrice = CalculateTP(sym, entryPrice, slPrice, isLong, idx, minRR);
   if(tpPrice <= 0) { Print("[TRY] ", sym, " BLOCCATO: TP=0 (pipResidui=", DoubleToString(g_media10gg[idx]-g_pipFatti[idx],1), " media10gg=", DoubleToString(g_media10gg[idx],1), " pipFatti=", DoubleToString(g_pipFatti[idx],1), ")"); return false; }

   double lots = GetLotSize(sym);
   if(lots <= 0) { Print("[TRY] ", sym, " BLOCCATO: lots=0"); return false; }
   //--- SAFETY LOTTO: protezione contro outlier/errori manuali (es. 1.00 lot)
   if(lots > InpMaxLotsSafety)
   {
      Print("[TRY] ", sym, " BLOCCATO: lots=", DoubleToString(lots, 2),
            " > safety max ", DoubleToString(InpMaxLotsSafety, 2),
            " (protezione outlier)");
      return false;
   }

   double rr = MathAbs(tpPrice - entryPrice) / MathAbs(entryPrice - slPrice);

   //=== AI CONFIRMATION ===
   if(InpUseAI)
   {
      int aiConf = GetAIConfirmation(idx, tag);

      if(aiConf < 0)
      {
         // Errore di connessione - NESSUN FALLBACK, trade saltato
         g_aiErrors++;
         g_aiMissedTrades++;
         g_aiMissedLastSymbol = sym;
         g_aiMissedLastModule = 1; // STD
         Print("============================================");
         Print("[AI] *** OPPORTUNITA' PERSA! ***");
         Print("[AI] Trade SALTATO per ERRORE CONNESSIONE: ", sym, " [", tag, "]");
         Print("[AI] Motivo: ", g_aiLastError);
         Print("[AI] Totale opportunita' perse per timeout: ", g_aiMissedTrades);
         Print("[AI] Se il server era in sleep, considera warm-up ping");
         Print("[AI] Warm-up status: ", (g_warmupOK ? "OK" : "MAI CONNESSO"),
               " | Ping OK: ", g_warmupTotalOK, " | Fail: ", g_warmupTotalFail);
         Print("============================================");
         return false;
      }
      else if(aiConf < InpAIMinConf)
      {
         Print("[AI] Confidenza ", aiConf, "% < min ", InpAIMinConf, "% -> SKIP ", sym);
         g_aiReject++;
         return false;
      }
      else
      {
         Print("[AI] CONFERMATO ", aiConf, "% >= ", InpAIMinConf, "% -> procedo ", sym);
         g_aiConfirm++;
      }
   }

   Print(">>> [", tag, "] ", (isLong ? "BUY" : "SELL"), " ", sym,
         " | Entry: ", DoubleToString(entryPrice, digits),
         " | SL: ", DoubleToString(slPrice, digits),
         " | TP: ", DoubleToString(tpPrice, digits),
         " | R:R: ", DoubleToString(rr, 2),
         " | RV: ", DoubleToString(g_radarValue[idx], 1));

   int ticket = OpenOrder(sym, isLong, lots, slPrice, tpPrice, tag);
   if(ticket > 0)
   {
      Print("[", tag, "] Ordine aperto: #", ticket, " ", sym);
      //--- Registra il trade per il feedback (anche con AI off, se raccogliamo dati)
      if(InpUseAI || InpSendFeedback) StoreTradeForFeedback(ticket, idx, tag, isLong);
      return true;
   }
   return false;
}

//+------------------------------------------------------------------+
// |  SORT CANDIDATES                                                  |
//+------------------------------------------------------------------+
void SortCandidates(int &candidates[], int count)
{
   for(int i = 0; i < count - 1; i++)
   {
      for(int j = i + 1; j < count; j++)
      {
         if(g_score[candidates[j]] < g_score[candidates[i]])
         {
            int temp = candidates[i];
            candidates[i] = candidates[j];
            candidates[j] = temp;
         }
      }
   }
}

//+------------------------------------------------------------------+
// |  OPEN ORDER - ECN                                                 |
//+------------------------------------------------------------------+
int OpenOrder(string sym, bool isLong, double lots, double sl, double tp, string tag)
{
   int digits = (int)MarketInfo(sym, MODE_DIGITS);
   double point = MarketInfo(sym, MODE_POINT);
   int cmd = isLong ? OP_BUY : OP_SELL;
   double price = NormalizeDouble(isLong ? MarketInfo(sym, MODE_ASK) : MarketInfo(sym, MODE_BID), digits);
   string comment = "PRP_" + tag + "_" + TimeToStr(TimeCurrent(), TIME_DATE | TIME_MINUTES);

   //--- Pip multiplier per broker 5/3 cifre
   double pipMult = 1.0;
   if(digits == 3 || digits == 5) pipMult = 10.0;
   double pipSize = point * pipMult;

   //--- Verifica distanza minima SL/TP in PIP reali
   double stopLevelPips = (double)MarketInfo(sym, MODE_STOPLEVEL);
   double minDistPips = MathMax(stopLevelPips * 1.2, 5.0); // Almeno 5 pip
   double minDist = minDistPips * pipSize;

   double slDist = MathAbs(price - sl);
   double tpDist = MathAbs(tp - price);

   if(slDist < minDist || tpDist < minDist)
   {
      Print("[ECN] RIFIUTATO: ", sym, " SL dist=", DoubleToString(slDist/pipSize,1),
            " TP dist=", DoubleToString(tpDist/pipSize,1), " pips | min richiesto=", DoubleToString(minDistPips,1));
      return -1;
   }

   int ticket = OrderSend(sym, cmd, lots, price, InpMaxSlippage,
                           0, 0, comment, InpMagicNumber, 0,
                           isLong ? clrLime : clrRed);

   if(ticket < 0)
   {
      Print("OrderSend FALLITO: ", sym, " | Err: ", GetLastError());
      return -1;
   }

   if(!OrderSelect(ticket, SELECT_BY_TICKET))
      return ticket;

   double slNorm = NormalizeDouble(sl, digits);
   double tpNorm = NormalizeDouble(tp, digits);

   Sleep(200);
   RefreshRates();

   if(!OrderModify(ticket, OrderOpenPrice(), slNorm, tpNorm, 0, clrBlue))
   {
      Sleep(500);
      RefreshRates();
      if(!OrderModify(ticket, OrderOpenPrice(), slNorm, tpNorm, 0, clrBlue))
         Print("[ECN] OrderModify retry fallito: #", ticket, " err ", GetLastError());
   }

   return ticket;
}

//+------------------------------------------------------------------+
// |  MANAGE OPEN TRADES                                               |
//+------------------------------------------------------------------+
void ManageOpenTrades()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;

      string sym    = OrderSymbol();
      int    ticket = OrderTicket();
      bool   isLong = (OrderType() == OP_BUY);
      double entry  = OrderOpenPrice();
      double curSL  = OrderStopLoss();
      double curTP  = OrderTakeProfit();
      int    digits = (int)MarketInfo(sym, MODE_DIGITS);
      double point  = MarketInfo(sym, MODE_POINT);
      if(point <= 0) continue;

      double stopLevel = MarketInfo(sym, MODE_STOPLEVEL) * point;
      double bid = MarketInfo(sym, MODE_BID);
      double ask = MarketInfo(sym, MODE_ASK);

      double pipMult = 1.0;
      if(digits == 3 || digits == 5) pipMult = 10.0;

      double profitPips;
      if(isLong) profitPips = (bid - entry) / point / pipMult;
      else       profitPips = (entry - ask) / point / pipMult;

      double R = MathAbs(entry - curSL);

      //=== BREAK-EVEN ===
      if(profitPips >= InpBEPips && R > 0)
      {
         double bePipDist = InpBEProfit * point * pipMult;
         double beSL;

         if(isLong) beSL = NormalizeDouble(entry + bePipDist, digits);
         else       beSL = NormalizeDouble(entry - bePipDist, digits);

         bool needBE = false;
         if(isLong  && (curSL < beSL || curSL == 0)) needBE = true;
         if(!isLong && (curSL > beSL || curSL == 0)) needBE = true;

         if(needBE)
         {
            if(OrderModify(ticket, entry, beSL, curTP, 0, clrGold))
            {
               Print("[BE] ", sym, " #", ticket, " SL -> entry+", InpBEProfit, " pip");
               curSL = beSL;
               R = MathAbs(entry - curSL);
            }
         }
      }

      //=== TRAILING EMA21 + ATR ===
      if(!InpTrailingOn) continue;
      if(R <= 0) continue;

      double profitDistance = 0;
      double originalR = MathAbs(entry - curSL);
      double pipSizeStep = InpTrailStepPips * point * pipMult;  // distanza minima per muovere SL

      if(isLong)
         profitDistance = bid - entry;
      else
         profitDistance = entry - ask;

      if(originalR <= 0) continue;

      double currentR = profitDistance / originalR;

      if(currentR >= InpTrailActivate)
      {
         double ema = iMA(sym, PERIOD_M15, 21, 0, MODE_EMA, PRICE_CLOSE, 0);
         double atr = iATR(sym, PERIOD_M15, InpATR_Period, 0);

         if(ema > 0 && atr > 0)
         {
            double newSL;

            if(isLong)
            {
               newSL = NormalizeDouble(ema - (InpTrailATRMult * atr), digits);
               if(newSL > curSL && (newSL - curSL) >= pipSizeStep && (bid - newSL) > (stopLevel + point))
               {
                  if(OrderModify(ticket, entry, newSL, curTP, 0, clrGreen))
                     Print("[TRAIL] ", sym, " #", ticket, " BUY SL -> ", DoubleToString(newSL, digits));
               }
            }
            else
            {
               newSL = NormalizeDouble(ema + (InpTrailATRMult * atr), digits);
               if(newSL < curSL && (curSL - newSL) >= pipSizeStep && (newSL - ask) > (stopLevel + point))
               {
                  if(OrderModify(ticket, entry, newSL, curTP, 0, clrRed))
                     Print("[TRAIL] ", sym, " #", ticket, " SELL SL -> ", DoubleToString(newSL, digits));
               }
            }
         }
      }
   }
}

//+------------------------------------------------------------------+
// |  EARLY EXIT — helper: conta candele GRAY consecutive per ticket   |
//+------------------------------------------------------------------+
//--- Registra che il ticket vede GRAY nella candela 'bar'. Ritorna quante
//    candele M15 GRAY consecutive ha accumulato.
int RegisterGrayBar(int ticket, datetime bar)
{
   //--- Cerca lo slot del ticket
   for(int i = 0; i < g_eeGrayN; i++)
   {
      if(g_eeGrayTicket[i] == ticket)
      {
         if(g_eeGrayLastBar[i] == bar) return g_eeGrayCount[i];   // stessa candela, gia' contata
         //--- Nuova candela: e' consecutiva alla precedente?
         if(bar - g_eeGrayLastBar[i] <= 15 * 60 + 5)   // ~1 candela M15 di distanza
            g_eeGrayCount[i]++;
         else
            g_eeGrayCount[i] = 1;   // gap -> riparte
         g_eeGrayLastBar[i] = bar;
         return g_eeGrayCount[i];
      }
   }
   //--- Nuovo ticket: crea slot
   int slot = g_eeGrayN;
   if(slot >= MAX_TRADES_TRACK)
   {
      // ricicla il primo
      for(int s = 0; s < MAX_TRADES_TRACK - 1; s++)
      {
         g_eeGrayTicket[s]  = g_eeGrayTicket[s+1];
         g_eeGrayLastBar[s] = g_eeGrayLastBar[s+1];
         g_eeGrayCount[s]   = g_eeGrayCount[s+1];
      }
      slot = MAX_TRADES_TRACK - 1;
   }
   else g_eeGrayN++;
   g_eeGrayTicket[slot]  = ticket;
   g_eeGrayLastBar[slot] = bar;
   g_eeGrayCount[slot]   = 1;
   return 1;
}

//--- Azzera il contatore GRAY di un ticket (quando torna colorato)
void ResetGrayBar(int ticket)
{
   for(int i = 0; i < g_eeGrayN; i++)
      if(g_eeGrayTicket[i] == ticket) { g_eeGrayCount[i] = 0; return; }
}

//+------------------------------------------------------------------+
// |  EARLY EXIT                                                       |
//+------------------------------------------------------------------+
void CheckEarlyExit()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if(OrderMagicNumber() != InpMagicNumber) continue;
      if(OrderType() > OP_SELL) continue;

      string sym  = OrderSymbol();
      bool isLong = (OrderType() == OP_BUY);

      string ordComment = OrderComment();
      if(StringFind(ordComment, "PRP_TEST") >= 0) continue;

      //--- ESCLUSIONE REVERSAL: i trade REV entrano APPOSTA contro l'istogramma
      //    (es. BUY su rosso esteso). L'Early Exit li chiuderebbe subito -> li saltiamo.
      if(StringFind(ordComment, "PRP_REV") >= 0) continue;

      //--- RITARDO: non toccare un trade appena aperto. Aspetta che sia passata
      //    almeno 1 candela M15 chiusa dall'apertura, cosi' non reagisce al rumore
      //    immediato (discrepanza CSV/live al momento dell'ingresso).
      int barsSinceOpen = iBarShift(NormSym(sym), PERIOD_M15, OrderOpenTime(), false);
      if(barsSinceOpen < 1) continue;   // ancora nella candela di apertura

      //--- Legge lo stato istogramma FRESCO dall'indicatore (candela 1, chiusa)
      double rvNow;
      string histStr;
      GetRadarData(NormSym(sym), 1, rvNow, histStr);
      int histNow = ParseHistogramState(histStr);

      //--- Se il dato manca (NONE/UNKNOWN), non decidere su dati incerti
      if(histNow == HS_UNKNOWN) continue;

      int ticket = OrderTicket();
      datetime curBar = iTime(NormSym(sym), PERIOD_M15, 1);   // candela chiusa di riferimento

      bool shouldClose = false;
      string reason = "";

      //=== CONDIZIONE 1: colore NETTAMENTE OPPOSTO (inversione forte) ===
      //    SELL -> diventa VERDE, BUY -> diventa ROSSO. Uscita immediata (trend invertito).
      if(isLong && (histNow == HS_RED_LIGHT || histNow == HS_RED_DARK))
      {
         shouldClose = true; reason = "inversione a " + histStr;
      }
      else if(!isLong && (histNow == HS_GREEN_LIGHT || histNow == HS_GREEN_DARK))
      {
         shouldClose = true; reason = "inversione a " + histStr;
      }

      //=== CONDIZIONE 2: GRAY confermato per N candele (trend fermo) ===
      //    Il rosso/verde si e' spento. Chiudi solo se resta GRAY per EARLY_GRAY_BARS
      //    candele M15 consecutive (non un flip momentaneo).
      if(!shouldClose)
      {
         if(histNow == HS_GRAY)
         {
            int grayBars = RegisterGrayBar(ticket, curBar);
            if(grayBars >= EARLY_GRAY_BARS)
            {
               shouldClose = true;
               reason = "GRAY confermato (" + IntegerToString(grayBars) + " candele)";
            }
         }
         else
         {
            //--- Tornato colorato nella direzione giusta -> azzera il contatore GRAY
            ResetGrayBar(ticket);
         }
      }

      if(shouldClose)
      {
         Print("[EARLY-EXIT] ", sym, " #", ticket, " ", (isLong ? "BUY" : "SELL"),
               " chiuso: ", reason);
         CloseOrder(ticket);
      }
   }
}

