//+------------------------------------------------------------------+
// |  HISTOGRAM TRACKING                                               |
//+------------------------------------------------------------------+
void UpdateHistogramTracking()
{
   for(int i = 0; i < g_dataCount; i++)
   {
      int current = g_histogramState[i];
      int prev    = g_prevHistogram[i];

      if(!g_histogramTracked)
      {
         g_lightStreak[i]  = 0;
         g_prevWasGray[i]  = (current == HS_GRAY);
         g_prevHistogram[i] = current;
         continue;
      }

      bool curIsGreenLight = (current == HS_GREEN_LIGHT);
      bool curIsRedLight   = (current == HS_RED_LIGHT);
      bool curIsLight      = (curIsGreenLight || curIsRedLight);
      bool prevIsGreenLight = (prev == HS_GREEN_LIGHT);
      bool prevIsRedLight   = (prev == HS_RED_LIGHT);

      bool sameColorLight = false;
      if(curIsGreenLight && prevIsGreenLight) sameColorLight = true;
      if(curIsRedLight   && prevIsRedLight)   sameColorLight = true;

      if(curIsLight && sameColorLight)
      {
         g_lightStreak[i] = g_lightStreak[i] + 1;
      }
      else if(curIsLight && !sameColorLight)
      {
         g_lightStreak[i] = 1;
         g_prevWasGray[i] = (prev == HS_GRAY);
      }
      else
      {
         if(prev == HS_GRAY || current == HS_GRAY)
            g_prevWasGray[i] = true;
         else
            g_prevWasGray[i] = false;
         g_lightStreak[i] = 0;
      }

      g_prevHistogram[i] = current;
   }

   g_histogramTracked = true;
}

//+------------------------------------------------------------------+
// |  HISTOGRAM SEQUENCE FEATURES — Analizza ultime 8 candele          |
// |  Estrae 8 feature numeriche per LightGBM e GPT                    |
//+------------------------------------------------------------------+
//+------------------------------------------------------------------+
// |  CALCOLA FEATURE ISTOGRAMMA PER SIMBOLO                           |
// |  Funzione riutilizzabile: sia per export che per tracking         |
//+------------------------------------------------------------------+
void CalcHistFeatures(string sym,
                      int &outConsec, int &outSinceGray, int &outCycles, int &outCrossedZero,
                      double &outSlope, double &outPullback, int &outSeqEnc, double &outBarRatio)
{
   //--- Leggi ultime 30 candele dell'istogramma (per consecutive, cycles, pullback)
   //--- Ma solo ultime 8 per slope e ratio (più sensibili al recente)
   #define HIST_LOOKBACK 30
   #define HIST_RECENT   8
   int    states[HIST_LOOKBACK];
   double values[HIST_LOOKBACK];
   ArrayInitialize(states, HS_GRAY);
   ArrayInitialize(values, 0);

   for(int b = 0; b < HIST_LOOKBACK; b++)
   {
      string histSt;
      GetRadarData(sym, b + 1, values[b], histSt);
      states[b] = ParseHistogramState(histSt);
   }

   //--- Feature 1: candele consecutive stesso colore (fino a 30)
   outConsec = 0;
   if(states[0] != HS_GRAY)
   {
      bool curIsGreen = (states[0] == HS_GREEN_LIGHT || states[0] == HS_GREEN_DARK);
      outConsec = 1;
      for(int b = 1; b < HIST_LOOKBACK; b++)
      {
         bool bIsGreen = (states[b] == HS_GREEN_LIGHT || states[b] == HS_GREEN_DARK);
         if(curIsGreen == bIsGreen && states[b] != HS_GRAY)
            outConsec++;
         else
            break;
      }
   }

   //--- Feature 2: candele dall'ultimo GRAY (fino a 30)
   outSinceGray = 0;
   for(int b = 0; b < HIST_LOOKBACK; b++)
   {
      if(states[b] == HS_GRAY) break;
      outSinceGray++;
   }

   //--- Feature 3: micro-cicli (ogni cambio di stato esatto nelle ultime 30)
   //    GREEN_LIGHT→GREEN_DARK conta come ciclo (indebolimento)
   //    GREEN→GRAY→RED conta come ciclo (inversione)
   //    GREEN_LIGHT→GREEN_LIGHT NON conta (stesso stato)
   outCycles = 0;
   for(int b = 1; b < HIST_LOOKBACK; b++)
   {
      if(states[b] != states[b-1])
         outCycles++;
   }

   //--- Feature 4: ha attraversato lo zero nelle ultime 30 candele
   outCrossedZero = 0;
   for(int b = 1; b < HIST_LOOKBACK; b++)
   {
      if(values[b] != 0 && values[b-1] != 0)
      {
         if((values[b] > 0 && values[b-1] < 0) || (values[b] < 0 && values[b-1] > 0))
         {
            outCrossedZero = 1;
            break;
         }
      }
   }

   //--- Feature 5: slope altezza barre (regressione lineare ultime 5)
   outSlope = 0;
   {
      int n = 5;
      double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
      for(int b = 0; b < n; b++)
      {
         double av = MathAbs(values[b]);
         sumX  += b;
         sumY  += av;
         sumXY += b * av;
         sumX2 += b * b;
      }
      double denom = n * sumX2 - sumX * sumX;
      if(denom != 0)
         outSlope = (n * sumXY - sumX * sumY) / denom;
   }

   //--- Feature 6: profondità pullback basata sui VALORI, non sul colore
   //    Cerca il minimo relativo (barra più bassa) tra il max e la barra attuale
   //    Misura quanto il trend si è ritirato dal suo massimo
   outPullback = 0;
   {
      double maxVal = 0;
      int maxBar = 0;
      // Trova il massimo assoluto nelle ultime 30
      for(int b = 0; b < HIST_LOOKBACK; b++)
      {
         if(MathAbs(values[b]) > maxVal)
         {
            maxVal = MathAbs(values[b]);
            maxBar = b;
         }
      }

      // Trova il minimo dopo il massimo (pullback dal picco)
      double minAfterMax = maxVal;
      for(int b = maxBar - 1; b >= 0; b--)
      {
         if(MathAbs(values[b]) < minAfterMax)
            minAfterMax = MathAbs(values[b]);
      }

      if(maxVal > 0)
         outPullback = (1.0 - minAfterMax / maxVal) * 100.0;
   }

   //--- Feature 7: sequenza ultime 5 candele encoded (5 stati, base 5)
   //    GRAY=0, GREEN_LIGHT=1, GREEN_DARK=2, RED_LIGHT=3, RED_DARK=4
   outSeqEnc = 0;
   {
      int mult = 1;
      for(int b = 0; b < 5; b++)
      {
         int code = 0;
         if(states[b] == HS_GREEN_LIGHT)      code = 1;
         else if(states[b] == HS_GREEN_DARK)  code = 2;
         else if(states[b] == HS_RED_LIGHT)   code = 3;
         else if(states[b] == HS_RED_DARK)    code = 4;
         outSeqEnc += code * mult;
         mult *= 5;
      }
   }

   //--- Feature 8: rapporto barra attuale / media ultime 7
   outBarRatio = 1.0;
   {
      double currentAbs = MathAbs(values[0]);
      double sumAbs = 0;
      int count = 0;
      for(int b = 1; b < HIST_RECENT; b++)
      {
         if(MathAbs(values[b]) > 0)
         {
            sumAbs += MathAbs(values[b]);
            count++;
         }
      }
      if(count > 0 && sumAbs > 0)
         outBarRatio = currentAbs / (sumAbs / count);
   }
}


void ExtractHistogramFeatures_all()
{
   for(int i = 0; i < g_dataCount; i++)
   {
      int hConsec, hSinceGray, hCycles, hCrossedZero, hSeqEnc;
      double hSlope, hPullback, hBarRatio;
      CalcHistFeatures(g_symbol[i],
                       hConsec, hSinceGray, hCycles, hCrossedZero,
                       hSlope, hPullback, hSeqEnc, hBarRatio);

      g_histConsecColor[i]   = hConsec;
      g_histBarsSinceGray[i] = hSinceGray;
      g_histCycleCount[i]    = hCycles;
      g_histCrossedZero[i]   = (hCrossedZero == 1);
      g_histBarSlope[i]      = hSlope;
      g_histPullbackDepth[i] = hPullback;
      g_histSeqEncoded[i]    = hSeqEnc;
      g_histBarRatio[i]      = hBarRatio;
   }
}

